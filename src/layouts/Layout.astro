---
import { ViewTransitions } from "astro:transitions";
import { SEO } from "astro-seo";
import Footer from "@components/landing/footer.tsx";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "../styles/custom.css";
import { useTranslations, localePath } from "@i18n/utils";
import type { Locale } from "@i18n/utils";

interface Props {
  title?: string;
  footerMargin?: boolean;
  ogImage?: string;
  description?: string;
  lang?: Locale;
}

const { title, footerMargin = true, ogImage, description, lang = "en" } = Astro.props;

const t = useTranslations(lang);

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  ogImage || "/banner.png",
  Astro.site
).toString();

const defaultDescription = t("meta.defaultDescription");
const metaDescription = description || defaultDescription;

const makeTitle = title
  ? title + " | " + t("meta.titleSuffix")
  : t("meta.defaultTitle");

// Compute hreflang paths
const enPath = localePath(Astro.url.pathname, "en");
const esPath = localePath(Astro.url.pathname, "es");
const enUrl = new URL(enPath, Astro.site).toString();
const esUrl = new URL(esPath, Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon"  href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Hreflang tags -->
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@lukepbutler_",
        site: "@lukepbutler_",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: title ? `${title} - ${t("meta.titleSuffix")}` : t("meta.ogAltHome"),
        },
      }}
    />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
      /* Remove arrows from list-style - fix for tailwindcss */
      details > summary.list-none::-webkit-details-marker,
      details > summary.list-none::marker {
        display: none;
      }
    </style>
    <!-- Enable this if you want to use Astro ViewTransitions  -->
    <ViewTransitions />
    <script src="https://ext.epanetjs.com/latest.js" async defer="defer"></script>
  </head>
  <body>
    <Navbar lang={lang} />
    <slot />
    <Footer lang={lang} client:visible />
  </body>
</html>
