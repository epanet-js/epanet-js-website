---
// Security page diagram: an on-premises deployment. The epanet-js
// application, the model data, and the people using it all sit inside the
// customer's own network boundary.
import { Database, Laptop, Server } from "lucide-react";

const nodes = [
  { icon: Laptop, label: "Your users" },
  { icon: Server, label: "epanet-js app" },
  { icon: Database, label: "Model data" },
];
---

<div
  class="relative h-[280px] w-full overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: an on-premises deployment with your users, the epanet-js application, and the model data all inside your own network.">
  <div class="absolute inset-0 flex scale-90 flex-col items-center justify-center sm:scale-100">
  <div
    class="relative rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 px-2 pb-4 pt-7 sm:px-5">
    <span
      class="absolute -top-2.5 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-gray-200 bg-white px-2 py-0.5 text-[9px] font-medium text-gray-500 shadow-sm">
      Your network
    </span>

    <div class="flex items-center justify-center gap-1.5 sm:gap-3">
      {
        nodes.map((node, index) => (
          <>
            {index > 0 && (
              <svg
                viewBox="0 0 24 8"
                class="w-4 shrink-0 sm:w-7"
                aria-hidden="true">
                <path
                  d="M2 4 H22"
                  fill="none"
                  stroke="#d1d5db"
                  stroke-width="2"
                  stroke-dasharray="4 3"
                />
              </svg>
            )}
            <div class="flex shrink-0 flex-col items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-2.5 py-4 shadow-sm sm:px-4">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                <node.icon size={18} />
              </span>
              <p class="text-[10px] font-medium text-gray-700 whitespace-nowrap">
                {node.label}
              </p>
            </div>
          </>
        ))
      }
    </div>
  </div>

  <p class="mt-4 text-center text-[10px] text-gray-400">
    Runs entirely on your own infrastructure.
  </p>
  </div>
</div>
