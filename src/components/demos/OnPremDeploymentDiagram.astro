---
// Security page diagram: an on-premises deployment. The epanet-js
// application, the model data, and the people using it all sit inside the
// customer's own network boundary.
import { Database, Laptop, Server } from "lucide-react";

const nodes = [
  { icon: Laptop, label: "Your users" },
  { icon: Server, label: "epanet-js app" },
  { icon: Database, label: "Model data" },
];
---

<div
  class="relative aspect-[3/2] w-full overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: an on-premises deployment with your users, the epanet-js application, and the model data all inside your own network.">
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="flex h-full w-full flex-col items-center justify-between">
  <div class="box-border flex w-full flex-1 flex-col items-center px-[28px] pb-[28px] pt-[28px]">
  <div
    class="relative flex h-full w-full flex-1 flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 px-6 pb-9 pt-12">
    <span
      class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-gray-200 bg-white px-3 py-1 text-[12px] font-medium text-gray-500 shadow-sm">
      Your network
    </span>

    <div class="flex items-center justify-center gap-[11px]">
      {
        nodes.map((node, index) => (
          <>
            {index > 0 && (
              <svg
                viewBox="0 0 24 8"
                preserveAspectRatio="none"
                class="h-2 flex-1"
                aria-hidden="true">
                <path
                  d="M2 4 H22"
                  fill="none"
                  stroke="#d1d5db"
                  stroke-width="2"
                  stroke-dasharray="4 3"
                />
              </svg>
            )}
            <div class="box-border flex h-[96px] w-[104px] shrink-0 flex-col items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-white px-[7px] py-[11px] shadow-sm">
              <span class="flex h-[45px] w-[45px] items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                <node.icon size={23} />
              </span>
              <p class="text-[12px] font-medium text-gray-700 whitespace-nowrap">
                {node.label}
              </p>
            </div>
          </>
        ))
      }
    </div>
  </div>
  </div>

  <p class="pb-6 text-center text-[14px] font-medium text-gray-700">
    Runs entirely on your own infrastructure
  </p>
      </div>
    </foreignObject>
  </svg>
</div>
