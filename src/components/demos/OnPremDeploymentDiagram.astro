---
// Security page diagram: an on-premises deployment. The epanet-js
// application, the model data, and the people using it all sit inside the
// customer's own network boundary.
import { Database, Laptop, Server } from "lucide-react";
import { useTranslations } from "@i18n/utils";
import type { Locale } from "@i18n/utils";

interface Props {
  lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const nodes = [
  { icon: Laptop, label: t("diagrams.onPremDeployment.yourUsers") },
  { icon: Server, label: t("diagrams.onPremDeployment.appName") },
  { icon: Database, label: t("diagrams.onPremDeployment.modelData") },
];
---

<div
  class="relative mx-auto aspect-[3/2] w-full max-w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label={t("diagrams.onPremDeployment.ariaLabel")}>
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="flex h-full w-full flex-col items-center justify-between">
  <div class="box-border flex w-full flex-1 flex-col items-center px-8 pb-8 pt-8">
  <div
    class="relative flex h-full w-full flex-1 flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 px-6 pb-9 pt-12">
    <span
      class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-gray-200 bg-white px-3 py-1 text-xs font-medium text-gray-500 shadow-sm">
      {t("diagrams.onPremDeployment.yourNetwork")}
    </span>

    <div class="flex items-center justify-center gap-1">
      {
        nodes.map((node, index) => (
          <>
            {index > 0 && (
              <svg
                viewBox="0 0 24 8"
                preserveAspectRatio="none"
                class="h-2 flex-1"
                aria-hidden="true">
                <path
                  d="M2 4 H22"
                  fill="none"
                  stroke="#d1d5db"
                  stroke-width="2"
                  stroke-dasharray="4 3"
                />
              </svg>
            )}
            <div class="box-border flex h-24 w-[104px] shrink-0 flex-col items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-white px-2 py-3 shadow-sm">
              <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                <node.icon size={23} />
              </span>
              <p class="text-xs font-medium text-gray-700 whitespace-nowrap">
                {node.label}
              </p>
            </div>
          </>
        ))
      }
    </div>
  </div>
  </div>

  <p class="pb-6 text-center text-sm font-medium text-gray-700">
    {t("diagrams.onPremDeployment.footer")}
  </p>
      </div>
    </foreignObject>
  </svg>
</div>
