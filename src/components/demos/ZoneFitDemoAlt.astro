---
// Alternate version of ZoneFitDemo, splitting the alt network's 16 pipes
// into 3 calibration zones by distance from the reservoir instead of the
// original's 20-pipe index groups (8/6/2 pipes vs the original's 7/7/6 --
// zone C is deliberately the smallest since it's just the two dead-end
// cul-de-sac tips, the network's own farthest extremity).
import { CheckCircle2, TriangleAlert } from "lucide-react";
import AppWindow from "./AppWindow.astro";
import { pipes, junctions } from "./network-geometry-alt";
import { JUNCTION_COLOR, JUNCTION_RADIUS, OUTLINE_COLOR, OUTLINE_STROKE_WIDTH, PIPE_STROKE_WIDTH } from "./network-style-alt";

const zones = [
  {
    name: "Zone A",
    color: "#3b82f6",
    cls: "zfa-zone-a",
    labelCls: "zfa-label-a",
    rowCls: "zfa-row-a",
    fit: "0.9 m",
    pipes: [0, 1, 2, 3, 4, 6, 7, 15],
    label: { left: "20%", top: "30%" },
  },
  {
    name: "Zone B",
    color: "#22c55e",
    cls: "zfa-zone-b",
    labelCls: "zfa-label-b",
    rowCls: "zfa-row-b",
    fit: "1.4 m",
    pipes: [5, 8, 9, 10, 13, 14],
    label: { left: "55%", top: "75%" },
  },
  {
    name: "Zone C",
    color: "#f59e0b",
    cls: "zfa-zone-c",
    labelCls: "zfa-label-c",
    fit: "3.8 m",
    pipes: [11, 12],
    label: { left: "83%", top: "60%" },
  },
];
---

<AppWindow
  variant="plain"
  altNetwork
  hideHeader
  hideFooter
  label="Zone fit in epanet-js: the network split into three colored calibration zones with a fit figure per zone, the worst-fitting zone pulsing.">
  <!-- zone coloring overlay -->
  <svg
    viewBox="0 0 640 400"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <g stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round" fill="none">
      {
        zones.map((zone) =>
          zone.pipes.map((index, i) => {
            const [x1, y1, x2, y2] = pipes[index];
            return (
              <line
                class={zone.cls}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke={zone.color}
                pathLength="100"
                style={`animation-delay: ${(i * 0.08).toFixed(2)}s`}
              />
            );
          }),
        )
      }
    </g>
    <!-- redraw the junction dots on top of the zone-colored lines, since
         this overlay is a separate sibling painted after NetworkMapAlt's own
         junctions and would otherwise cover them -->
    <g stroke={OUTLINE_COLOR} stroke-width={OUTLINE_STROKE_WIDTH}>
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r={JUNCTION_RADIUS} fill={JUNCTION_COLOR} />
        ))
      }
    </g>
  </svg>

  <!-- zone labels -->
  {
    zones.map((zone) => (
      <span
        class:list={[
          "absolute -translate-x-1/2 rounded border border-gray-200 bg-white px-1.5 py-px text-xs font-medium text-gray-600 shadow-sm",
          zone.labelCls,
        ]}
        style={`left: ${zone.label.left}; top: ${zone.label.top}`}>
        {zone.name}
      </span>
    ))
  }

  <!-- fit-by-zone panel -->
  <div
    class="zfa-panel absolute top-2 right-2 w-[168px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Fit by zone</p>
      <p class="text-xs text-gray-400">Mean error</p>
    </div>
    <div class="py-1 text-xs">
      {
        zones.map((zone, i) => (
          <div
            class:list={[
              "flex items-center justify-between px-3 py-1",
              i === 2 ? "zfa-row-warn" : zone.rowCls,
            ]}>
            <span class="flex items-center gap-1.5 text-gray-600">
              <span
                class="inline-block h-2 w-2 rounded-sm"
                style={`background: ${zone.color}`}
              />
              {zone.name}
            </span>
            <span class="flex items-center gap-1 font-medium text-gray-700 tabular-nums">
              {zone.fit}
              {i === 2 ? (
                <TriangleAlert size={14} className="text-amber-500" />
              ) : (
                <CheckCircle2 size={14} className="text-green-500" />
              )}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</AppWindow>

<style>
  /* zones sweep in one after another */
  .zfa-zone-a,
  .zfa-zone-b,
  .zfa-zone-c {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .zfa-zone-a {
    animation: zfa-draw-a 8s linear infinite both;
  }
  .zfa-zone-b {
    animation: zfa-draw-b 8s linear infinite both;
  }
  .zfa-zone-c {
    animation: zfa-draw-c 8s linear infinite both;
  }
  @keyframes zfa-draw-a {
    0%,
    10% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    18% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes zfa-draw-b {
    0%,
    22% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    30% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes zfa-draw-c {
    0%,
    34% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    42% {
      stroke-dashoffset: 0;
    }
    66% {
      opacity: 1;
    }
    72% {
      opacity: 0.45;
    }
    78% {
      opacity: 1;
    }
    84% {
      opacity: 0.45;
    }
    90% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  .zfa-label-a {
    animation: zfa-label-a-in 8s ease-out infinite both;
  }
  @keyframes zfa-label-a-in {
    0%,
    20.5% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    26.5% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .zfa-label-b {
    animation: zfa-label-b-in 8s ease-out infinite both;
  }
  @keyframes zfa-label-b-in {
    0%,
    32.5% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    38.5% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .zfa-label-c {
    animation: zfa-label-c-in 8s ease-out infinite both;
  }
  @keyframes zfa-label-c-in {
    0%,
    43.5% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    49.5% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  .zfa-panel {
    animation: zfa-panel-in 8s ease-out infinite both;
  }
  @keyframes zfa-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .zfa-row-a {
    animation: zfa-row-a-in 8s ease-out infinite both;
  }
  @keyframes zfa-row-a-in {
    0%,
    20.5% {
      opacity: 0;
      transform: translateY(4px);
    }
    26.5% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .zfa-row-b {
    animation: zfa-row-b-in 8s ease-out infinite both;
  }
  @keyframes zfa-row-b-in {
    0%,
    32.5% {
      opacity: 0;
      transform: translateY(4px);
    }
    38.5% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  @keyframes zfa-row-c-in {
    0%,
    43.5% {
      opacity: 0;
      transform: translateY(4px);
    }
    49.5% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  .zfa-row-warn {
    animation:
      zfa-row-c-in 8s ease-out infinite both,
      zfa-row-tint 8s ease-in-out infinite both;
  }
  @keyframes zfa-row-tint {
    0%,
    66% {
      background-color: transparent;
    }
    72% {
      background-color: #fef3c7;
    }
    78% {
      background-color: #fffbeb;
    }
    84% {
      background-color: #fef3c7;
    }
    92%,
    100% {
      background-color: transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zfa-zone-a,
    .zfa-zone-b,
    .zfa-zone-c,
    .zfa-label-a,
    .zfa-label-b,
    .zfa-label-c,
    .zfa-panel,
    .zfa-row-a,
    .zfa-row-b,
    .zfa-row-warn {
      animation: none;
    }
    .zfa-zone-a,
    .zfa-zone-b,
    .zfa-zone-c {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .zfa-label-a,
    .zfa-label-b,
    .zfa-label-c {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    .zfa-panel,
    .zfa-row-a,
    .zfa-row-b,
    .zfa-row-warn {
      opacity: 1;
      transform: none;
    }
  }
</style>
