---
// Demand pattern editor: the 24-hour multiplier profile for a pattern from
// the library, bars rising into the diurnal shape with a reference line at
// the 1.0x average and a readout chip on the evening peak.
import { ChevronDown } from "lucide-react";

// Hourly multipliers as % of chart height; the 1.0x baseline sits at 55%.
const hours = [
  30, 25, 22, 20, 22, 32, 55, 80, 95, 85, 70, 60, 55, 50, 52, 58, 70, 88, 100,
  92, 75, 60, 45, 35,
];
---

<div
  class="bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden select-none"
  role="img"
  aria-label="Demand pattern editor in epanet-js: a 24-hour diurnal multiplier profile for the residential pattern, with morning and evening peaks reaching 1.8 times average demand at 19:00.">
  <div
    class="flex items-center justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
    <p class="text-[11px] font-semibold text-gray-700">Demand patterns</p>
    <span
      class="flex items-center gap-1 text-[10px] text-gray-600 border border-gray-200 rounded px-1.5 py-0.5">
      Residential
      <ChevronDown size={10} className="text-gray-400" />
    </span>
  </div>
  <div class="px-3 pt-3 pb-2.5">
    <div class="relative h-16">
      <div class="flex items-end gap-px h-full">
        {
          hours.map((height, i) => (
            <span
              class:list={[
                "flex-1 rounded-sm bg-violet-400",
                i === 18 || i === 19 ? "pe-bar-peak" : "pe-bar",
              ]}
              style={`height: ${height}%; animation-delay: ${(i * 0.06).toFixed(2)}s`}
            />
          ))
        }
      </div>
      <div
        class="absolute left-0 right-0 border-t border-dashed border-gray-300"
        style="bottom: 55%">
        <span class="absolute right-0 -top-3 text-[9px] text-gray-400 tabular-nums">
          1.0x
        </span>
      </div>
      <span
        class="pe-chip absolute -top-2 right-[7%] rounded bg-white border border-gray-100 shadow-md px-1.5 py-0.5 text-[9px] text-gray-600 tabular-nums whitespace-nowrap">
        1.8x at 19:00
      </span>
    </div>
    <div class="flex justify-between text-[9px] text-gray-400 tabular-nums mt-1">
      <span>00</span>
      <span>06</span>
      <span>12</span>
      <span>18</span>
      <span>24</span>
    </div>
  </div>
</div>

<style>
  .pe-bar,
  .pe-bar-peak {
    transform-origin: bottom;
  }
  .pe-bar {
    animation: pe-rise 6s ease-in-out infinite both;
  }
  .pe-bar-peak {
    animation: pe-rise-breathe 6s ease-in-out infinite both;
  }
  @keyframes pe-rise {
    0% {
      opacity: 0;
      transform: scaleY(0.1);
    }
    3% {
      opacity: 1;
    }
    12% {
      transform: scaleY(1);
    }
    92% {
      opacity: 1;
      transform: scaleY(1);
    }
    100% {
      opacity: 0;
      transform: scaleY(1);
    }
  }
  @keyframes pe-rise-breathe {
    0% {
      opacity: 0;
      transform: scaleY(0.1);
    }
    3% {
      opacity: 1;
    }
    12%,
    40% {
      transform: scaleY(1);
    }
    56% {
      transform: scaleY(1.04);
    }
    72% {
      transform: scaleY(0.96);
    }
    88% {
      transform: scaleY(1);
    }
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: scaleY(1);
    }
  }
  .pe-chip {
    animation: pe-chip-pop 6s ease-out infinite both;
  }
  @keyframes pe-chip-pop {
    0%,
    46% {
      opacity: 0;
      transform: translateY(3px);
    }
    53% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pe-bar,
    .pe-bar-peak,
    .pe-chip {
      animation: none;
      opacity: 1;
    }
    .pe-bar,
    .pe-bar-peak {
      transform: scaleY(1);
    }
    .pe-chip {
      transform: translateY(0);
    }
  }
</style>
