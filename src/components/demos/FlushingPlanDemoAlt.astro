---
// Alternate version of FlushingPlanDemo (concept), running 3 flushing runs
// over the alt network instead of NetworkMap's. Same timing; the 3 runs are
// re-picked as connected 2-pipe paths through the alt topology (top row,
// then down the right side, then across), and badge positions are
// recomputed for the 640x400 canvas.
import AppWindow from "./AppWindow.astro";
import BasemapAlt from "./BasemapAlt.astro";
import { pipes, junctions, reservoirPoint } from "./network-geometry-alt";
import {
  JUNCTION_COLOR,
  JUNCTION_RADIUS,
  OUTLINE_COLOR,
  OUTLINE_STROKE_WIDTH,
  PIPE_COLOR,
  PIPE_STROKE_WIDTH,
  RESERVOIR_COLOR,
  RESERVOIR_APEX_OFFSET,
  RESERVOIR_BASE_OFFSET,
  RESERVOIR_HALF_WIDTH,
  SCALE,
} from "./network-style-alt";

// This demo draws its own network by hand (AppWindow's bare prop skips
// NetworkMapAlt), so it's always the alt network -- no alt prop to toggle,
// matching GisImportDemoAlt/ShutdownPlanDemoAlt.

// The network, pipes/junctions/reservoir, and this file's own highlight/march
// overlay shift down together by a fixed amount (translate(0, Y), below) --
// only the basemap stays put. Y is 20 x SCALE (32) instead of NetworkMap's
// 20, since this shift is in viewBox user units, and the alt viewBox is
// 640-wide vs NetworkMap's 400-wide: the same *physical* pixel nudge needs
// a proportionally larger unit shift here.
const SHIFT_Y = 20 * SCALE; // = 32
const HIGHLIGHT_STROKE_WIDTH = PIPE_STROKE_WIDTH * SCALE; // = 6.4
const MARCH_STROKE_WIDTH = PIPE_STROKE_WIDTH * 0.6; // = 2.4

type RunPipe = { index: number; swap?: boolean };

const runs: {
  name: string;
  velocity: string;
  badge: { left: string; top: string };
  pipes: RunPipe[];
}[] = [
  {
    name: "Run 1",
    velocity: "1.6 m/s",
    badge: { left: "42.2%", top: "29.5%" },
    pipes: [{ index: 1 }, { index: 9 }],
  },
  {
    name: "Run 2",
    velocity: "1.4 m/s",
    badge: { left: "42.2%", top: "84.5%" },
    pipes: [{ index: 7, swap: true }, { index: 14 }],
  },
  {
    name: "Run 3",
    velocity: "1.7 m/s",
    badge: { left: "73.4%", top: "29.5%" },
    pipes: [{ index: 10 }, { index: 5, swap: true }],
  },
];

const segment = ({ index, swap }: RunPipe) => {
  const [x1, y1, x2, y2] = pipes[index];
  return swap ? { x1: x2, y1: y2, x2: x1, y2: y1 } : { x1, y1, x2, y2 };
};

const toPct = (seconds: number, cycle: number) =>
  +((seconds / cycle) * 100).toFixed(3);

const RUN_SPACING = 2;
const PIPE_DRAW = 0.5;
const PIPE_STAGGER = 0.25;
const SUCCESS_DELAY = 0.4;
const GREEN_TRANSITION = 0.25;
const BADGE_POP = 0.15;
const PANEL_FADE_IN = 0.3;
const HOLD_AFTER_LAST = 2;
const FADE_DURATION = 0.5;
const LOOP_BUFFER = 0.3;

const runStart = (i: number) => i * RUN_SPACING;
const pipeDrawStart = (i: number, j: number) => runStart(i) + j * PIPE_STAGGER;
const pipeDrawEnd = (i: number, j: number) => pipeDrawStart(i, j) + PIPE_DRAW;
const runSuccess = (i: number) => pipeDrawEnd(i, 1) + SUCCESS_DELAY;
const runGreenDone = (i: number) => runSuccess(i) + GREEN_TRANSITION;

const FADE_START = runGreenDone(runs.length - 1) + HOLD_AFTER_LAST;
const FADE_END = FADE_START + FADE_DURATION;
const CYCLE = FADE_END + LOOP_BUFFER;

const pct = (seconds: number) => toPct(seconds, CYCLE);

const drawKeyframes = (cls: string, i: number, j: number) => {
  const end = pipeDrawEnd(i, j);
  const success = runSuccess(i);
  const greenDone = runGreenDone(i);
  return `
.${cls} {
  stroke-dasharray: 100;
  stroke-dashoffset: 100;
  animation: ${cls} ${CYCLE}s linear infinite both;
}
@keyframes ${cls} {
  0%, ${pct(pipeDrawStart(i, j))}% { stroke-dashoffset: 100; opacity: 0.85; stroke: #8b5cf6; }
  ${pct(end)}% { stroke-dashoffset: 0; stroke: #8b5cf6; }
  ${pct(success)}% { stroke: #8b5cf6; }
  ${pct(greenDone)}% { stroke: #22c55e; }
  ${pct(FADE_START)}% { stroke-dashoffset: 0; opacity: 0.85; stroke: #22c55e; }
  ${pct(FADE_END)}%, 100% { stroke-dashoffset: 0; opacity: 0; stroke: #22c55e; }
}`;
};

const marchKeyframes = (cls: string, i: number, j: number) => {
  const end = pipeDrawEnd(i, j);
  const success = runSuccess(i);
  return `
.${cls} {
  opacity: 0;
  animation: ${cls}-vis ${CYCLE}s linear infinite both, flpa-march 1.1s linear infinite;
}
@keyframes ${cls}-vis {
  0%, ${pct(end)}% { opacity: 0; }
  ${pct(end + 0.1)}%, ${pct(success - 0.1)}% { opacity: 0.9; }
  ${pct(success)}%, 100% { opacity: 0; }
}`;
};

const badgeKeyframes = (cls: string, i: number) => {
  const pop = runStart(i) + BADGE_POP;
  return `
.${cls} {
  opacity: 0;
  animation: ${cls} ${CYCLE}s ease-out infinite both;
}
@keyframes ${cls} {
  0%, ${pct(runStart(i))}% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
  ${pct(pop)}% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
  ${pct(pop + 0.05)}% { transform: translate(-50%, -50%) scale(1); }
  ${pct(FADE_START)}% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  ${pct(FADE_END)}%, 100% { opacity: 0; transform: translate(-50%, -50%) scale(1); }
}`;
};

const statKeyframes = (cls: string, i: number) => {
  const success = runSuccess(i);
  return `
.${cls} {
  animation: ${cls} ${CYCLE}s linear infinite both;
}
@keyframes ${cls} {
  0%, ${pct(success - 0.1)}% { opacity: 0; }
  ${pct(success)}% { opacity: 1; }
  ${pct(FADE_START)}% { opacity: 1; }
  ${pct(FADE_END)}%, 100% { opacity: 0; }
}`;
};

const panelCss = `
.flpa-panel {
  animation: flpa-panel-in ${CYCLE}s ease-out infinite both;
}
@keyframes flpa-panel-in {
  0% { opacity: 0; transform: translateY(4px); }
  ${pct(PANEL_FADE_IN)}% { opacity: 1; transform: translateY(0); }
  ${pct(FADE_START)}% { opacity: 1; }
  ${pct(FADE_END)}%, 100% { opacity: 0; }
}`;

const generatedCss =
  runs
    .flatMap((_, i) => [
      drawKeyframes(`flpa-draw-${i + 1}-1`, i, 0),
      drawKeyframes(`flpa-draw-${i + 1}-2`, i, 1),
      marchKeyframes(`flpa-march-${i + 1}-1`, i, 0),
      marchKeyframes(`flpa-march-${i + 1}-2`, i, 1),
      badgeKeyframes(`flpa-badge-${i + 1}`, i),
      statKeyframes(`flpa-stat-${i + 1}`, i),
    ])
    .join("\n") + panelCss;
---

<AppWindow
  bare
  hideHeader
  hideFooter
  label="Unidirectional flushing in epanet-js: three flushing runs highlighting in order, each checked off in the sequence panel as it hits its cleaning velocity.">
  <svg
    viewBox="0 0 640 400"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <!-- basemap stays put -- the network itself, plus this file's own
         highlight/march overlay, shifts down together inside the translate
         group below. The run-order badges are plain HTML spans outside
         this svg (their own top percentages are adjusted to match); the
         flpa-panel popover is untouched. -->
    <BasemapAlt />

    <g transform={`translate(0, ${SHIFT_Y})`}>
    <!-- the network, normally drawn by NetworkMapAlt -- rendered by hand
         here (AppWindow's bare prop skips NetworkMapAlt) so it can shift
         down with the rest of this file's content instead of staying
         fixed with the basemap. -->
    <g stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round">
      {
        pipes.map(([x1, y1, x2, y2]) => (
          <line x1={x1} y1={y1} x2={x2} y2={y2} stroke={PIPE_COLOR} />
        ))
      }
    </g>

    <g stroke-linecap="round" fill="none">
      {
        runs.map((run, i) =>
          run.pipes.map((p, j) => {
            const { x1, y1, x2, y2 } = segment(p);
            return (
              <line
                class={`flpa-draw-${i + 1}-${j + 1}`}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke="#8b5cf6"
                stroke-width={HIGHLIGHT_STROKE_WIDTH}
                pathLength="100"
              />
            );
          }),
        )
      }
      {
        runs.map((run, i) =>
          run.pipes.map((p, j) => {
            const { x1, y1, x2, y2 } = segment(p);
            return (
              <line
                class={`flpa-march-${i + 1}-${j + 1}`}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke="#ffffff"
                stroke-width={MARCH_STROKE_WIDTH}
                stroke-dasharray="6 16"
                pathLength="100"
              />
            );
          }),
        )
      }
    </g>

    <!-- redraw the junction dots on top of the flushing-run highlight
         lines, since this overlay is a separate sibling painted after
         NetworkMapAlt's own junctions and would otherwise cover them -->
    <g stroke={OUTLINE_COLOR} stroke-width={OUTLINE_STROKE_WIDTH}>
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r={JUNCTION_RADIUS} fill={JUNCTION_COLOR} />
        ))
      }
    </g>

    <!-- reservoir, matching NetworkMapAlt's own fixed triangle glyph -->
    <path
      d={`M${reservoirPoint[0]} ${reservoirPoint[1] - RESERVOIR_APEX_OFFSET} L${reservoirPoint[0] + RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} L${reservoirPoint[0] - RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} Z`}
      fill={RESERVOIR_COLOR}
      stroke={OUTLINE_COLOR}
      stroke-width={OUTLINE_STROKE_WIDTH}></path>
    </g>
  </svg>

  <!-- run order badges -->
  {
    runs.map((run, i) => (
      <span
        class={`flpa-badge-${i + 1} absolute flex h-4 w-4 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-violet-600 text-xs font-semibold text-white shadow-sm ring-2 ring-white`}
        style={`left: ${run.badge.left}; top: ${run.badge.top};`}>
        {i + 1}
      </span>
    ))
  }

  <!-- flushing sequence panel -->
  <div
    class="flpa-panel absolute top-2 right-2 w-[176px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Flushing sequence</p>
      <p class="text-xs text-gray-400">UDF</p>
    </div>
    <div class="py-1 text-xs">
      {
        runs.map((run, i) => (
          <div class="flex items-center justify-between px-3 py-1">
            <span class="text-gray-600">{run.name}</span>
            <span class="relative">
              <span class="text-gray-400">Queued</span>
              <span
                class={`flpa-stat-${i + 1} absolute inset-0 flex items-center justify-end gap-0.5 bg-white font-medium text-green-600 tabular-nums whitespace-nowrap`}>
                {run.velocity} ✓
              </span>
            </span>
          </div>
        ))
      }
    </div>
  </div>
</AppWindow>

<style set:html={generatedCss} />

<style>
  @keyframes flpa-march {
    0% {
      stroke-dashoffset: 22;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flpa-draw-1-1,
    .flpa-draw-1-2,
    .flpa-draw-2-1,
    .flpa-draw-2-2,
    .flpa-draw-3-1,
    .flpa-draw-3-2,
    .flpa-march-1-1,
    .flpa-march-1-2,
    .flpa-march-2-1,
    .flpa-march-2-2,
    .flpa-march-3-1,
    .flpa-march-3-2,
    .flpa-badge-1,
    .flpa-badge-2,
    .flpa-badge-3,
    .flpa-panel,
    .flpa-stat-1,
    .flpa-stat-2,
    .flpa-stat-3 {
      animation: none;
    }
    .flpa-draw-1-1,
    .flpa-draw-1-2,
    .flpa-draw-2-1,
    .flpa-draw-2-2,
    .flpa-draw-3-1,
    .flpa-draw-3-2 {
      stroke-dashoffset: 0;
      opacity: 0.85;
      stroke: #22c55e;
    }
    .flpa-march-1-1,
    .flpa-march-1-2,
    .flpa-march-2-1,
    .flpa-march-2-2,
    .flpa-march-3-1,
    .flpa-march-3-2 {
      opacity: 0;
    }
    .flpa-badge-1,
    .flpa-badge-2,
    .flpa-badge-3 {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
    .flpa-panel,
    .flpa-stat-1,
    .flpa-stat-2,
    .flpa-stat-3 {
      opacity: 1;
      transform: none;
    }
  }
</style>
