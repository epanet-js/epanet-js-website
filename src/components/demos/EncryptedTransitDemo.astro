---
// Encrypted transit diagram: traffic between the user's machine and the
// epanet-js service shuttles through a TLS lock in both directions. Grounded
// in the security page's "encrypted in transit" claim.
import { Cloud, Laptop, Lock } from "lucide-react";
import { useTranslations } from "@i18n/utils";
import type { Locale } from "@i18n/utils";

interface Props {
  lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<div
  class="relative mx-auto aspect-[3/2] w-full max-w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label={t("diagrams.encryptedTransit.ariaLabel")}>
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="flex h-full w-full flex-col items-center justify-between">
  <div class="box-border flex w-full flex-1 flex-col items-center justify-center px-8 pt-8">
  <div class="flex w-[360px] items-start justify-center gap-2">
    <!-- the user's machine -->
    <div class="flex shrink-0 flex-col items-center gap-2">
      <span
        class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
        <Laptop size={23} />
      </span>
      <p class="text-xs font-medium text-gray-600 whitespace-nowrap">
        {t("diagrams.encryptedTransit.yourMachine")}
      </p>
    </div>

    <!-- encrypted connection -->
    <div class="relative flex h-12 flex-1 items-center">
      <svg viewBox="0 0 200 24" class="w-full" aria-hidden="true">
        <line
          class="enc-line"
          pathLength="100"
          x1="4"
          y1="12"
          x2="196"
          y2="12"
          stroke="#c4b5fd"
          stroke-width="2"></line>
        <circle class="enc-pkt enc-pkt-out" cx="4" cy="12" r="3" fill="#8b5cf6"
        ></circle>
        <circle
          class="enc-pkt enc-pkt-back"
          cx="196"
          cy="12"
          r="3"
          fill="#6366f1"></circle>
      </svg>
      <span
        class="enc-lock absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <span
          class="flex h-12 w-12 items-center justify-center rounded-full border border-violet-200 bg-white text-violet-600 shadow-sm">
          <Lock size={23} />
        </span>
      </span>
      <span
        class="enc-pill absolute left-1/2 top-full mt-2.5 -translate-x-1/2 whitespace-nowrap rounded-full border border-gray-200 bg-gray-50 px-4 py-1.5 text-[10px] font-medium text-gray-500">
        HTTPS · TLS
      </span>
    </div>

    <!-- service -->
    <div class="flex shrink-0 flex-col items-center gap-2">
      <span
        class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
        <Cloud size={23} />
      </span>
      <p class="text-xs font-medium text-gray-600 whitespace-nowrap">
        epanet-js
      </p>
    </div>
  </div>
  </div>
  <p class="enc-footer pb-6 text-center text-sm font-medium text-gray-700">
    {t("diagrams.encryptedTransit.footer")}
  </p>
      </div>
    </foreignObject>
  </svg>
</div>

<style>
  .enc-line {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: enc-line-draw 8s linear infinite both;
  }
  @keyframes enc-line-draw {
    0%,
    8% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    18% {
      stroke-dashoffset: 0;
    }
    94% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  .enc-lock {
    animation: enc-lock-in 8s ease-out infinite both;
  }
  @keyframes enc-lock-in {
    0%,
    20% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.7);
    }
    25% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.1);
    }
    28% {
      transform: translate(-50%, -50%) scale(1);
    }
    94% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    100% {
      opacity: 0;
    }
  }

  .enc-pill {
    animation: enc-pill-in 8s ease-out infinite both;
  }
  @keyframes enc-pill-in {
    0%,
    28% {
      opacity: 0;
      transform: translate(-50%, 2px);
    }
    34% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* packets shuttle in both directions while the connection is up; the
     travel loop runs continuously and an 8s window gates visibility */
  .enc-pkt-out {
    animation:
      enc-travel-out 2.6s linear infinite,
      enc-pkt-vis 8s linear infinite both;
  }
  .enc-pkt-back {
    animation:
      enc-travel-back 2.6s linear infinite,
      enc-pkt-vis 8s linear infinite both;
    animation-delay: -1.3s, 0s;
  }
  /* cx is a native SVG coordinate (viewBox user units), so the travel
     distance stays proportional to the connector's actual rendered
     width no matter how wide it renders — unlike a CSS px transform,
     which would be a fixed pixel distance regardless of the SVG's size. */
  @keyframes enc-travel-out {
    0% {
      cx: 4;
    }
    100% {
      cx: 196;
    }
  }
  @keyframes enc-travel-back {
    0% {
      cx: 196;
    }
    100% {
      cx: 4;
    }
  }
  @keyframes enc-pkt-vis {
    0%,
    32% {
      opacity: 0;
    }
    36% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .enc-footer {
    animation: enc-footer-in 8s ease-out infinite both;
  }
  @keyframes enc-footer-in {
    0%,
    4% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .enc-line,
    .enc-lock,
    .enc-pill,
    .enc-pkt-out,
    .enc-pkt-back,
    .enc-footer {
      animation: none;
      opacity: 1;
    }
    .enc-line {
      stroke-dashoffset: 0;
    }
    .enc-lock {
      transform: translate(-50%, -50%);
    }
    .enc-pill {
      transform: translate(-50%, 0);
    }
    .enc-pkt-out,
    .enc-pkt-back {
      opacity: 0;
    }
  }
</style>
