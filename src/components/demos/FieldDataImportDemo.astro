---
// Field data import demo: a logger CSV drops in, monitoring-point halos
// fade in once the file has "loaded" (progress bar complete), sparkline
// chips appear at each point after that, and a summary bar reads off the
// campaign: loggers, duration, and logging interval.
import { FileUp } from "lucide-react";
import AppWindow from "./AppWindow.astro";
import Basemap from "./Basemap.astro";
import { pipes, junctions, markerPoints } from "./network-geometry";

// The tank, pipes, junctions, and their monitoring-point markers are nudged
// down 40px (translate-y-10, below) — only the basemap stays put, so the
// two layers are rendered as separate SVGs rather than through NetworkMap
// (which bundles everything into one). Chip positions are calculated as a
// percentage of the 400x300 viewBox (matching the map's own coordinate
// system) plus that same fixed 40px, so each sparkline chip stays anchored
// to its (shifted) marker.
const chipPos = markerPoints.map(([x, y]) => ({
  left: `${((x / 400) * 100).toFixed(1)}%`,
  top: `calc(${((y / 300) * 100).toFixed(1)}% + 40px)`,
}));

const sparkPoints = [
  "1,10 7,5 13,8 19,4 25,7 31,3 37,6",
  "1,4 7,8 13,5 19,9 25,6 31,9 37,5",
  "1,7 7,3 13,7 19,5 25,9 31,5 37,8",
  "1,5 7,9 13,4 19,7 25,4 31,8 37,4",
];

// The last point of each sparkline, marked with a dot (the standard
// "current reading" sparkline convention).
const sparkEnds = sparkPoints.map((points) => {
  const [x, y] = points.trim().split(" ").at(-1)!.split(",").map(Number);
  return { x, y };
});

// Timing is baked directly into per-index @keyframes below (no
// animation-delay), so every element resets on the same cycle boundary —
// see the other demos harmonized this session for why that matters.
const toPct = (seconds: number, cycle: number) =>
  +((seconds / cycle) * 100).toFixed(3);

// Unchanged from before: the chip drops in, then the progress bar fills.
const CHIP_VISIBLE = 0.56;
const PROGRESS_HOLD_START = 0.8;
const PROGRESS_COMPLETE = 2.24;

// Halos fade in one at a time, starting 0.5s after the progress bar
// completes, staggered 0.5s apart.
const HALO_START = PROGRESS_COMPLETE + 0.5;
const HALO_STAGGER = 0.5;
const HALO_ENTRANCE = 0.3;
const haloTimings = markerPoints.map((_, i) => {
  const start = HALO_START + i * HALO_STAGGER;
  return { start, visible: start + HALO_ENTRANCE };
});

// Each sparkline chip now appears 0.25s after its own marker's halo — tied
// directly to that halo's visible time (same index) rather than a separate
// shared stagger schedule.
const SPARK_DELAY_AFTER_HALO = 0.25;
const SPARK_ENTRANCE = 0.32;
const sparkTimings = haloTimings.map(({ visible: haloVisible }) => {
  const visible = haloVisible + SPARK_DELAY_AFTER_HALO;
  return { start: visible - SPARK_ENTRANCE, visible };
});
const lastSparkVisible = sparkTimings.at(-1)!.visible;

// The summary keeps the same ~0.8s gap after the last spark as before.
const SUMMARY_ENTRANCE = 0.48;
const SUMMARY_VISIBLE = lastSparkVisible + 1;
const SUMMARY_START = SUMMARY_VISIBLE - SUMMARY_ENTRANCE;

// Everything holds once the summary lands, then fades out together.
const HOLD_END = SUMMARY_VISIBLE + 1.28;
const FADE_END = HOLD_END + 0.48;
const CYCLE = FADE_END + 0.22;
const pct = (seconds: number) => toPct(seconds, CYCLE);

// Each halo needs TWO animations at once: the continuous scale pulse
// (shared, always running) and its own entrance fade. Those can't be split
// across a shared ".fdi-marker-pulse { animation: ... }" class plus a
// separate per-index rule — a full "animation" shorthand on one selector
// resets animation-name for every other rule matching the same element, so
// whichever rule has higher specificity wins outright instead of the two
// merging (this is what silently killed the halos the first time: the
// scoped .fdi-marker-pulse rule always won, so fdi-halo-in-N never played
// and the circles just sat at their static opacity:0 forever). Declaring
// both animations together, comma-separated, on the one generated rule
// avoids that entirely.
const haloCss = haloTimings
  .map(
    ({ start, visible }, i) => `
.fdi-halo-${i} {
  animation-name: fdi-marker-pulse, fdi-halo-in-${i};
  animation-duration: 1.8s, ${CYCLE}s;
  animation-timing-function: ease-in-out, ease-out;
  animation-iteration-count: infinite, infinite;
  animation-fill-mode: none, both;
  animation-delay: ${i * 0.4}s, 0s;
}
@keyframes fdi-halo-in-${i} {
  0%, ${pct(start)}% { opacity: 0; }
  ${pct(visible)}% { opacity: 1; }
  ${pct(HOLD_END)}% { opacity: 1; }
  ${pct(FADE_END)}%, 100% { opacity: 0; }
}`,
  )
  .join("\n");

const sparkCss = sparkTimings
  .map(
    ({ start, visible }, i) => `
.fdi-spark-${i + 1} { animation-name: fdi-spark-${i + 1}; }
@keyframes fdi-spark-${i + 1} {
  0%, ${pct(start)}% { opacity: 0; transform: translateY(calc(-100% + 2px)) scale(0.92); }
  ${pct(visible)}% { opacity: 1; transform: translateY(-100%) scale(1); }
  ${pct(HOLD_END)}% { opacity: 1; transform: translateY(-100%) scale(1); }
  ${pct(FADE_END)}%, 100% { opacity: 0; transform: translateY(-100%) scale(1); }
}`,
  )
  .join("\n");

const singleCss = `
.fdi-chip { animation-name: fdi-chip-in; }
@keyframes fdi-chip-in {
  0% { opacity: 0; transform: translateY(-6px); }
  ${pct(CHIP_VISIBLE)}% { opacity: 1; transform: translateY(0); }
  ${pct(HOLD_END)}% { opacity: 1; }
  ${pct(FADE_END)}%, 100% { opacity: 0; }
}
.fdi-progress { animation-name: fdi-progress; }
@keyframes fdi-progress {
  0%, ${pct(PROGRESS_HOLD_START)}% { width: 0; opacity: 1; }
  ${pct(PROGRESS_COMPLETE)}% { width: 100%; opacity: 1; }
  ${pct(HOLD_END)}% { width: 100%; opacity: 1; }
  ${pct(FADE_END)}%, 100% { width: 100%; opacity: 0; }
}
.fdi-summary { animation-name: fdi-summary-in; }
@keyframes fdi-summary-in {
  0%, ${pct(SUMMARY_START)}% { opacity: 0; transform: translateY(4px); }
  ${pct(SUMMARY_VISIBLE)}% { opacity: 1; transform: translateY(0); }
  ${pct(HOLD_END)}% { opacity: 1; }
  ${pct(FADE_END)}%, 100% { opacity: 0; }
}`;

const generatedCss = `${singleCss}\n${haloCss}\n${sparkCss}`;
---

<AppWindow
  bare
  hideHeader
  hideFooter
  label="Field data import in epanet-js: a logger CSV drops in and sparkline chips appear at each monitoring point, with a summary of loggers, duration, and interval.">
  <!-- basemap stays put -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <Basemap />
  </svg>

  <!-- tank, pipes, junctions, and monitoring markers, nudged down 40px (see
       chipPos above) -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full translate-y-10"
    aria-hidden="true">
    <path
      d="M40 42 L48 56 L32 56 Z"
      fill="#312e81"
      stroke="#ffffff"
      stroke-width="1"></path>
    <g stroke-width="2.5" stroke-linecap="round">
      {
        pipes.map(([x1, y1, x2, y2]) => (
          <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#3730a3" />
        ))
      }
    </g>
    <g stroke="#ffffff" stroke-width="1">
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r="3.5" fill="#312e81" />
        ))
      }
    </g>
    <g fill="none" stroke="#8b5cf6" stroke-width="2.5">
      {
        markerPoints.map(([x, y], i) => (
          <circle cx={x} cy={y} r="8" class={`fdi-halo-${i}`} />
        ))
      }
    </g>
  </svg>

  <!-- dropped CSV chip + campaign summary, side by side (top left) -->
  <div class="absolute top-2 left-2 flex items-center gap-4">
    <div class="fdi-chip">
      <div
        class="flex items-center gap-1.5 bg-white rounded-lg border border-gray-100 shadow-md pl-1.5 pr-2.5 py-1.5">
        <span
          class="flex items-center justify-center w-5 h-5 rounded bg-violet-50 text-violet-600">
          <FileUp size={14} />
        </span>
        <span class="text-[12px] font-medium text-gray-700">loggers.csv</span>
        <span class="text-[11px] text-gray-400">680 KB</span>
      </div>
      <div class="mx-1.5 -mt-px h-0.5 rounded-full bg-gray-100 overflow-hidden">
        <div class="fdi-progress h-full bg-violet-500"></div>
      </div>
    </div>

    <!-- campaign summary -->
    <div
      class="fdi-summary whitespace-nowrap rounded-lg border border-gray-100 bg-white px-3 py-1.5 text-[12px] text-gray-600 shadow-md">
      <span class="font-medium text-gray-700">4 loggers</span>
      · 14 days · 2-min interval
    </div>
  </div>

  <!-- sparkline chips landing at the monitoring points -->
  {
    chipPos.map((pos, i) => (
      <span
        class={`fdi-spark-${i + 1} absolute -translate-y-full ml-2 -mt-1.5 rounded border border-gray-200 bg-white px-2.5 py-2 shadow-sm`}
        style={`left: ${pos.left}; top: ${pos.top};`}>
        <svg viewBox="0 0 40 12" class="h-3 w-10" aria-hidden="true">
          <polyline
            points={sparkPoints[i]}
            fill="none"
            stroke="#8b5cf6"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
          <circle cx={sparkEnds[i].x} cy={sparkEnds[i].y} r="2" fill="#8b5cf6" />
        </svg>
      </span>
    ))
  }
</AppWindow>

<style define:vars={{ cycle: `${CYCLE}s` }}>
  /* monitoring point markers pulse continuously (same keyframe as
     NetworkMap's own .nm-pulse, duplicated here since this demo renders
     pipes/junctions/markers itself instead of through NetworkMap, to shift
     just that layer down) *and* fade in on their own entrance schedule.
     Both animations — and the entrance keyframe stops, which depend on
     CYCLE — are declared together in the generated block below, since
     splitting them across two separate rules is what silently broke the
     entrance fade the first time (see the comment above haloCss). */
  .fdi-halo-0,
  .fdi-halo-1,
  .fdi-halo-2,
  .fdi-halo-3 {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
  }
  @keyframes fdi-marker-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.5);
    }
  }

  /* width/opacity/transform keyframe stops for the chip, progress bar, and
     summary are generated below since they depend on CYCLE */
  .fdi-chip {
    animation-duration: var(--cycle);
    animation-timing-function: ease-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }
  .fdi-progress {
    width: 0;
    animation-duration: var(--cycle);
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }
  .fdi-summary {
    animation-duration: var(--cycle);
    animation-timing-function: ease-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  /* one sparkline chip pops per logger record as it loads; keyframe stops
     are generated (fdi-spark-N, below) since they depend on CYCLE */
  .fdi-spark-1,
  .fdi-spark-2,
  .fdi-spark-3,
  .fdi-spark-4 {
    opacity: 0;
    animation-duration: var(--cycle);
    animation-timing-function: ease-out;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  @media (prefers-reduced-motion: reduce) {
    .fdi-halo-0,
    .fdi-halo-1,
    .fdi-halo-2,
    .fdi-halo-3,
    .fdi-chip,
    .fdi-progress,
    .fdi-spark-1,
    .fdi-spark-2,
    .fdi-spark-3,
    .fdi-spark-4,
    .fdi-summary {
      animation: none;
    }
    .fdi-halo-0,
    .fdi-halo-1,
    .fdi-halo-2,
    .fdi-halo-3 {
      opacity: 1;
    }
    .fdi-chip {
      opacity: 1;
      transform: none;
    }
    .fdi-progress {
      width: 100%;
      opacity: 1;
    }
    .fdi-spark-1,
    .fdi-spark-2,
    .fdi-spark-3,
    .fdi-spark-4 {
      opacity: 1;
      transform: translateY(-100%);
    }
    .fdi-summary {
      opacity: 1;
      transform: none;
    }
  }
</style>

<style set:html={generatedCss} />
