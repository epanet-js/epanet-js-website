---
// Alternate version of SourceTraceDemo. The alt network only has one built-in
// source (the reservoir), so a second one -- "WTP B" -- is synthesized here
// at the network's other dead-end cul-de-sac tip (570,306), diagonally
// opposite the reservoir (top-left vs bottom-right), using the exact same
// triangle glyph as the reservoir (RESERVOIR_* offsets from
// network-style-alt) just in violet instead of navy. WTP A's territory
// covers the left column (5 pipes), WTP B's covers the bottom-right (4
// pipes), and the remaining 7 pipes in between form the blend zone -- the
// same 7-pipe blend size as the original, just a different partition of a
// 16-pipe network instead of a 20-pipe one.
import AppWindow from "./AppWindow.astro";
import LegendPanel from "./LegendPanel.astro";
import { pipes, junctions, reservoirPoint } from "./network-geometry-alt";
import {
  JUNCTION_COLOR,
  JUNCTION_RADIUS,
  OUTLINE_COLOR,
  OUTLINE_STROKE_WIDTH,
  PIPE_STROKE_WIDTH,
  RESERVOIR_COLOR,
  RESERVOIR_APEX_OFFSET,
  RESERVOIR_BASE_OFFSET,
  RESERVOIR_HALF_WIDTH,
} from "./network-style-alt";

type Segment = { x1: number; y1: number; x2: number; y2: number };

const seg = (index: number, swap = false): Segment => {
  const [x1, y1, x2, y2] = pipes[index];
  return swap ? { x1: x2, y1: y2, x2: x1, y2: y1 } : { x1, y1, x2, y2 };
};

const wtpBPoint: [number, number] = [570, 306];

// Pipes supplied only by the reservoir (left column).
const traceA: Segment[] = [
  seg(0), // (64,86) -> (170,86)
  seg(1), // (170,86) -> (270,86)
  seg(3, true), // (170,86) -> (170,196)
  seg(6, true), // (170,196) -> (170,306)
  seg(15), // (170,306) -> (270,306)
];

// Pipes supplied only by WTP B (bottom-right dead-end).
const traceB: Segment[] = [
  seg(12, true), // (570,306) -> (470,306)
  seg(13, true), // (470,306) -> (370,306)
  seg(8), // (470,306) -> (470,196)
  seg(11), // (470,196) -> (570,196)
];

// Pipes carrying water from both: a blue and a violet stroke are stacked
// and counter-faded as the blend swings over the day.
const blend: Segment[] = [
  seg(2), // (170,196) -> (270,196)
  seg(4), // (270,196) -> (270,86)
  seg(5), // (470,196) -> (470,86)
  seg(7), // (270,306) -> (270,196)
  seg(9), // (270,86) -> (370,86)
  seg(10), // (370,86) -> (470,86)
  seg(14), // (270,306) -> (370,306)
];

// Map coordinates -> percentage offsets for HTML chips over the map.
const at = (x: number, y: number) =>
  `left: ${((x / 640) * 100).toFixed(2)}%; top: ${((y / 400) * 100).toFixed(2)}%`;

const sourceAChip = at(reservoirPoint[0], reservoirPoint[1] - RESERVOIR_APEX_OFFSET);
const sourceBChip = at(wtpBPoint[0], wtpBPoint[1] + RESERVOIR_BASE_OFFSET);
const blendChip = at(370, 196);

const legendEntries = [
  { color: "#3b82f6", label: "WTP A" },
  { color: "#8b5cf6", label: "WTP B" },
];
---

<AppWindow
  variant="plain"
  altNetwork
  hideHeader
  hideFooter
  label="Source tracing in epanet-js: water from two treatment works blending mid-network, with the share shown per pipe.">
  <!-- trace overlay: same viewBox as NetworkMapAlt so strokes align exactly -->
  <svg
    viewBox="0 0 640 400"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <!-- water from WTP A spreads from the reservoir -->
    <g stroke="#3b82f6" stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round" fill="none">
      {
        traceA.map(({ x1, y1, x2, y2 }, i) => (
          <line
            class="sta-trace-a"
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
            pathLength="100"
            style={`animation-delay: ${(i * 0.25).toFixed(2)}s`}
          />
        ))
      }
    </g>

    <!-- water from WTP B spreads from the second works -->
    <g stroke="#8b5cf6" stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round" fill="none">
      {
        traceB.map(({ x1, y1, x2, y2 }, i) => (
          <line
            class="sta-trace-b"
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
            pathLength="100"
            style={`animation-delay: ${(i * 0.34).toFixed(2)}s`}
          />
        ))
      }
    </g>

    <!-- blend zone: blue under violet, the mix swinging once per cycle -->
    <g stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round" fill="none">
      {
        blend.map(({ x1, y1, x2, y2 }) => (
          <line
            class="sta-blend-blue"
            stroke="#3b82f6"
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
          />
        ))
      }
      {
        blend.map(({ x1, y1, x2, y2 }) => (
          <line
            class="sta-blend-violet"
            stroke="#8b5cf6"
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
          />
        ))
      }
    </g>

    <!-- redraw the junction dots on top of the trace/blend overlay lines,
         since this overlay is a separate sibling painted after NetworkMapAlt's
         own junctions and would otherwise cover them -->
    <g stroke={OUTLINE_COLOR} stroke-width={OUTLINE_STROKE_WIDTH}>
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r={JUNCTION_RADIUS} fill={JUNCTION_COLOR} />
        ))
      }
    </g>

    <!-- WTP B source marker: drawn last so it stays on top of every
         junction dot above (it sits right on top of one), and always
         visible -- no fade in/out like the rest of the UI. -->
    <path
      d={`M${wtpBPoint[0]} ${wtpBPoint[1] - RESERVOIR_APEX_OFFSET} L${wtpBPoint[0] + RESERVOIR_HALF_WIDTH} ${wtpBPoint[1] + RESERVOIR_BASE_OFFSET} L${wtpBPoint[0] - RESERVOIR_HALF_WIDTH} ${wtpBPoint[1] + RESERVOIR_BASE_OFFSET} Z`}
      fill="#7c3aed"
      stroke={OUTLINE_COLOR}
      stroke-width={OUTLINE_STROKE_WIDTH}></path>

    <!-- WTP A / reservoir marker: NetworkMapAlt draws this first (it's the
         base map's own reservoir glyph), and traceA's first pipe starts
         right at it, so it gets covered as soon as that line draws in.
         Redrawn here, last, matching NetworkMapAlt's exact styling, so it
         stays above every line/highlight -- also always visible, no fade. -->
    <path
      d={`M${reservoirPoint[0]} ${reservoirPoint[1] - RESERVOIR_APEX_OFFSET} L${reservoirPoint[0] + RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} L${reservoirPoint[0] - RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} Z`}
      fill={RESERVOIR_COLOR}
      stroke={OUTLINE_COLOR}
      stroke-width={OUTLINE_STROKE_WIDTH}></path>
  </svg>

  <!-- source labels -->
  <div
    class="sta-ui absolute -translate-x-1/2 mt-1.5 flex items-center gap-1 bg-white rounded border border-gray-100 shadow-md px-1.5 py-0.5 text-xs font-medium text-gray-600 whitespace-nowrap"
    style={sourceAChip}>
    <span class="sta-dot w-1.5 h-1.5 rounded-full bg-blue-500"></span>
    WTP A
  </div>
  <div
    class="sta-ui absolute -translate-x-1/2 mt-2 flex items-center gap-1 bg-white rounded border border-gray-100 shadow-md px-1.5 py-0.5 text-xs font-medium text-gray-600 whitespace-nowrap"
    style={sourceBChip}>
    <span class="sta-dot w-1.5 h-1.5 rounded-full bg-violet-500"></span>
    WTP B
  </div>

  <!-- share readout in the blend zone -->
  <div class="absolute -translate-x-1/2 -translate-y-1/2" style={blendChip}>
    <div
      class="sta-card grid bg-white rounded-lg border border-gray-100 shadow-md px-2 py-1 text-sm font-medium text-gray-600 tabular-nums whitespace-nowrap">
      <span class="sta-val-a col-start-1 row-start-1">62% from WTP A</span>
      <span class="sta-val-b col-start-1 row-start-1">48% from WTP A</span>
    </div>
  </div>

  <!-- source legend (bottom-left) -->
  <div class="sta-legend absolute bottom-2 left-2">
    <LegendPanel title="Source" entries={legendEntries} />
  </div>
</AppWindow>

<style>
  /* traces draw outward from each works (A over 4-30%, B over 14-42%),
     hold, then fade with the reset */
  .sta-trace-a,
  .sta-trace-b {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .sta-trace-a {
    animation: sta-draw-a 8s linear infinite both;
  }
  .sta-trace-b {
    animation: sta-draw-b 8s linear infinite both;
  }
  @keyframes sta-draw-a {
    0%,
    4% {
      stroke-dashoffset: 100;
    }
    11% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes sta-draw-b {
    0%,
    14% {
      stroke-dashoffset: 100;
    }
    21% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  /* blend pipes appear once both waves arrive (~45%), then swing once from
     blue-dominant to violet-dominant over 54-80% */
  .sta-blend-blue {
    opacity: 0;
    animation: sta-blend-blue 8s ease-in-out infinite both;
  }
  .sta-blend-violet {
    opacity: 0;
    animation: sta-blend-violet 8s ease-in-out infinite both;
  }
  @keyframes sta-blend-blue {
    0%,
    38% {
      opacity: 0;
    }
    45%,
    54% {
      opacity: 1;
    }
    80%,
    92% {
      opacity: 0.35;
    }
    100% {
      opacity: 0;
    }
  }
  @keyframes sta-blend-violet {
    0%,
    40% {
      opacity: 0;
    }
    46%,
    54% {
      opacity: 0.3;
    }
    80%,
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .sta-ui {
    animation: sta-ui-in 8s ease-out infinite both;
  }
  @keyframes sta-ui-in {
    0% {
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .sta-legend {
    animation: sta-legend-in 8s ease-out infinite both;
  }
  @keyframes sta-legend-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    8% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .sta-card {
    animation: sta-card-in 8s ease-out infinite both;
  }
  @keyframes sta-card-in {
    0%,
    43% {
      opacity: 0;
      transform: translateY(4px);
    }
    48% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }
  .sta-val-a {
    animation: sta-val-out 8s ease-in-out infinite both;
  }
  .sta-val-b {
    animation: sta-val-in 8s ease-in-out infinite both;
  }
  @keyframes sta-val-out {
    0%,
    54% {
      opacity: 1;
    }
    80%,
    100% {
      opacity: 0;
    }
  }
  @keyframes sta-val-in {
    0%,
    54% {
      opacity: 0;
    }
    80%,
    100% {
      opacity: 1;
    }
  }

  .sta-dot {
    animation: sta-dot-breathe 2s ease-in-out infinite;
  }
  @keyframes sta-dot-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.35);
      opacity: 0.65;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sta-trace-a,
    .sta-trace-b,
    .sta-blend-blue,
    .sta-blend-violet,
    .sta-ui,
    .sta-legend,
    .sta-card,
    .sta-val-a,
    .sta-val-b,
    .sta-dot {
      animation: none;
    }
    .sta-trace-a,
    .sta-trace-b {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .sta-blend-blue {
      opacity: 1;
    }
    .sta-blend-violet {
      opacity: 0.5;
    }
    .sta-ui {
      opacity: 1;
    }
    .sta-legend,
    .sta-card {
      opacity: 1;
      transform: none;
    }
    .sta-val-a {
      opacity: 1;
    }
    .sta-val-b {
      opacity: 0;
    }
    .sta-dot {
      transform: none;
      opacity: 1;
    }
  }
</style>
