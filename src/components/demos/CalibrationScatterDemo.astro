---
// Calibration scatter demo: observed-versus-simulated points appear
// scattered off the 1:1 line, then pull onto it as a model change applies,
// with the RMSE chip improving from amber to green.

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

// Final dot positions near the 1:1 line, plus the initial offset each dot
// starts from (applied as a CSS transform that animates back to zero).
const dots: { x: number; y: number; dx: number; dy: number }[] = [
  { x: 24, y: 90, dx: 5, dy: -12 },
  { x: 33, y: 85, dx: -7, dy: 9 },
  { x: 41, y: 72, dx: 9, dy: 7 },
  { x: 50, y: 68, dx: -5, dy: -13 },
  { x: 60, y: 53, dx: 7, dy: 11 },
  { x: 68, y: 50, dx: -11, dy: -7 },
  { x: 78, y: 36, dx: 6, dy: -10 },
  { x: 86, y: 32, dx: -8, dy: 12 },
  { x: 95, y: 19, dx: 10, dy: 6 },
  { x: 102, y: 16, dx: -6, dy: 9 },
];
---

<div
  class:list={[
    "bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden select-none",
    className,
  ]}
  role="img"
  aria-label="Calibration fit panel: an observed-versus-simulated scatter plot pulling toward the 1:1 line as a change applies, with the RMSE improving from 4.8 to 1.2 meters.">
  <div
    class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
    <p class="text-[11px] font-semibold text-gray-700">Calibration fit</p>
    <p class="text-[10px] text-gray-400">10 observations</p>
  </div>
  <div class="px-3 py-2.5">
    <div class="relative">
      <svg viewBox="0 0 150 112" class="w-full" aria-hidden="true">
        <!-- axes -->
        <g stroke="#e5e7eb" stroke-width="1">
          <line x1="16" y1="8" x2="16" y2="100"></line>
          <line x1="16" y1="100" x2="108" y2="100"></line>
        </g>
        <text
          x="62"
          y="110"
          text-anchor="middle"
          font-size="6.5"
          fill="#9ca3af">
          Observed (m)
        </text>
        <text
          x="6"
          y="54"
          text-anchor="middle"
          font-size="6.5"
          fill="#9ca3af"
          transform="rotate(-90 6 54)">
          Simulated (m)
        </text>

        <!-- 1:1 line -->
        <line
          class="csc-line"
          pathLength="100"
          x1="16"
          y1="100"
          x2="108"
          y2="8"
          stroke="#9ca3af"
          stroke-width="1"
          stroke-dasharray="3 2"></line>

        <!-- observations snap toward the 1:1 line -->
        {
          dots.map((d, i) => (
            <circle
              class="csc-dot"
              cx={d.x}
              cy={d.y}
              r="2.4"
              fill="#8b5cf6"
              stroke="#ffffff"
              stroke-width="0.75"
              style={`--dx: ${d.dx}px; --dy: ${d.dy}px; animation-delay: ${(i * 0.1).toFixed(2)}s`}
            />
          ))
        }
      </svg>

      <span class="absolute left-[16%] top-[6%]">
        <span
          class="csc-rmse-old block whitespace-nowrap rounded border border-amber-200 bg-amber-50 px-1.5 py-0.5 text-[9px] font-medium text-amber-700 shadow-sm">
          RMSE 4.8 m
        </span>
        <span
          class="csc-rmse-new absolute inset-0 flex items-center justify-center whitespace-nowrap rounded border border-green-200 bg-green-50 px-1.5 py-0.5 text-[9px] font-medium text-green-700 shadow-sm">
          RMSE 1.2 m
        </span>
      </span>
    </div>
  </div>
</div>

<style>
  .csc-line {
    stroke-dashoffset: 0;
    animation: csc-line-in 7s ease-out infinite both;
  }
  @keyframes csc-line-in {
    0%,
    4% {
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  /* dots fade in at their offset, hold, then travel home to the 1:1 line */
  .csc-dot {
    transform-box: fill-box;
    transform-origin: center;
    transform: translate(var(--dx), var(--dy));
    animation: csc-snap 7s ease-in-out infinite both;
  }
  @keyframes csc-snap {
    0%,
    16% {
      opacity: 0;
      transform: translate(var(--dx), var(--dy));
    }
    22% {
      opacity: 1;
    }
    46% {
      transform: translate(var(--dx), var(--dy));
    }
    60% {
      transform: translate(0, 0);
    }
    90% {
      opacity: 1;
      transform: translate(0, 0);
    }
    96%,
    100% {
      opacity: 0;
      transform: translate(0, 0);
    }
  }

  .csc-rmse-old {
    animation: csc-rmse-old 7s linear infinite both;
  }
  @keyframes csc-rmse-old {
    0%,
    18% {
      opacity: 0;
    }
    22%,
    76% {
      opacity: 1;
    }
    80%,
    100% {
      opacity: 0;
    }
  }
  .csc-rmse-new {
    animation: csc-rmse-new 7s linear infinite both;
  }
  @keyframes csc-rmse-new {
    0%,
    76% {
      opacity: 0;
    }
    80% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .csc-line,
    .csc-dot,
    .csc-rmse-old,
    .csc-rmse-new {
      animation: none;
    }
    .csc-line {
      opacity: 1;
    }
    .csc-dot {
      opacity: 1;
      transform: translate(0, 0);
    }
    .csc-rmse-old {
      opacity: 0;
    }
    .csc-rmse-new {
      opacity: 1;
    }
  }
</style>
