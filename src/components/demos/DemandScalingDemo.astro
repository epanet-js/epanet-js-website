---
// Demand scaling demo: allocated demand falls short of the metered DMA
// inflow, a scaling factor applies, the allocated bar grows to close the
// gap, and the balance check flips from unbalanced to balanced.
import { CheckCircle2 } from "lucide-react";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={[
    "relative aspect-[16/10] w-full rounded-xl border border-gray-200 shadow-lg bg-gray-100 overflow-hidden",
    className,
  ]}>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div
      class="w-full max-w-[280px] bg-white rounded-lg border border-gray-200 shadow-md overflow-hidden select-none"
      role="img"
      aria-label="Demand balance panel: allocated demand short of metered inflow until a scaling factor closes the gap and the balance check turns green.">
      <div
        class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
        <p class="text-[12px] font-semibold text-gray-700">Demand balance</p>
        <p class="text-[11px] text-gray-400">DMA-3</p>
      </div>
      <div class="px-3 py-2.5">
        <!-- metered inflow -->
        <div>
          <div class="flex items-baseline justify-between text-[12px]">
            <span class="text-gray-500">Metered inflow</span>
            <span class="font-medium text-gray-700 tabular-nums">128 l/s</span>
          </div>
          <div class="mt-1 h-2 rounded-full bg-gray-100 overflow-hidden">
            <div class="dsc-bar-in h-full w-full rounded-full bg-indigo-900"></div>
          </div>
        </div>

        <!-- allocated demand with the shortfall gap -->
        <div class="mt-4">
          <div class="flex items-baseline justify-between text-[12px]">
            <span class="text-gray-500">Allocated demand</span>
            <span class="flex items-baseline gap-1.5">
              <span class="dsc-gap-label text-[11px] font-medium text-amber-600">
                −25 l/s
              </span>
              <span class="relative font-medium text-gray-700 tabular-nums">
                <span class="dsc-val-old">103 l/s</span>
                <span class="dsc-val-new absolute inset-0 text-right bg-white">
                  128 l/s
                </span>
              </span>
            </span>
          </div>
          <div class="relative mt-1 h-2 rounded-full bg-gray-100">
            <div
              class="dsc-bar-alloc absolute inset-y-0 left-0 w-full rounded-full bg-violet-500">
            </div>
            <div
              class="dsc-gap absolute inset-y-0 left-[80%] right-0 rounded-r-full"
              style="background: repeating-linear-gradient(135deg, #fcd34d 0 2px, transparent 2px 5px);">
            </div>
          </div>
        </div>

        <!-- scaling factor -->
        <div class="mt-4 flex items-center justify-between text-[12px]">
          <span class="text-gray-500">Scaling factor</span>
          <span class="relative">
            <span
              class="dsc-factor-old inline-block rounded border border-gray-200 bg-gray-50 px-1.5 py-0.5 font-medium text-gray-600 tabular-nums">
              × 1.00
            </span>
            <span
              class="dsc-factor-new absolute inset-0 flex items-center justify-center rounded border border-violet-200 bg-violet-50 px-1.5 py-0.5 font-medium text-violet-700 tabular-nums">
              × 1.24
            </span>
          </span>
        </div>

        <!-- balance status -->
        <div
          class="mt-2.5 flex items-center justify-between border-t border-gray-100 pt-2">
          <span class="text-[12px] text-gray-500">Balance check</span>
          <span class="relative">
            <span
              class="dsc-status-off block whitespace-nowrap rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-medium text-amber-700">
              Unbalanced
            </span>
            <span
              class="dsc-status-on absolute inset-0 flex items-center justify-center gap-1 whitespace-nowrap rounded-full bg-green-100 px-2 py-0.5 text-[11px] font-medium text-green-700">
              <CheckCircle2 size={14} />
              Balanced
            </span>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /*
    Sequence (seconds, of the 8.5s cycle — everything shifted 1s later than
    the previous cut, and the multiplier's flash now plays twice as fast):
    1.35-2.05  metered inflow bar draws in
    1.84-2.54  allocated bar draws to 80% (the shortfall), then holds
    2.68-3.10  "-25 l/s" gap label + gap stripe appear, hold
    3.80-4.00  old factor (x1.00) fades out
    4.00-4.35  the x1.24 box fades in and flashes as one motion — it pops
               in at its scale/brightness peak (4.2s) rather than
               appearing plainly and flashing separately, then settles
    4.60-4.90  +0.25s after the flash, the gap label fades out
    4.85-5.35  +0.5s after the flash, allocated bar grows to 100%
    5.15-5.35  "103 l/s" fades out, right as "128 l/s" is ready
    5.35-5.55  "128 l/s" fades in — 1s after the multiplier's flash ended
    6.35-6.65  "Balanced" appears — 1s after the allocated bar reaches 100%
    6.65-7.85  holds balanced
    7.85-8.25  everything fades out together
  */
  .dsc-bar-in {
    transform-origin: left;
    animation: dsc-bar-in 8.5s ease-in-out infinite both;
  }
  @keyframes dsc-bar-in {
    0%,
    15.882% {
      transform: scaleX(0);
      opacity: 1;
    }
    24.118% {
      transform: scaleX(1);
    }
    92.353% {
      transform: scaleX(1);
      opacity: 1;
    }
    97.059%,
    100% {
      transform: scaleX(1);
      opacity: 0;
    }
  }

  /* allocated bar draws to 80%, then grows to full once the factor applies */
  .dsc-bar-alloc {
    transform-origin: left;
    animation: dsc-bar-alloc 8.5s ease-in-out infinite both;
  }
  @keyframes dsc-bar-alloc {
    0%,
    21.647% {
      transform: scaleX(0);
      opacity: 1;
    }
    29.882% {
      transform: scaleX(0.8);
    }
    57.059% {
      transform: scaleX(0.8);
    }
    62.941% {
      transform: scaleX(1);
    }
    92.353% {
      transform: scaleX(1);
      opacity: 1;
    }
    97.059%,
    100% {
      transform: scaleX(1);
      opacity: 0;
    }
  }

  .dsc-gap,
  .dsc-gap-label {
    animation: dsc-gap-in 8.5s ease-in-out infinite both;
  }
  @keyframes dsc-gap-in {
    0%,
    31.529% {
      opacity: 0;
    }
    36.471%,
    54.118% {
      opacity: 1;
    }
    57.647%,
    100% {
      opacity: 0;
    }
  }

  /* "128 l/s" appears 1s after the multiplier's flash ends, not alongside
     the multiplier swap itself */
  .dsc-val-new {
    animation: dsc-val-swap-in 8.5s linear infinite both;
  }
  @keyframes dsc-val-swap-in {
    0%,
    62.941% {
      opacity: 0;
    }
    65.294% {
      opacity: 1;
    }
    92.353% {
      opacity: 1;
    }
    97.059%,
    100% {
      opacity: 0;
    }
  }
  /* the scaling factor box also flashes (scale + brightness) once it
     lands — twice as fast as the previous cut (0.15s total) */
  .dsc-factor-new {
    transform-origin: center;
    animation: dsc-factor-flash-in 8.5s linear infinite both;
  }
  @keyframes dsc-factor-flash-in {
    0%,
    47.059% {
      opacity: 0;
      transform: scale(1);
      filter: brightness(1);
    }
    49.412% {
      opacity: 1;
      transform: scale(1.15);
      filter: brightness(1.6);
    }
    51.176% {
      transform: scale(1);
      filter: brightness(1);
    }
    92.353% {
      opacity: 1;
    }
    97.059%,
    100% {
      opacity: 0;
    }
  }
  /* "103 l/s" now holds until "128 l/s" is ready to replace it, instead of
     fading out early and leaving a blank gap */
  .dsc-val-old {
    animation: dsc-val-old-out 8.5s linear infinite both;
  }
  @keyframes dsc-val-old-out {
    0% {
      opacity: 0;
    }
    18.353%,
    60.588% {
      opacity: 1;
    }
    62.941%,
    100% {
      opacity: 0;
    }
  }
  .dsc-factor-old {
    animation: dsc-factor-old-out 8.5s linear infinite both;
  }
  @keyframes dsc-factor-old-out {
    0% {
      opacity: 0;
    }
    18.353%,
    44.706% {
      opacity: 1;
    }
    47.059%,
    100% {
      opacity: 0;
    }
  }

  .dsc-status-on {
    animation: dsc-status-on 8.5s linear infinite both;
  }
  @keyframes dsc-status-on {
    0%,
    74.706% {
      opacity: 0;
    }
    78.235% {
      opacity: 1;
    }
    92.353% {
      opacity: 1;
    }
    97.059%,
    100% {
      opacity: 0;
    }
  }
  .dsc-status-off {
    animation: dsc-status-off 8.5s linear infinite both;
  }
  @keyframes dsc-status-off {
    0% {
      opacity: 0;
    }
    18.353%,
    74.706% {
      opacity: 1;
    }
    78.235%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dsc-bar-in,
    .dsc-bar-alloc,
    .dsc-gap,
    .dsc-gap-label,
    .dsc-val-old,
    .dsc-val-new,
    .dsc-factor-old,
    .dsc-factor-new,
    .dsc-status-off,
    .dsc-status-on {
      animation: none;
    }
    .dsc-bar-in,
    .dsc-bar-alloc {
      transform: scaleX(1);
      opacity: 1;
    }
    .dsc-gap,
    .dsc-gap-label,
    .dsc-val-old,
    .dsc-factor-old,
    .dsc-status-off {
      opacity: 0;
    }
    .dsc-val-new,
    .dsc-factor-new,
    .dsc-status-on {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }
</style>
