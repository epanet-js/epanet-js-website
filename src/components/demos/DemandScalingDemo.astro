---
// Demand scaling demo: allocated demand falls short of the metered DMA
// inflow, a scaling factor applies, the allocated bar grows to close the
// gap, and the balance check flips from unbalanced to balanced.
import { CheckCircle2 } from "lucide-react";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={[
    "bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden select-none",
    className,
  ]}
  role="img"
  aria-label="Demand balance panel: allocated demand short of metered inflow until a scaling factor closes the gap and the balance check turns green.">
  <div
    class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
    <p class="text-[11px] font-semibold text-gray-700">Demand balance</p>
    <p class="text-[10px] text-gray-400">DMA-3</p>
  </div>
  <div class="px-3 py-2.5 space-y-2.5">
    <!-- metered inflow -->
    <div>
      <div class="flex items-baseline justify-between text-[10px]">
        <span class="text-gray-500">Metered inflow</span>
        <span class="font-medium text-gray-700 tabular-nums">128 l/s</span>
      </div>
      <div class="mt-1 h-2 rounded-full bg-gray-100 overflow-hidden">
        <div class="dsc-bar-in h-full w-full rounded-full bg-indigo-900"></div>
      </div>
    </div>

    <!-- allocated demand with the shortfall gap -->
    <div>
      <div class="flex items-baseline justify-between text-[10px]">
        <span class="text-gray-500">Allocated demand</span>
        <span class="relative font-medium text-gray-700 tabular-nums">
          <span class="dsc-val-old">103 l/s</span>
          <span class="dsc-val-new absolute inset-0 text-right bg-white">
            128 l/s
          </span>
        </span>
      </div>
      <div class="relative mt-1 h-2 rounded-full bg-gray-100">
        <div
          class="dsc-bar-alloc absolute inset-y-0 left-0 w-full rounded-full bg-violet-500">
        </div>
        <div
          class="dsc-gap absolute inset-y-0 left-[80%] right-0 rounded-r-full"
          style="background: repeating-linear-gradient(135deg, #fcd34d 0 2px, transparent 2px 5px);">
        </div>
        <span
          class="dsc-gap-label absolute -top-4 right-0 text-[9px] font-medium text-amber-600">
          −25 l/s
        </span>
      </div>
    </div>

    <!-- scaling factor -->
    <div class="flex items-center justify-between text-[10px]">
      <span class="text-gray-500">Scaling factor</span>
      <span class="relative">
        <span
          class="dsc-factor-old inline-block rounded border border-gray-200 bg-gray-50 px-1.5 py-0.5 font-medium text-gray-600 tabular-nums">
          × 1.00
        </span>
        <span
          class="dsc-factor-new absolute inset-0 flex items-center justify-center rounded border border-violet-200 bg-violet-50 px-1.5 py-0.5 font-medium text-violet-700 tabular-nums">
          × 1.24
        </span>
      </span>
    </div>

    <!-- balance status -->
    <div
      class="flex items-center justify-between border-t border-gray-100 pt-2">
      <span class="text-[10px] text-gray-500">Balance check</span>
      <span class="relative">
        <span
          class="dsc-status-off block whitespace-nowrap rounded-full bg-amber-100 px-2 py-0.5 text-[9px] font-medium text-amber-700">
          Unbalanced
        </span>
        <span
          class="dsc-status-on absolute inset-0 flex items-center justify-center gap-1 whitespace-nowrap rounded-full bg-green-100 px-2 py-0.5 text-[9px] font-medium text-green-700">
          <CheckCircle2 size={10} />
          Balanced
        </span>
      </span>
    </div>
  </div>
</div>

<style>
  .dsc-bar-in {
    transform-origin: left;
    animation: dsc-bar-in 7s ease-in-out infinite both;
  }
  @keyframes dsc-bar-in {
    0%,
    5% {
      transform: scaleX(0);
      opacity: 1;
    }
    15% {
      transform: scaleX(1);
    }
    92% {
      transform: scaleX(1);
      opacity: 1;
    }
    98%,
    100% {
      transform: scaleX(1);
      opacity: 0;
    }
  }

  /* allocated bar draws to 80%, then grows to full once the factor applies */
  .dsc-bar-alloc {
    transform-origin: left;
    animation: dsc-bar-alloc 7s ease-in-out infinite both;
  }
  @keyframes dsc-bar-alloc {
    0%,
    12% {
      transform: scaleX(0);
      opacity: 1;
    }
    22% {
      transform: scaleX(0.8);
    }
    45% {
      transform: scaleX(0.8);
    }
    58% {
      transform: scaleX(1);
    }
    92% {
      transform: scaleX(1);
      opacity: 1;
    }
    98%,
    100% {
      transform: scaleX(1);
      opacity: 0;
    }
  }

  .dsc-gap,
  .dsc-gap-label {
    animation: dsc-gap-in 7s ease-in-out infinite both;
  }
  @keyframes dsc-gap-in {
    0%,
    24% {
      opacity: 0;
    }
    30%,
    45% {
      opacity: 1;
    }
    54%,
    100% {
      opacity: 0;
    }
  }

  .dsc-val-new {
    animation: dsc-swap-in 7s linear infinite both;
  }
  .dsc-factor-new {
    animation: dsc-swap-in 7s linear infinite both;
  }
  @keyframes dsc-swap-in {
    0%,
    45% {
      opacity: 0;
    }
    48% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }
  .dsc-val-old,
  .dsc-factor-old {
    animation: dsc-old-out 7s linear infinite both;
  }
  @keyframes dsc-old-out {
    0% {
      opacity: 0;
    }
    8%,
    45% {
      opacity: 1;
    }
    48%,
    100% {
      opacity: 0;
    }
  }

  .dsc-status-on {
    animation: dsc-status-on 7s linear infinite both;
  }
  @keyframes dsc-status-on {
    0%,
    62% {
      opacity: 0;
    }
    66% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }
  .dsc-status-off {
    animation: dsc-status-off 7s linear infinite both;
  }
  @keyframes dsc-status-off {
    0% {
      opacity: 0;
    }
    8%,
    62% {
      opacity: 1;
    }
    66%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dsc-bar-in,
    .dsc-bar-alloc,
    .dsc-gap,
    .dsc-gap-label,
    .dsc-val-old,
    .dsc-val-new,
    .dsc-factor-old,
    .dsc-factor-new,
    .dsc-status-off,
    .dsc-status-on {
      animation: none;
    }
    .dsc-bar-in,
    .dsc-bar-alloc {
      transform: scaleX(1);
      opacity: 1;
    }
    .dsc-gap,
    .dsc-gap-label,
    .dsc-val-old,
    .dsc-factor-old,
    .dsc-status-off {
      opacity: 0;
    }
    .dsc-val-new,
    .dsc-factor-new,
    .dsc-status-on {
      opacity: 1;
    }
  }
</style>
