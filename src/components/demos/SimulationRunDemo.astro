---
// Simulation run demo: a "Running EPANET 2.3" toast with a progress hairline,
// then the network recolors by flow and the result legend appears. The
// loop reads as the model being re-run.
import { Zap } from "lucide-react";
import NetworkMap from "./NetworkMap.astro";
import NetworkMapAlt from "./NetworkMapAlt.astro";
import LegendPanel from "./LegendPanel.astro";

interface Props {
  /** Render NetworkMapAlt instead of NetworkMap. */
  alt?: boolean;
}

const { alt = false } = Astro.props;
const Map = alt ? NetworkMapAlt : NetworkMap;
---

<div
  class="relative mx-auto aspect-[3/2] w-full max-w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Running a simulation in epanet-js: the network recolors by flow when the simulation finishes, with a legend.">
  <!-- plain base map, recolored by the flow overlay below -->
  <Map variant="plain" class="absolute inset-0" />

  <!-- flow result layer fading in over the plain base map -->
  <div class="sr-result absolute inset-0">
    <Map variant="pressure" class="absolute inset-0" />
  </div>

  <!-- run toast -->
  <div
    class="sr-toast absolute top-2 left-1/2 -translate-x-1/2 w-[180px] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div class="flex items-center gap-1.5 px-3 pt-2 pb-1.5">
      <Zap size={12} className="text-violet-600 shrink-0" />
      <span class="text-xs text-gray-600">Running simulation...</span>
    </div>
    <div class="h-0.5 bg-gray-100">
      <div class="sr-progress h-full bg-violet-500"></div>
    </div>
  </div>

  <!-- result legend -->
  <div class="sr-legend absolute bottom-2 left-2">
    <LegendPanel title="Flow (l/s)" />
  </div>
</div>

<style>
  .sr-result {
    opacity: 0;
    animation: sr-result-in 7s ease-in-out infinite both;
  }
  @keyframes sr-result-in {
    0%,
    35% {
      opacity: 0;
    }
    50%,
    90% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .sr-toast {
    animation: sr-toast-in 7s ease infinite both;
  }
  @keyframes sr-toast-in {
    0% {
      opacity: 0;
      transform: translate(-50%, -6px);
    }
    6% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    38% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    46%,
    100% {
      opacity: 0;
      transform: translate(-50%, 0);
    }
  }

  .sr-progress {
    width: 0;
    animation: sr-progress 7s infinite both;
  }
  @keyframes sr-progress {
    0% {
      width: 0;
    }
    35%,
    100% {
      width: 100%;
    }
  }

  .sr-legend {
    opacity: 0;
    animation: sr-legend-in 7s ease infinite both;
  }
  @keyframes sr-legend-in {
    0%,
    45% {
      opacity: 0;
      transform: translateY(4px);
    }
    55% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
      transform: translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sr-result,
    .sr-toast,
    .sr-progress,
    .sr-legend {
      animation: none;
    }
    .sr-result {
      opacity: 1;
    }
    .sr-toast {
      opacity: 0;
    }
    .sr-progress {
      width: 100%;
    }
    .sr-legend {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
