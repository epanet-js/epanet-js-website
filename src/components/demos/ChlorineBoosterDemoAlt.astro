---
// Alternate version of ChlorineBoosterDemo, banding the alt network's 16
// pipes by distance from the reservoir (same tiers as WaterAgeDemoAlt /
// ZoneFitDemoAlt) instead of the original's index-range slices. The booster
// sits at junction (270,86); "mid" and "tail" pipes are what comes back to
// green once it's added.
import AppWindow from "./AppWindow.astro";
import { pipes, junctions } from "./network-geometry-alt";
import { JUNCTION_COLOR, JUNCTION_RADIUS, OUTLINE_COLOR, OUTLINE_STROKE_WIDTH, PIPE_STROKE_WIDTH } from "./network-style-alt";

const BOOSTER_JUNCTION: [number, number] = [270, 86];

const bands = [
  { color: "#22c55e", cls: "clba-src", pipes: [0, 1, 2, 3, 4, 6, 7, 15].map((i) => pipes[i]) },
  { color: "#f59e0b", cls: "clba-mid", pipes: [5, 8, 9, 10, 13, 14].map((i) => pipes[i]) },
  { color: "#ef4444", cls: "clba-tail", pipes: [11, 12].map((i) => pipes[i]) },
];

// After the booster, everything downstream (mid + tail) comes back to green.
const fixedPipes = [5, 8, 9, 10, 11, 12, 13, 14].map((i) => pipes[i]);
---

<AppWindow
  variant="plain"
  altNetwork
  hideHeader
  hideFooter
  label="Chlorine residual in epanet-js: the network tinted by residual as it decays from the works, then a booster lifting the tail back above the 0.2 milligram per liter minimum.">
  <!-- residual tint overlay -->
  <svg
    viewBox="0 0 640 400"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <g stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round" fill="none">
      {
        bands.map((band) =>
          band.pipes.map(([x1, y1, x2, y2]) => (
            <line
              class={band.cls}
              x1={x1}
              y1={y1}
              x2={x2}
              y2={y2}
              stroke={band.color}
            />
          )),
        )
      }
      {
        fixedPipes.map(([x1, y1, x2, y2]) => (
          <line
            class="clba-fix"
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
            stroke="#22c55e"
          />
        ))
      }
    </g>

    <!-- redraw the junction dots on top of the residual-tint overlay
         lines, since this overlay is a separate sibling painted after
         NetworkMapAlt's own junctions and would otherwise cover them (every
         pipe gets tinted across the three bands, so every junction is
         affected) -->
    <g stroke={OUTLINE_COLOR} stroke-width={OUTLINE_STROKE_WIDTH}>
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r={JUNCTION_RADIUS} fill={JUNCTION_COLOR} />
        ))
      }
    </g>

    <!-- booster station added mid-network -->
    <circle
      class="clba-booster-pulse"
      cx={BOOSTER_JUNCTION[0]}
      cy={BOOSTER_JUNCTION[1]}
      r="13"
      fill="none"
      stroke="#8b5cf6"
      stroke-width="2.4"></circle>
    <circle
      class="clba-booster"
      cx={BOOSTER_JUNCTION[0]}
      cy={BOOSTER_JUNCTION[1]}
      r="8"
      fill="#8b5cf6"
      stroke="#ffffff"
      stroke-width="2.4"></circle>
  </svg>

  <!-- residual panel -->
  <div
    class="clba-panel absolute top-2 right-2 w-[220px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Chlorine residual</p>
      <p class="text-xs text-gray-400">mg/l</p>
    </div>
    <div class="px-3 pt-2 pb-1">
      <svg viewBox="0 0 170 70" class="w-full" aria-hidden="true">
        <!-- minimum residual floor -->
        <line
          x1="4"
          y1="46"
          x2="166"
          y2="46"
          stroke="#d1d5db"
          stroke-width="1"
          stroke-dasharray="3 2"></line>
        <text x="166" y="43" text-anchor="end" font-size="10.4" fill="#9ca3af">
          0.2 min
        </text>

        <!-- decay from the works; the tail drops below the floor -->
        <polyline
          class="clba-curve-head"
          pathLength="100"
          points="4,12 30,22 56,31 82,39 100,44"
          fill="none"
          stroke="#8b5cf6"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>
        <polyline
          class="clba-curve-tail"
          pathLength="100"
          points="100,44 130,52 166,57"
          fill="none"
          stroke="#8b5cf6"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>
        <polyline
          class="clba-tail-flash"
          points="100,44 130,52 166,57"
          fill="none"
          stroke="#f59e0b"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>

        <!-- booster location and the lifted tail -->
        <line
          class="clba-marker"
          x1="100"
          y1="8"
          x2="100"
          y2="62"
          stroke="#8b5cf6"
          stroke-width="1"
          stroke-dasharray="3 2"></line>
        <polyline
          class="clba-lift"
          pathLength="100"
          points="100,44 106,24 132,32 166,39"
          fill="none"
          stroke="#22c55e"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>
      </svg>
      <p class="mt-0.5 whitespace-nowrap text-xs text-gray-400">
        Residual vs distance from works
      </p>
    </div>
    <p
      class="clba-chip px-3 py-1.5 border-t border-gray-100 text-xs font-medium text-green-600">
      ≥ 0.2 mg/l network-wide
    </p>
  </div>
</AppWindow>

<style>
  /* residual bands tint the map outward from the works. 10s cycle: the
     original 8s sequence rescaled by 8/10 so every event keeps its
     absolute-second pacing, with the shared hold-before-fade marker
     (92%/98%/100% below) pushed back an extra 2s so everything holds at
     full state for 2s longer before the fade-out. */
  .clba-src {
    animation: clba-band-1 10s ease-in-out infinite both;
  }
  .clba-mid {
    animation: clba-band-2 10s ease-in-out infinite both;
  }
  .clba-tail {
    animation: clba-band-3 10s ease-in-out infinite both;
  }
  @keyframes clba-band-1 {
    0%, 4.8% { opacity: 0; }
    11.2% { opacity: 1; }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }
  @keyframes clba-band-2 {
    0%, 7.2% { opacity: 0; }
    13.6% { opacity: 1; }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }
  @keyframes clba-band-3 {
    0%, 9.6% { opacity: 0; }
    16% { opacity: 1; }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }

  /* downstream pipes come back to green after the booster */
  .clba-fix {
    animation: clba-fix-in 10s ease-in-out infinite both;
  }
  @keyframes clba-fix-in {
    0%,
    46.4% {
      opacity: 0;
    }
    57.6% {
      opacity: 1;
    }
    93.6% {
      opacity: 1;
    }
    98.4%,
    100% {
      opacity: 0;
    }
  }

  .clba-booster {
    transform-box: fill-box;
    transform-origin: center;
    animation: clba-booster-in 10s ease-out infinite both;
  }
  @keyframes clba-booster-in {
    0%,
    36.8% {
      opacity: 0;
      transform: scale(0);
    }
    40% {
      opacity: 1;
      transform: scale(1.3);
    }
    41.6% {
      transform: scale(1);
    }
    93.6% {
      opacity: 1;
      transform: scale(1);
    }
    98.4%,
    100% {
      opacity: 0;
    }
  }
  .clba-booster-pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: clba-booster-pulse 10s ease-out infinite both;
  }
  @keyframes clba-booster-pulse {
    0%,
    40% {
      opacity: 0;
      transform: scale(0.8);
    }
    43.2% {
      opacity: 0.7;
      transform: scale(1);
    }
    51.2% {
      opacity: 0;
      transform: scale(2);
    }
    56%,
    59.2% {
      opacity: 0.5;
      transform: scale(1);
    }
    67.2%,
    100% {
      opacity: 0;
      transform: scale(2);
    }
  }

  .clba-panel {
    animation: clba-panel-in 10s ease-out infinite both;
  }
  @keyframes clba-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    4.8% {
      opacity: 1;
      transform: translateY(0);
    }
    93.6% {
      opacity: 1;
    }
    98.4%,
    100% {
      opacity: 0;
    }
  }

  .clba-curve-head {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: clba-head-draw 10s linear infinite both;
  }
  @keyframes clba-head-draw {
    0%,
    9.6% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    20% {
      stroke-dashoffset: 0;
    }
    93.6% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98.4%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  /* the tail draws, then dims once the lifted curve takes over */
  .clba-curve-tail {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: clba-tail-draw 10s linear infinite both;
  }
  @keyframes clba-tail-draw {
    0%,
    20% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    25.6% {
      stroke-dashoffset: 0;
    }
    41.6% {
      opacity: 1;
    }
    49.6% {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
    93.6% {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
    98.4%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  .clba-tail-flash {
    animation: clba-tail-flash 10s linear infinite both;
  }
  @keyframes clba-tail-flash {
    0%,
    28.8% {
      opacity: 0;
    }
    31.2%,
    33.6% {
      opacity: 1;
    }
    35.2% {
      opacity: 0;
    }
    36.8%,
    39.2% {
      opacity: 1;
    }
    41.6%,
    100% {
      opacity: 0;
    }
  }

  .clba-marker {
    animation: clba-marker-in 10s ease-out infinite both;
  }
  @keyframes clba-marker-in {
    0%,
    38.4% {
      opacity: 0;
    }
    41.6% {
      opacity: 1;
    }
    93.6% {
      opacity: 1;
    }
    98.4%,
    100% {
      opacity: 0;
    }
  }

  .clba-lift {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: clba-lift-draw 10s linear infinite both;
  }
  @keyframes clba-lift-draw {
    0%,
    41.6% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    52.8% {
      stroke-dashoffset: 0;
    }
    93.6% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98.4%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  .clba-chip {
    animation: clba-chip-in 10s ease-out infinite both;
  }
  @keyframes clba-chip-in {
    0%,
    60.8% {
      opacity: 0;
    }
    65.6% {
      opacity: 1;
    }
    93.6% {
      opacity: 1;
    }
    98.4%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .clba-src,
    .clba-mid,
    .clba-tail,
    .clba-fix,
    .clba-booster,
    .clba-booster-pulse,
    .clba-panel,
    .clba-curve-head,
    .clba-curve-tail,
    .clba-tail-flash,
    .clba-marker,
    .clba-lift,
    .clba-chip {
      animation: none;
    }
    .clba-src,
    .clba-mid,
    .clba-tail,
    .clba-fix,
    .clba-panel,
    .clba-marker,
    .clba-chip {
      opacity: 1;
      transform: none;
    }
    .clba-booster {
      opacity: 1;
      transform: scale(1);
    }
    .clba-booster-pulse,
    .clba-tail-flash {
      opacity: 0;
    }
    .clba-curve-head,
    .clba-lift {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .clba-curve-tail {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
  }
</style>
