---
// Alternate version of GisImportDemo, rendered over BasemapAlt / the
// network-geometry-alt network instead of Basemap / network-geometry. Same
// staged-import timing logic (draw order, stagger, node pop) since it
// doesn't depend on which geometry set is passed in -- only the imports,
// canvas, and stroke sizing differ.
import { FileUp, CheckCircle2 } from "lucide-react";
import AppWindow from "./AppWindow.astro";
import BasemapAlt from "./BasemapAlt.astro";
import { pipes, junctions, reservoirPoint } from "./network-geometry-alt";
import {
  PIPE_COLOR,
  PIPE_STROKE_WIDTH,
  JUNCTION_COLOR,
  JUNCTION_RADIUS,
  OUTLINE_COLOR,
  OUTLINE_STROKE_WIDTH,
  RESERVOIR_COLOR,
  RESERVOIR_APEX_OFFSET,
  RESERVOIR_BASE_OFFSET,
  RESERVOIR_HALF_WIDTH,
} from "./network-style-alt";

// Orient each pipe so it draws from its west endpoint, then sweep west to east.
const drawnPipes = pipes
  .map(([x1, y1, x2, y2]) =>
    x1 <= x2 ? [x1, y1, x2, y2] : [x2, y2, x1, y1],
  )
  .sort((a, b) => a[0] - b[0]);

const sortedJunctions = [...junctions].sort((a, b) => a[0] - b[0]);

// Total cycle length. Every keyframe percentage below is a fraction of this,
// so this is the one number to touch to stretch/compress the whole sequence.
const CYCLE = 12.5;
const toPct = (seconds: number) => +((seconds / CYCLE) * 100).toFixed(3);

// Network drawing only starts once the chip + popover have fully faded out
// (see the "fade" breakpoints on .gis-chip / .gis-panel below).
const NETWORK_START = 5.25;

// Every pipe/junction gets its own dedicated @keyframes with the draw time
// baked directly into the percentages (no animation-delay) -- see
// GisImportDemo.astro for why.
const PIPE_STAGGER = 0.11;
const PIPE_DRAW = 0.4;
const pipeTimings = drawnPipes.map((_, i) => {
  const start = NETWORK_START + i * PIPE_STAGGER;
  return { start, end: start + PIPE_DRAW };
});

// Junctions must not pop before the network has actually grown into them --
// see GisImportDemo.astro for the full reasoning.
const NODE_BUFFER = 0.05;
const NODE_BOUNCE = 0.15;
const NODE_SETTLE = 0.2;
const arrivalTimeByX = new Map<number, number>();
drawnPipes.forEach(([, , x2], i) => {
  const { end } = pipeTimings[i];
  const prev = arrivalTimeByX.get(x2);
  if (prev === undefined || end < prev) arrivalTimeByX.set(x2, end);
});
const nodeTimings = sortedJunctions.map(([x]) => {
  const start = (arrivalTimeByX.get(x) ?? NETWORK_START) + NODE_BUFFER;
  return { start, bounce: start + NODE_BOUNCE, settle: start + NODE_SETTLE };
});
// The reservoir is a pure source (nothing arrives at it) -- it pops as soon
// as its own outgoing pipe (the first one, index 0) starts drawing.
const tankTiming = (() => {
  const start = pipeTimings[0].start + NODE_BUFFER;
  return { start, bounce: start + NODE_BOUNCE, settle: start + NODE_SETTLE };
})();

// The dash-reveal fade-in -- see GisImportDemo.astro for why this exists.
const PIPE_FADE_IN = PIPE_DRAW * 0.3;
const pipeCss = pipeTimings
  .map(
    ({ start, end }, i) => `
.gisa-pipe-${i} { animation-name: gisa-pipe-draw-${i}; }
@keyframes gisa-pipe-draw-${i} {
  0%, ${toPct(start)}% { stroke-dashoffset: 100; opacity: 0; }
  ${toPct(start + PIPE_FADE_IN)}% { opacity: 1; }
  ${toPct(end)}%, 100% { stroke-dashoffset: 0; opacity: 1; }
}`,
  )
  .join("\n");

const nodeCss = nodeTimings
  .map(
    ({ start, bounce, settle }, i) => `
.gisa-node-${i} { animation-name: gisa-node-pop-${i}; }
@keyframes gisa-node-pop-${i} {
  0%, ${toPct(start)}% { transform: scale(0); }
  ${toPct(bounce)}% { transform: scale(1.25); }
  ${toPct(settle)}%, 100% { transform: scale(1); }
}`,
  )
  .join("\n");

const tankCss = `
.gisa-tank { animation-name: gisa-tank-pop; }
@keyframes gisa-tank-pop {
  0%, ${toPct(tankTiming.start)}% { transform: scale(0); }
  ${toPct(tankTiming.bounce)}% { transform: scale(1.25); }
  ${toPct(tankTiming.settle)}%, 100% { transform: scale(1); }
}`;

const generatedCss = `${pipeCss}\n${nodeCss}\n${tankCss}`;

const summary = [
  { label: "Pipes", value: "1,407" },
  { label: "Junctions", value: "1,284" },
  { label: "Demand patterns", value: "6" },
];
---

<AppWindow
  bare
  hideHeader
  hideFooter
  label="GIS import in epanet-js: a shapefile loading onto the map as pipes and junctions appear, with an import summary popover.">
  <!-- map: basemap plus the imported network drawing in -->
  <svg
    viewBox="0 0 640 400"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <BasemapAlt />

    <!-- whole network fades in/out together once drawing starts -->
    <g class="gisa-network">
      <g stroke={PIPE_COLOR} stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round">
        {
          drawnPipes.map(([x1, y1, x2, y2], i) => (
            <line
              x1={x1}
              y1={y1}
              x2={x2}
              y2={y2}
              pathLength="100"
              class={`gisa-pipe gisa-pipe-${i}`}
            />
          ))
        }
      </g>

      <g stroke={OUTLINE_COLOR} stroke-width={OUTLINE_STROKE_WIDTH}>
        {
          sortedJunctions.map(([x, y], i) => (
            <circle
              cx={x}
              cy={y}
              r={JUNCTION_RADIUS}
              fill={JUNCTION_COLOR}
              class={`gisa-node gisa-node-${i}`}
            />
          ))
        }
      </g>

      <!-- reservoir at the supply point pops first -->
      <path
        d={`M${reservoirPoint[0]} ${reservoirPoint[1] - RESERVOIR_APEX_OFFSET} L${reservoirPoint[0] + RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} L${reservoirPoint[0] - RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} Z`}
        fill={RESERVOIR_COLOR}
        stroke={OUTLINE_COLOR}
        stroke-width={OUTLINE_STROKE_WIDTH}
        class="gisa-node gisa-tank"></path>
    </g>
  </svg>

  <!-- dropped file chip, with the progress popover stacked directly below it -->
  <div class="absolute top-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <div
      class="gisa-chip flex items-center gap-2 bg-white rounded-lg border border-gray-100 shadow-md pl-2 pr-3 py-2">
      <span
        class="flex items-center justify-center w-6 h-6 rounded bg-violet-50 text-violet-600">
        <FileUp size={14} />
      </span>
      <span class="text-xs font-medium text-gray-700">network.shp</span>
      <span class="text-xs text-gray-400">2.1 MB</span>
    </div>

    <div
      class="gisa-panel w-[190px] max-w-full bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
      <div class="px-3 pt-2.5 pb-2 border-b border-gray-100">
        <div class="flex items-baseline justify-between">
          <p class="text-xs font-semibold text-gray-700">GIS import</p>
          <p class="text-xs text-gray-400">network.shp</p>
        </div>
        <div class="mt-2 h-0.5 rounded-full bg-gray-100 overflow-hidden">
          <div class="gisa-progress-bar h-full bg-violet-500"></div>
        </div>
      </div>
      <div class="py-1 text-xs">
        {
          summary.map((row, i) => (
            <div class={`gisa-row gisa-row-${i} flex items-center justify-between px-3 py-1`}>
              <span class="text-gray-500">{row.label}</span>
              <span class="font-medium text-gray-700 tabular-nums">
                {row.value}
              </span>
            </div>
          ))
        }
      </div>
      <p
        class="gisa-footer flex items-center gap-1 px-3 py-1.5 border-t border-gray-100 text-xs text-green-600">
        <span class="gisa-check inline-flex">
          <CheckCircle2 size={14} />
        </span>
        All features connected
      </p>
    </div>
  </div>
</AppWindow>

<style define:vars={{ cycle: `${CYCLE}s` }}>
  .gisa-pipe {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    opacity: 0;
    animation-duration: var(--cycle);
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  .gisa-node {
    transform: scale(0);
    transform-box: fill-box;
    transform-origin: center;
    animation-duration: var(--cycle);
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }

  .gisa-network {
    opacity: 0;
    animation: gisa-network-fade var(--cycle) infinite both;
  }
  @keyframes gisa-network-fade {
    0%,
    42% {
      opacity: 0;
    }
    42.8% {
      opacity: 1;
    }
    88% {
      opacity: 1;
    }
    92% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .gisa-chip {
    animation: gisa-chip-in var(--cycle) infinite both;
  }
  @keyframes gisa-chip-in {
    0% {
      opacity: 0;
      transform: translateY(-6px);
    }
    3.6% {
      opacity: 1;
      transform: translateY(0);
    }
    38% {
      opacity: 1;
    }
    42% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .gisa-panel {
    animation: gisa-panel-in var(--cycle) infinite both;
  }
  @keyframes gisa-panel-in {
    0%,
    6% {
      opacity: 0;
      transform: translateY(4px);
    }
    9.2% {
      opacity: 1;
      transform: translateY(0);
    }
    38% {
      opacity: 1;
    }
    42% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .gisa-progress-bar {
    width: 0;
    animation: gisa-progress var(--cycle) linear infinite both;
  }
  @keyframes gisa-progress {
    0%,
    9.2% {
      width: 0;
      opacity: 1;
    }
    18% {
      width: 100%;
      opacity: 1;
    }
    38% {
      width: 100%;
      opacity: 1;
    }
    42% {
      width: 100%;
      opacity: 0;
    }
    100% {
      width: 100%;
      opacity: 0;
    }
  }

  .gisa-row {
    animation-duration: var(--cycle);
    animation-iteration-count: infinite;
    animation-fill-mode: both;
  }
  .gisa-row-0 {
    animation-name: gisa-row-in-0;
  }
  .gisa-row-1 {
    animation-name: gisa-row-in-1;
  }
  .gisa-row-2 {
    animation-name: gisa-row-in-2;
  }
  @keyframes gisa-row-in-0 {
    0%,
    18% {
      opacity: 0;
      transform: translateY(4px);
    }
    20.4% {
      opacity: 1;
      transform: translateY(0);
    }
    38% {
      opacity: 1;
    }
    42% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }
  @keyframes gisa-row-in-1 {
    0%,
    20.8% {
      opacity: 0;
      transform: translateY(4px);
    }
    23.2% {
      opacity: 1;
      transform: translateY(0);
    }
    38% {
      opacity: 1;
    }
    42% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }
  @keyframes gisa-row-in-2 {
    0%,
    23.6% {
      opacity: 0;
      transform: translateY(4px);
    }
    26% {
      opacity: 1;
      transform: translateY(0);
    }
    38% {
      opacity: 1;
    }
    42% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .gisa-footer {
    animation: gisa-footer-in var(--cycle) infinite both;
  }
  @keyframes gisa-footer-in {
    0%,
    27.6% {
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    38% {
      opacity: 1;
    }
    42% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }
  .gisa-check {
    animation: gisa-check-pulse 1.8s ease-in-out infinite;
  }
  @keyframes gisa-check-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.12);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gisa-pipe,
    .gisa-node,
    .gisa-network,
    .gisa-chip,
    .gisa-panel,
    .gisa-progress-bar,
    .gisa-row,
    .gisa-footer,
    .gisa-check {
      animation: none;
    }
    .gisa-pipe {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .gisa-node {
      transform: scale(1);
    }
    .gisa-network {
      opacity: 1;
    }
    .gisa-chip,
    .gisa-panel,
    .gisa-row {
      opacity: 1;
      transform: none;
    }
    .gisa-footer {
      opacity: 1;
    }
    .gisa-progress-bar {
      width: 100%;
      opacity: 0;
    }
  }
</style>

<style set:html={generatedCss} />
