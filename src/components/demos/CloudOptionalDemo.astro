---
// Cloud optional diagram: one model syncing from a cloud, ours or yours,
// down to three devices and back. The cloud is a sync point, not a
// requirement.
import { Cloud, FileText, Laptop, Monitor } from "lucide-react";
import NetworkMap from "./NetworkMap.astro";

const devices = [
  { icon: Monitor, label: "Office" },
  { icon: Monitor, label: "Office" },
  { icon: Laptop, label: "Site" },
];
---

<div
  class="relative aspect-[3/2] w-full overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: one model syncing through a cloud, managed or self-hosted, down to three devices and back.">
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="box-border flex h-full w-full flex-col justify-between p-4">
    <!-- the sync point -->
    <div class="flex items-center justify-center gap-4">
      <span class="cop-cloud relative text-indigo-950">
        <Cloud size={40} />
        <span
          class="cop-badge absolute -bottom-1.5 left-1/2 flex -translate-x-1/2 items-center gap-1 rounded border border-gray-200 bg-white px-1.5 text-[12px] font-semibold text-gray-600 shadow-sm">
          <FileText size={12} className="text-violet-500" />
          .ejsdb
        </span>
      </span>
      <p class="cop-caption text-[14px] leading-tight text-gray-500">
        Our cloud,
        <br />
        or yours.
      </p>
    </div>

    <!-- trunk, bus, and drops to each device -->
    <div class="relative h-16">
      <svg
        viewBox="0 0 300 48"
        preserveAspectRatio="none"
        class="absolute inset-0 h-full w-full"
        aria-hidden="true">
        <path
          class="cop-lines"
          d="M150 2 V20 M50 20 H250 M50 20 V40 M150 20 V40 M250 20 V40"
          fill="none"
          stroke="#9ca3af"
          stroke-width="1.5"
          pathLength="100"></path>
        <g class="cop-heads" fill="#9ca3af">
          <path d="M46 36 L50 44 L54 36 Z"></path>
          <path d="M146 36 L150 44 L154 36 Z"></path>
          <path d="M246 36 L250 44 L254 36 Z"></path>
        </g>
        <!-- sync dots: down to each device, then one back up -->
        <circle class="cop-dot cop-dot-1" cx="50" cy="16" r="3.5" fill="#8b5cf6"
        ></circle>
        <circle class="cop-dot cop-dot-2" cx="150" cy="16" r="3.5" fill="#8b5cf6"
        ></circle>
        <circle class="cop-dot cop-dot-3" cx="250" cy="16" r="3.5" fill="#8b5cf6"
        ></circle>
        <circle class="cop-dot cop-dot-up" cx="150" cy="40" r="3.5" fill="#6366f1"
        ></circle>
      </svg>
    </div>

    <!-- devices -->
    <div class="grid grid-cols-3 gap-4">
      {
        devices.map((device, i) => (
          <div>
            <div class="rounded-lg border-2 border-gray-300 overflow-hidden">
              <div class="relative aspect-[3/2] bg-gray-100">
                <NetworkMap class="absolute inset-0" />
                <span
                  class={`cop-tick-${i + 1} absolute top-1 right-1 h-2.5 w-2.5 rounded-full bg-violet-500 ring-2 ring-white`}
                />
              </div>
            </div>
            <div class="h-1.5 mx-4 rounded-b-lg bg-gray-300" />
            <p class="flex items-center justify-center gap-1.5 mt-2 text-[12px] font-medium text-gray-600">
              <device.icon size={16} className="text-gray-400" />
              {device.label}
            </p>
          </div>
        ))
      }
    </div>
      </div>
    </foreignObject>
  </svg>
</div>

<style>
  .cop-cloud,
  .cop-caption {
    animation: cop-cloud-in 8s ease-out infinite both;
  }
  @keyframes cop-cloud-in {
    0%,
    3% {
      opacity: 0;
    }
    9% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* the model badge ticks when the upstream change lands */
  .cop-badge {
    animation: cop-badge-tick 8s ease-out infinite both;
  }
  @keyframes cop-badge-tick {
    0%,
    72% {
      transform: translateX(-50%) scale(1);
    }
    75% {
      transform: translateX(-50%) scale(1.15);
    }
    78% {
      transform: translateX(-50%) scale(1);
    }
    100% {
      transform: translateX(-50%) scale(1);
    }
  }

  .cop-lines {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: cop-lines-draw 8s linear infinite both;
  }
  @keyframes cop-lines-draw {
    0%,
    14% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    26% {
      stroke-dashoffset: 0;
    }
    94% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  .cop-heads {
    animation: cop-heads-in 8s linear infinite both;
  }
  @keyframes cop-heads-in {
    0%,
    25% {
      opacity: 0;
    }
    28% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* sync dots slide down each drop in turn, then one heads back up */
  .cop-dot {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
  }
  .cop-dot-1 {
    animation: cop-dot-down-1 8s ease-in-out infinite both;
  }
  .cop-dot-2 {
    animation: cop-dot-down-2 8s ease-in-out infinite both;
  }
  .cop-dot-3 {
    animation: cop-dot-down-3 8s ease-in-out infinite both;
  }
  .cop-dot-up {
    animation: cop-dot-up 8s ease-in-out infinite both;
  }
  @keyframes cop-dot-down-1 {
    0%, 30% { opacity: 0; transform: translateY(-12px); }
    33% { opacity: 1; }
    38% { opacity: 1; transform: translateY(22px); }
    40%, 100% { opacity: 0; transform: translateY(24px); }
  }
  @keyframes cop-dot-down-2 {
    0%, 38% { opacity: 0; transform: translateY(-12px); }
    41% { opacity: 1; }
    46% { opacity: 1; transform: translateY(22px); }
    48%, 100% { opacity: 0; transform: translateY(24px); }
  }
  @keyframes cop-dot-down-3 {
    0%, 46% { opacity: 0; transform: translateY(-12px); }
    49% { opacity: 1; }
    54% { opacity: 1; transform: translateY(22px); }
    56%, 100% { opacity: 0; transform: translateY(24px); }
  }
  @keyframes cop-dot-up {
    0%, 62% { opacity: 0; transform: translateY(0); }
    65% { opacity: 1; }
    71% { opacity: 1; transform: translateY(-36px); }
    73%, 100% { opacity: 0; transform: translateY(-38px); }
  }

  /* each device blinks a sync tick as its copy lands */
  .cop-tick-1 {
    animation: cop-tick-1 8s ease-out infinite both;
  }
  .cop-tick-2 {
    animation: cop-tick-2 8s ease-out infinite both;
  }
  .cop-tick-3 {
    animation: cop-tick-3 8s ease-out infinite both;
  }
  @keyframes cop-tick-1 {
    0%, 38% { opacity: 0; transform: scale(0.5); }
    41% { opacity: 1; transform: scale(1.2); }
    44% { transform: scale(1); }
    94% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; }
  }
  @keyframes cop-tick-2 {
    0%, 46% { opacity: 0; transform: scale(0.5); }
    49% { opacity: 1; transform: scale(1.2); }
    52% { transform: scale(1); }
    94% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; }
  }
  @keyframes cop-tick-3 {
    0%, 54% { opacity: 0; transform: scale(0.5); }
    57% { opacity: 1; transform: scale(1.2); }
    60% { transform: scale(1); }
    94% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cop-cloud,
    .cop-caption,
    .cop-badge,
    .cop-lines,
    .cop-heads,
    .cop-dot-1,
    .cop-dot-2,
    .cop-dot-3,
    .cop-dot-up,
    .cop-tick-1,
    .cop-tick-2,
    .cop-tick-3 {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .cop-lines {
      stroke-dashoffset: 0;
    }
    .cop-badge {
      transform: translateX(-50%);
    }
    .cop-dot-1,
    .cop-dot-2,
    .cop-dot-3,
    .cop-dot-up {
      opacity: 0;
    }
  }
</style>
