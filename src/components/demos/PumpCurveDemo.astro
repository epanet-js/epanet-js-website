---
// Pump curve panel: the head-flow curve for pump PMP-1 drawn against the
// system curve, with the operating point popping in at the intersection and
// efficiency and power chips below. `framed` places the panel over the app map.
import AppWindow from "./AppWindow.astro";

interface Props {
  framed?: boolean;
  class?: string;
}

const { framed = false, class: className } = Astro.props;

const label =
  "Pump curve panel in epanet-js: the head-flow curve for pump PMP-1 crossing the system curve at the operating point, with efficiency and power draw shown below the chart.";
---

{
  framed ? (
    <AppWindow variant="plain" label={label} class={className}>
      <Astro.self class="absolute top-2 right-2 w-[250px] max-w-[72%]" />
    </AppWindow>
  ) : (
    <div
      role="img"
      aria-label={label}
      class:list={[
        "select-none bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden",
        className,
      ]}>
      <div class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
        <p class="text-[11px] font-semibold text-gray-700">Pump PMP-1</p>
        <p class="text-[10px] text-gray-400">Head (m) vs flow (l/s)</p>
      </div>
      <div class="px-3 py-2.5">
        <svg viewBox="0 0 200 90" class="w-full" aria-hidden="true">
          <g stroke="#f3f4f6" stroke-width="1">
            <line x1="0" y1="22" x2="200" y2="22" />
            <line x1="0" y1="44" x2="200" y2="44" />
            <line x1="0" y1="66" x2="200" y2="66" />
          </g>
          <g
            class="pc-hairlines"
            stroke="#d1d5db"
            stroke-width="1"
            stroke-dasharray="2 2">
            <line x1="2" y1="52" x2="113" y2="52" />
            <line x1="118" y1="57" x2="118" y2="88" />
          </g>
          <path
            class="pc-curve pc-curve-pump"
            pathLength="100"
            d="M8 16 Q100 48 192 74"
            fill="none"
            stroke="#8b5cf6"
            stroke-width="1.5"
          />
          <path
            class="pc-curve pc-curve-system"
            pathLength="100"
            d="M8 78 Q120 55 192 28"
            fill="none"
            stroke="#9ca3af"
            stroke-width="1.5"
          />
          <circle
            class="pc-point"
            cx="118"
            cy="52"
            r="3"
            fill="#8b5cf6"
            stroke="#fff"
            stroke-width="1"
          />
        </svg>
        <div class="flex gap-1.5 mt-1.5">
          <span class="pc-chip pc-chip-eff rounded border border-gray-200 px-2 py-1 text-[10px] text-gray-600 tabular-nums">
            Efficiency
            <span class="relative inline-block">
              <span class="pc-eff pc-eff-high">71%</span>
              <span class="pc-eff pc-eff-low absolute inset-0">68%</span>
            </span>
          </span>
          <span class="pc-chip pc-chip-kw rounded border border-gray-200 px-2 py-1 text-[10px] text-gray-600 tabular-nums">
            8.4 kW
          </span>
        </div>
        <div class="flex gap-3 text-[9px] text-gray-400 mt-1.5">
          <span class="flex items-center gap-1">
            <span class="w-2.5 h-0.5 bg-violet-500"></span> Pump PMP-1
          </span>
          <span class="flex items-center gap-1">
            <span class="w-2.5 h-0.5 bg-gray-400"></span> System
          </span>
        </div>
      </div>
    </div>
  )
}

<style>
  .pc-curve {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .pc-curve-pump {
    animation: pc-draw-pump 6s linear infinite both;
  }
  .pc-curve-system {
    animation: pc-draw-system 6s linear infinite both;
  }
  @keyframes pc-draw-pump {
    0% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    30% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes pc-draw-system {
    0%,
    12% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    42% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  .pc-point {
    transform-box: fill-box;
    transform-origin: center;
    animation: pc-point 6s ease-in-out infinite both;
  }
  @keyframes pc-point {
    0%,
    45% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      opacity: 1;
      transform: scale(1.3);
    }
    55% {
      transform: scale(1);
    }
    64% {
      transform: scale(1.15);
    }
    73% {
      transform: scale(1);
    }
    82% {
      transform: scale(1.15);
    }
    92% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 0;
    }
  }
  .pc-hairlines {
    animation: pc-hairlines 6s ease-in-out infinite both;
  }
  @keyframes pc-hairlines {
    0%,
    45% {
      opacity: 0;
    }
    52%,
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  .pc-chip-eff {
    animation: pc-chip-eff 6s ease-out infinite both;
  }
  .pc-chip-kw {
    animation: pc-chip-kw 6s ease-out infinite both;
  }
  @keyframes pc-chip-eff {
    0%,
    55% {
      opacity: 0;
      transform: translateY(4px);
    }
    61% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  @keyframes pc-chip-kw {
    0%,
    61% {
      opacity: 0;
      transform: translateY(4px);
    }
    68% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  .pc-eff-high {
    animation: pc-eff-high 6s ease-in-out infinite both;
  }
  .pc-eff-low {
    animation: pc-eff-low 6s ease-in-out infinite both;
  }
  @keyframes pc-eff-high {
    0%,
    68% {
      opacity: 1;
    }
    75%,
    83% {
      opacity: 0;
    }
    90%,
    100% {
      opacity: 1;
    }
  }
  @keyframes pc-eff-low {
    0%,
    68% {
      opacity: 0;
    }
    75%,
    83% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pc-curve,
    .pc-curve-pump,
    .pc-curve-system,
    .pc-point,
    .pc-hairlines,
    .pc-chip-eff,
    .pc-chip-kw,
    .pc-eff-high,
    .pc-eff-low {
      animation: none;
    }
    .pc-curve,
    .pc-curve-pump,
    .pc-curve-system {
      stroke-dashoffset: 0;
    }
    .pc-point {
      opacity: 1;
      transform: scale(1);
    }
    .pc-hairlines {
      opacity: 1;
    }
    .pc-chip-eff,
    .pc-chip-kw {
      opacity: 1;
      transform: translateY(0);
    }
    .pc-eff-high {
      opacity: 1;
    }
    .pc-eff-low {
      opacity: 0;
    }
  }
</style>
