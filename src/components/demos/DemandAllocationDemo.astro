---
// Flow balance concept: metered inflow allocated across demand zones, each
// with its own consumption profile, reconciling to a balance check.
import { CheckCircle2, Gauge } from "lucide-react";

const zones = [
  { name: "Zone A", flow: "41.2", bars: [35, 55, 90, 70, 50, 65] },
  { name: "Zone B", flow: "28.7", bars: [45, 70, 100, 60, 40, 55] },
  { name: "Zone C", flow: "15.6", bars: [30, 50, 75, 95, 60, 45] },
];
---

<div
  class="relative mx-auto aspect-[3/2] w-full max-w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: metered inflow allocated across three demand zones, each with a daily consumption profile, reconciling in a balance check.">
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="flex h-full w-full flex-col items-center justify-between">
        <div class="box-border flex w-full flex-1 flex-col items-center justify-center gap-2 px-8 pt-8">
          <div
            class="box-border flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-2 py-3 shadow-sm">
            <span
              class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
              <Gauge size={23} />
            </span>
            <div>
              <p class="text-xs font-semibold text-gray-700">Metered inflow</p>
              <p class="text-xs text-gray-500 tabular-nums">86.4 m³/h</p>
            </div>
          </div>

          <div class="w-full max-w-[300px]">
            <svg viewBox="0 0 300 40" class="h-10 w-full" aria-hidden="true">
              <g
                class="da-arrow"
                fill="none"
                stroke="#c4b5fd"
                stroke-width="1.5"
                stroke-dasharray="4 3">
                <path d="M150 0 C 150 20, 60 18, 52 40"></path>
                <path d="M150 0 L 150 40"></path>
                <path d="M150 0 C 150 20, 240 18, 248 40"></path>
              </g>
            </svg>

            <div class="grid grid-cols-3 gap-3">
              {
                zones.map((zone, zi) => (
                  <div class="box-border rounded-lg border border-gray-200 bg-white px-2 py-3 shadow-sm">
                    <p class="text-xs font-semibold text-gray-700">{zone.name}</p>
                    <p class="text-xs text-gray-500 tabular-nums">{zone.flow} m³/h</p>
                    <div class="mt-1.5 flex h-8 items-end gap-0.5">
                      {zone.bars.map((height, bi) => (
                        <span
                          class="da-bar flex-1 rounded-sm bg-violet-400"
                          style={`height: ${height}%; animation-delay: ${zi * 0.2 + bi * 0.1}s`}
                        />
                      ))}
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <p
          class="flex items-center justify-center gap-1.5 pb-6 text-sm font-medium text-gray-700">
          <CheckCircle2 size={14} className="text-green-500" />
          Balance check: 99.2% allocated · 0.8% unaccounted
        </p>
      </div>
    </foreignObject>
  </svg>
</div>

<style>
  .da-arrow path {
    animation: da-march 1.4s linear infinite;
  }
  @keyframes da-march {
    to {
      stroke-dashoffset: -7;
    }
  }
  .da-bar {
    transform-origin: bottom;
    animation: da-rise 5s ease-in-out infinite both;
  }
  @keyframes da-rise {
    0% {
      transform: scaleY(0.15);
    }
    18% {
      transform: scaleY(1);
    }
    88% {
      transform: scaleY(1);
    }
    100% {
      transform: scaleY(0.15);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .da-arrow path,
    .da-bar {
      animation: none;
    }
  }
</style>
