---
// Flow balance concept: metered inflow allocated across demand zones, each
// with its own consumption profile, reconciling to a balance check.
import { CheckCircle2, Gauge } from "lucide-react";

const zones = [
  { name: "Zone A", flow: "41.2", bars: [35, 55, 90, 70, 50, 65] },
  { name: "Zone B", flow: "28.7", bars: [45, 70, 100, 60, 40, 55] },
  { name: "Zone C", flow: "15.6", bars: [30, 50, 75, 95, 60, 45] },
];
---

<div
  class="w-full rounded-xl border border-gray-200 shadow-lg bg-white p-4 sm:p-5 select-none"
  role="img"
  aria-label="Concept diagram: metered inflow being allocated across three demand zones, each with a daily consumption profile, reconciling in a balance check.">
  <div
    class="flex items-center gap-2 mx-auto w-fit bg-white rounded-lg border border-gray-100 shadow-md px-3 py-2">
    <span
      class="flex items-center justify-center w-7 h-7 rounded-lg bg-purple-50 text-purple-600">
      <Gauge size={14} />
    </span>
    <div>
      <p class="text-[11px] font-semibold text-gray-700">Metered inflow</p>
      <p class="text-[10px] text-gray-500 tabular-nums">86.4 m³/h</p>
    </div>
  </div>

  <svg viewBox="0 0 300 40" class="w-full h-10" aria-hidden="true">
    <g
      class="da-arrow"
      fill="none"
      stroke="#c4b5fd"
      stroke-width="1.5"
      stroke-dasharray="4 3">
      <path d="M150 0 C 150 20, 60 18, 52 40"></path>
      <path d="M150 0 L 150 40"></path>
      <path d="M150 0 C 150 20, 240 18, 248 40"></path>
    </g>
  </svg>

  <div class="grid grid-cols-3 gap-2 sm:gap-3">
    {
      zones.map((zone, zi) => (
        <div class="bg-white rounded-lg border border-gray-100 shadow-md px-2.5 py-2">
          <p class="text-[11px] font-semibold text-gray-700">{zone.name}</p>
          <p class="text-[10px] text-gray-500 tabular-nums">{zone.flow} m³/h</p>
          <div class="flex items-end gap-0.5 h-8 mt-1.5">
            {zone.bars.map((height, bi) => (
              <span
                class="da-bar flex-1 rounded-sm bg-violet-400"
                style={`height: ${height}%; animation-delay: ${zi * 0.2 + bi * 0.1}s`}
              />
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <p
    class="flex items-center justify-center gap-1.5 mt-4 text-[11px] text-gray-500">
    <CheckCircle2 size={12} className="text-green-500" />
    Balance check: 99.2% allocated · 0.8% unaccounted
  </p>
</div>

<style>
  .da-arrow path {
    animation: da-march 1.4s linear infinite;
  }
  @keyframes da-march {
    to {
      stroke-dashoffset: -7;
    }
  }
  .da-bar {
    transform-origin: bottom;
    animation: da-rise 6s infinite both;
  }
  @keyframes da-rise {
    0% {
      transform: scaleY(0.15);
    }
    12% {
      transform: scaleY(1);
    }
    94% {
      transform: scaleY(1);
    }
    100% {
      transform: scaleY(0.15);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .da-arrow path,
    .da-bar {
      animation: none;
    }
  }
</style>
