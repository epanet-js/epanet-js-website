---
// Alternate illustrative water network, traced from a hand-made reference
// (diagram-network.svg): navy pipes and junctions over BasemapAlt's streets.
// Supports the same variant/markers props as NetworkMap.astro, so it's a
// drop-in swap wherever AppWindow's altNetwork prop is used.
import BasemapAlt from "./BasemapAlt.astro";
import {
  pipes,
  junctions,
  markerPoints,
  reservoirPoint,
  type Zone,
} from "./network-geometry-alt";
import {
  PIPE_COLOR,
  PIPE_STROKE_WIDTH,
  JUNCTION_COLOR,
  JUNCTION_RADIUS,
  OUTLINE_COLOR,
  OUTLINE_STROKE_WIDTH,
  RESERVOIR_COLOR,
  RESERVOIR_APEX_OFFSET,
  RESERVOIR_BASE_OFFSET,
  RESERVOIR_HALF_WIDTH,
  pressureColor,
  MARKER_RADIUS,
} from "./network-style-alt";

interface Props {
  variant?: "plain" | "pressure" | "passfail";
  markers?: boolean;
  class?: string;
}

const { variant = "plain", markers = false, class: className } = Astro.props;

const pipeColor = (zone: Zone) =>
  variant === "pressure" ? pressureColor[zone] : PIPE_COLOR;

const junctionColor = (passes: boolean) =>
  variant === "passfail" ? (passes ? "#22c55e" : "#ef4444") : JUNCTION_COLOR;
---

<div class:list={["w-full h-full", className]} aria-hidden="true">
  <svg
    viewBox="0 0 640 400"
    class="absolute inset-0 w-full h-full"
    preserveAspectRatio="xMidYMid slice">
    <BasemapAlt />
  </svg>

  <svg
    viewBox="0 0 640 400"
    class="absolute inset-0 w-full h-full"
    preserveAspectRatio="xMidYMid slice">
    <!-- pipes -->
    <g stroke-width={PIPE_STROKE_WIDTH} stroke-linecap="round">
      {
        pipes.map(([x1, y1, x2, y2, zone]) => (
          <line x1={x1} y1={y1} x2={x2} y2={y2} stroke={pipeColor(zone)} />
        ))
      }
    </g>

    <!-- junctions -->
    <g stroke={OUTLINE_COLOR} stroke-width={OUTLINE_STROKE_WIDTH}>
      {
        junctions.map(([x, y, passes]) => (
          <circle
            cx={x}
            cy={y}
            r={JUNCTION_RADIUS}
            fill={junctionColor(passes)}
            class={variant === "passfail" && !passes ? "nma-pulse" : undefined}
          />
        ))
      }
    </g>

    <!-- reservoir -->
    <path
      d={`M${reservoirPoint[0]} ${reservoirPoint[1] - RESERVOIR_APEX_OFFSET} L${reservoirPoint[0] + RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} L${reservoirPoint[0] - RESERVOIR_HALF_WIDTH} ${reservoirPoint[1] + RESERVOIR_BASE_OFFSET} Z`}
      fill={RESERVOIR_COLOR}
      stroke={OUTLINE_COLOR}
      stroke-width={OUTLINE_STROKE_WIDTH}></path>

    <!-- monitoring point markers -->
    {
      markers && (
        <g fill="none" stroke="#8b5cf6" stroke-width={PIPE_STROKE_WIDTH}>
          {markerPoints.map(([x, y], i) => (
            <circle
              cx={x}
              cy={y}
              r={MARKER_RADIUS}
              class="nma-pulse"
              style={`animation-delay: ${i * 0.4}s`}
            />
          ))}
        </g>
      )
    }
  </svg>
</div>

<style>
  .nma-pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: nma-pulse 1.8s ease-in-out infinite;
  }
  @keyframes nma-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.5);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nma-pulse {
      animation: none;
    }
  }
</style>
