---
// Connectivity trace demo: a selected junction traces upstream to the tank,
// then a boundary trace spreads outward and stops at a closed valve. Overlay
// strokes reuse the shared network geometry so they sit exactly on the base pipes.
import AppWindow from "./AppWindow.astro";
import { pipes, junctions } from "./network-geometry";

type Segment = [number, number, number, number];

// Pull a pipe from the shared geometry, optionally swapping its endpoints so
// the dashoffset draw starts from the trace's travelling end.
const seg = (index: number, swap = false): Segment => {
  const [x1, y1, x2, y2] = pipes[index];
  return swap ? [x2, y2, x1, y1] : [x1, y1, x2, y2];
};

// Upstream path: selected junction (170,200) back to the tank at (40,50).
const upstream: Segment[] = [
  seg(8, true), // (170,200) -> (160,140)
  seg(5), // (160,140) -> (150,60)
  seg(1, true), // (150,60) -> (90,70)
  seg(0, true), // (90,70) -> (40,50)
];

// The boundary wave stops at a closed valve halfway along the
// (210,75)-(270,65) pipe, so the last stroke only covers half of it.
const [vx1, vy1, vx2, vy2] = pipes[9];
const valveApproach: Segment = [vx1, vy1, (vx1 + vx2) / 2, (vy1 + vy2) / 2];

// Boundary trace: hops outward from the junction, one hop per draw wave.
const boundary: { line: Segment; hop: number }[] = [
  { line: seg(8, true), hop: 1 }, // (170,200) -> (160,140)
  { line: seg(10, true), hop: 1 }, // (170,200) -> (110,195)
  { line: seg(11), hop: 1 }, // (170,200) -> (240,210)
  { line: seg(5), hop: 2 }, // (160,140) -> (150,60)
  { line: seg(13, true), hop: 2 }, // (160,140) -> (230,150)
  { line: seg(3), hop: 3 }, // (150,60) -> (210,75)
  { line: valveApproach, hop: 4 }, // (210,75) -> closed valve at (240,70)
];
---

<AppWindow
  variant="plain"
  hideHeader
  hideFooter
  label="Tracing in epanet-js: an upstream trace from a junction back to the source, then a boundary trace stopping at a closed valve.">
  <!-- trace overlay: same viewBox as NetworkMap so strokes line up exactly -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <!-- upstream trace -->
    <g stroke="#eab308" stroke-width="2.5" stroke-linecap="round" fill="none">
      {
        upstream.map(([x1, y1, x2, y2], i) => (
          <line
            class={`tr-up tr-up-${i + 1}`}
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
            pathLength="100"
          />
        ))
      }
    </g>

    <!-- boundary trace -->
    <g stroke="#eab308" stroke-width="2.5" stroke-linecap="round" fill="none">
      {
        boundary.map(({ line: [x1, y1, x2, y2], hop }) => (
          <line
            class={`tr-b tr-b-${hop}`}
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
            pathLength="100"
          />
        ))
      }
    </g>

    <!-- redraw the junction dots on top of the upstream/boundary trace
         lines, since this overlay is a separate sibling painted after
         NetworkMap's own junctions and would otherwise cover them -->
    <g stroke="#ffffff" stroke-width="1">
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r="3.5" fill="#312e81" />
        ))
      }
    </g>

    <!-- closed valve at (240,70): gray until the trace reaches it, then red -->
    <g
      class="tr-valve-gray"
      fill="#6b7280"
      stroke="#ffffff"
      stroke-width="0.75"
      stroke-linejoin="round">
      <path d="M234 66 L240 70 L234 74 Z"></path>
      <path d="M246 66 L240 70 L246 74 Z"></path>
    </g>
    <g
      class="tr-valve-red"
      fill="#ef4444"
      stroke="#ffffff"
      stroke-width="0.75"
      stroke-linejoin="round">
      <path d="M234 66 L240 70 L234 74 Z"></path>
      <path d="M246 66 L240 70 L246 74 Z"></path>
    </g>

    <!-- selected junction -->
    <circle
      class="tr-ring"
      cx="170"
      cy="200"
      r="7"
      fill="none"
      stroke="#eab308"
      stroke-width="2"></circle>

    <!-- tank marker: the upstream trace's last segment ends right at it,
         so it needs to be drawn last to stay on top of every line -->
    <path
      d="M40 42 L48 56 L32 56 Z"
      fill="#312e81"
      stroke="#ffffff"
      stroke-width="1"></path>
  </svg>

  <!-- trace panel (top-right, like the asset panel) -->
  <div
    class="absolute bottom-2 right-2 w-[168px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Trace</p>
      <p class="text-xs text-gray-400">Connectivity</p>
    </div>
    <div class="px-3 py-2 space-y-2.5 text-xs">
      <div class="flex items-center justify-between">
        <span class="text-gray-500">Mode</span>
        <span class="relative font-medium text-gray-700">
          <span class="tr-swap-a">Upstream</span>
          <span class="tr-swap-b absolute inset-y-0 right-0 whitespace-nowrap">
            Boundary
          </span>
        </span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-gray-500">Start node</span>
        <span class="font-medium text-gray-700 tabular-nums">J34</span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-gray-500">Selected</span>
        <span class="relative text-gray-700 tabular-nums">
          <span class="tr-swap-a">4 pipes</span>
          <span class="tr-swap-b absolute inset-y-0 right-0 whitespace-nowrap">
            7 pipes
          </span>
        </span>
      </div>
    </div>
  </div>
</AppWindow>

<style>
  /* selected junction: gentle pulse for the whole cycle */
  .tr-ring {
    transform-box: fill-box;
    transform-origin: center;
    animation: tr-ring-pulse 2s ease-in-out infinite;
  }
  @keyframes tr-ring-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.7;
    }
  }

  /* upstream trace: segments draw junction -> tank, then dim to a faint
     highlight while the boundary trace runs, then fade for the reset.
     10s cycle: the original 8s sequence rescaled by 8/10 so every event
     keeps its absolute-second pacing, with the shared reset window
     (92%/100% of the old 8s) pushed back an extra 2s (to 93.6%/100% of
     the new 10s) so the latest state holds 2s longer before resetting. */
  .tr-up {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .tr-up-1 {
    animation:
      tr-up-d1 10s linear infinite both,
      tr-up-fade 10s ease-in-out infinite both;
  }
  .tr-up-2 {
    animation:
      tr-up-d2 10s linear infinite both,
      tr-up-fade 10s ease-in-out infinite both;
  }
  .tr-up-3 {
    animation:
      tr-up-d3 10s linear infinite both,
      tr-up-fade 10s ease-in-out infinite both;
  }
  .tr-up-4 {
    animation:
      tr-up-d4 10s linear infinite both,
      tr-up-fade 10s ease-in-out infinite both;
  }
  @keyframes tr-up-d1 {
    0%,
    4% {
      stroke-dashoffset: 100;
    }
    11.2%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-up-d2 {
    0%,
    11.2% {
      stroke-dashoffset: 100;
    }
    18.4%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-up-d3 {
    0%,
    18.4% {
      stroke-dashoffset: 100;
    }
    25.6%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-up-d4 {
    0%,
    25.6% {
      stroke-dashoffset: 100;
    }
    32%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-up-fade {
    0%,
    33.6% {
      opacity: 1;
    }
    40%,
    93.6% {
      opacity: 0.25;
    }
    100% {
      opacity: 0;
    }
  }

  /* boundary trace: hops spread outward from the junction */
  .tr-b {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .tr-b-1 {
    animation:
      tr-b-d1 10s linear infinite both,
      tr-out 10s ease-in-out infinite both;
  }
  .tr-b-2 {
    animation:
      tr-b-d2 10s linear infinite both,
      tr-out 10s ease-in-out infinite both;
  }
  .tr-b-3 {
    animation:
      tr-b-d3 10s linear infinite both,
      tr-out 10s ease-in-out infinite both;
  }
  .tr-b-4 {
    animation:
      tr-b-d4 10s linear infinite both,
      tr-out 10s ease-in-out infinite both;
  }
  @keyframes tr-b-d1 {
    0%,
    40% {
      stroke-dashoffset: 100;
    }
    45.6%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-b-d2 {
    0%,
    45.6% {
      stroke-dashoffset: 100;
    }
    51.2%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-b-d3 {
    0%,
    51.2% {
      stroke-dashoffset: 100;
    }
    56.8%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-b-d4 {
    0%,
    56.8% {
      stroke-dashoffset: 100;
    }
    62.4%,
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes tr-out {
    0%,
    93.6% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* closed valve: gray crossfades to red as the wave arrives, then pulses */
  .tr-valve-gray {
    animation: tr-valve-off 10s ease-in-out infinite both;
  }
  .tr-valve-red {
    transform-box: fill-box;
    transform-origin: center;
    animation:
      tr-valve-on 10s ease-in-out infinite both,
      tr-valve-pulse 10s ease-in-out infinite both;
  }
  @keyframes tr-valve-off {
    0%,
    60% {
      opacity: 1;
    }
    64%,
    93.6% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  @keyframes tr-valve-on {
    0%,
    60% {
      opacity: 0;
    }
    64%,
    93.6% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  @keyframes tr-valve-pulse {
    0%,
    63.2% {
      transform: scale(1);
    }
    65.6% {
      transform: scale(1.35);
    }
    68% {
      transform: scale(1);
    }
    70.4% {
      transform: scale(1.3);
    }
    72.8%,
    100% {
      transform: scale(1);
    }
  }

  /* panel values: Upstream/4 pipes swap to Boundary/7 pipes */
  .tr-swap-a {
    animation: tr-swap-out 10s ease-in-out infinite both;
  }
  .tr-swap-b {
    animation: tr-swap-in 10s ease-in-out infinite both;
  }
  @keyframes tr-swap-out {
    0%,
    35.2% {
      opacity: 1;
    }
    40%,
    94.4% {
      opacity: 0;
    }
    99.2%,
    100% {
      opacity: 1;
    }
  }
  @keyframes tr-swap-in {
    0%,
    35.2% {
      opacity: 0;
    }
    40%,
    94.4% {
      opacity: 1;
    }
    99.2%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tr-ring,
    .tr-up,
    .tr-up-1,
    .tr-up-2,
    .tr-up-3,
    .tr-up-4,
    .tr-b,
    .tr-b-1,
    .tr-b-2,
    .tr-b-3,
    .tr-b-4,
    .tr-valve-gray,
    .tr-valve-red,
    .tr-swap-a,
    .tr-swap-b {
      animation: none;
    }
    .tr-ring {
      transform: scale(1);
      opacity: 1;
    }
    .tr-up {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
    .tr-b {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .tr-valve-gray {
      opacity: 0;
    }
    .tr-valve-red {
      opacity: 1;
      transform: scale(1);
    }
    .tr-swap-a {
      opacity: 0;
    }
    .tr-swap-b {
      opacity: 1;
    }
  }
</style>
