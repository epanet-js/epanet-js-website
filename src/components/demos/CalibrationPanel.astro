---
// The calibration assistant panel: a suggested parameter change with
// accept/adjust/reject controls and an observed-vs-simulated graph that
// converges as the change is applied.
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["rounded-lg shadow-md", className]}>
  <div class="bg-white rounded-lg border border-gray-100 overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-base font-semibold text-gray-700">Calibration assistant</p>
      <p class="text-sm text-gray-400">Suggestion 2 of 7</p>
    </div>
    <div class="px-3 py-2.5 space-y-2">
      <p class="text-sm text-gray-500">Zone B · 14 pipes</p>
      <div class="flex items-center justify-between text-sm">
        <span class="text-gray-600">Roughness</span>
        <span class="tabular-nums">
          <span class="line-through text-gray-400">110</span>
          <span aria-hidden="true" class="text-gray-400 mx-1">→</span>
          <span class="font-semibold text-violet-600">95</span>
        </span>
      </div>
      <div>
        <svg viewBox="0 0 200 68" class="w-full" aria-hidden="true">
          <g stroke="#f3f4f6" stroke-width="1">
            <line x1="0" y1="17" x2="200" y2="17"></line>
            <line x1="0" y1="34" x2="200" y2="34"></line>
            <line x1="0" y1="51" x2="200" y2="51"></line>
          </g>
          <polyline
            points="0,58 25,46 50,61 75,40 100,55 125,37 150,52 175,40 200,49"
            fill="none"
            stroke="#9ca3af"
            stroke-width="1.5"></polyline>
          <polyline
            class="cal-sim cal-sim-before"
            points="0,34 25,21 50,37 75,15 100,31 125,12 150,28 175,15 200,25"
            fill="none"
            stroke="#8b5cf6"
            stroke-width="1.5"></polyline>
          <polyline
            class="cal-sim cal-sim-after"
            points="0,55 25,43 50,58 75,37 100,52 125,34 150,49 175,37 200,46"
            fill="none"
            stroke="#8b5cf6"
            stroke-width="1.5"></polyline>
        </svg>
        <div class="flex gap-3 text-xs text-gray-400 mt-2">
          <span class="flex items-center gap-1">
            <span class="w-2.5 h-0.5 bg-gray-400"></span> Observed
          </span>
          <span class="flex items-center gap-1">
            <span class="w-2.5 h-0.5 bg-violet-500"></span> Simulated
          </span>
        </div>
      </div>
    </div>
    <div class="flex gap-1.5 px-3 pb-2.5">
      <span
        class="rounded border border-violet-600 bg-violet-600 text-white text-sm font-medium px-2.5 py-1">
        Accept
      </span>
      <span
        class="rounded border border-gray-200 text-gray-600 text-sm px-2.5 py-1">
        Adjust
      </span>
      <span
        class="rounded border border-gray-200 text-gray-600 text-sm px-2.5 py-1">
        Reject
      </span>
    </div>
  </div>
</div>

<style>
  .cal-sim-before {
    animation: cal-fade-out 5s ease-in-out infinite;
  }
  .cal-sim-after {
    animation: cal-fade-in 5s ease-in-out infinite;
  }
  @keyframes cal-fade-out {
    0%,
    20% {
      opacity: 1;
    }
    45%,
    75% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  @keyframes cal-fade-in {
    0%,
    20% {
      opacity: 0;
    }
    45%,
    75% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cal-sim {
      animation: none;
    }
    .cal-sim-before {
      opacity: 0;
    }
    .cal-sim-after {
      opacity: 1;
    }
  }
</style>
