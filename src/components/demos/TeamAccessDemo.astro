---
// Team access demo: a workspace member list with per-person roles, an
// invite going out, and a role change applying.
import { UserPlus } from "lucide-react";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const members = [
  { initials: "EB", name: "Elena B.", role: "Editor" },
  { initials: "MK", name: "Marcus K.", role: "Editor", changes: true },
  { initials: "PN", name: "Priya N.", role: "Viewer" },
  { initials: "JR", name: "Jordan R.", role: "Viewer" },
];

const roleChip = (role: string) =>
  role === "Editor"
    ? "border-violet-100 bg-violet-50 text-violet-700"
    : "border-gray-200 bg-gray-100 text-gray-500";
---

<div
  class:list={[
    "relative h-[280px] rounded-lg shadow-md select-none",
    className,
  ]}
  role="img"
  aria-label="Team access panel: a member list with per-person roles, an invite going out, and one member's role changing from editor to viewer.">
  <div class="absolute inset-0 overflow-hidden rounded-lg border border-gray-100 bg-white">
  <div class="absolute inset-0 flex flex-col justify-between">
  <div
    class="flex items-baseline justify-between px-4 pt-4 pb-3 border-b border-gray-100">
    <p class="text-[11px] font-semibold text-gray-700">Team access</p>
    <p class="text-[10px] text-gray-400">Acme Water</p>
  </div>
  <div class="py-1 text-[10px]">
    {
      members.map((member, i) => (
        <div
          class="tac-row flex items-center gap-3 px-4 py-2.5"
          style={`animation-delay: ${(i * 0.45).toFixed(2)}s`}>
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-violet-100 text-[8px] font-semibold text-violet-700">
            {member.initials}
          </span>
          <span class="font-medium text-gray-700">{member.name}</span>
          {member.changes ? (
            <span class="relative ml-auto">
              <span
                class:list={[
                  "tac-role-old block rounded-full border px-1.5 py-px text-[9px] font-medium",
                  roleChip("Editor"),
                ]}>
                Editor
              </span>
              <span
                class:list={[
                  "tac-role-new absolute inset-0 flex items-center justify-center rounded-full border px-1.5 py-px text-[9px] font-medium",
                  roleChip("Viewer"),
                ]}>
                Viewer
              </span>
            </span>
          ) : (
            <span
              class:list={[
                "ml-auto rounded-full border px-1.5 py-px text-[9px] font-medium",
                roleChip(member.role),
              ]}>
              {member.role}
            </span>
          )}
        </div>
      ))
    }
    <div
      class="tac-invite flex items-center gap-3 border-t border-gray-50 px-4 py-2.5">
      <span
        class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-dashed border-gray-300 text-gray-400">
        <UserPlus size={10} />
      </span>
      <span class="text-gray-500">sara@acme.com</span>
      <span
        class="ml-auto rounded-full bg-violet-500 px-1.5 py-px text-[9px] font-medium text-white">
        Invite sent
      </span>
    </div>
  </div>
  <p
    class="tac-footer px-4 py-2.5 border-t border-gray-100 text-[9px] text-gray-400">
    5 seats · roles per member
  </p>
  </div>
  </div>
</div>

<style>
  .tac-row {
    animation: tac-row-in 7s ease-out infinite both;
  }
  @keyframes tac-row-in {
    0%,
    8% {
      opacity: 0;
      transform: translateY(4px);
    }
    13% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  .tac-invite {
    animation: tac-invite-in 7s ease-out infinite both;
  }
  @keyframes tac-invite-in {
    0%,
    48% {
      opacity: 0;
      transform: translateY(4px);
    }
    54% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  /* one member's role changes from editor to viewer */
  .tac-role-old {
    animation: tac-role-old 7s linear infinite both;
  }
  @keyframes tac-role-old {
    0%,
    64% {
      opacity: 1;
    }
    67%,
    100% {
      opacity: 0;
    }
  }
  .tac-role-new {
    animation: tac-role-new 7s linear infinite both;
  }
  @keyframes tac-role-new {
    0%,
    64% {
      opacity: 0;
    }
    67% {
      opacity: 1;
      box-shadow: 0 0 0 1.5px #c4b5fd;
    }
    76% {
      box-shadow: none;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .tac-footer {
    animation: tac-footer-in 7s ease-out infinite both;
  }
  @keyframes tac-footer-in {
    0%,
    78% {
      opacity: 0;
    }
    84% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tac-row,
    .tac-invite,
    .tac-role-old,
    .tac-role-new,
    .tac-footer {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .tac-role-old {
      opacity: 0;
    }
  }
</style>
