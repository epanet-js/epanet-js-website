---
// Data regions diagram: three regions side by side, each running the
// epanet-js app next to its own model storage inside a dashed boundary.
// A model file leaves each region and lands with that region's users;
// nothing crosses from one region to another.
import {
  AppWindow,
  CheckCircle2,
  Database,
  FileText,
  Users,
} from "lucide-react";
import NetworkMap from "./NetworkMap.astro";

const regions = [
  { name: "Europe", code: "eu-west", users: "European users" },
  { name: "United States", code: "us-east", users: "American users" },
  { name: "Asia Pacific", code: "ap-southeast", users: "Asia Pacific users" },
];
---

<div
  class="relative aspect-video w-full overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: three data regions, Europe, the United States, and Asia Pacific, each running the epanet-js app beside its own model storage and delivering models to that region's users without leaving the region.">
  <div class="absolute inset-0 flex scale-90 items-center justify-center sm:scale-100">
  <div class="mx-auto w-full max-w-[420px]">
    <div class="grid grid-cols-3 gap-4 sm:gap-5">
      {
        regions.map((region, i) => (
          <div class={`drg-lane-${i + 1}`}>
            <!-- region bucket -->
            <div class="relative rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 px-2 pb-2.5 pt-4">
              <span class="absolute -top-2 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-gray-200 bg-white px-1.5 py-px text-[8px] font-medium text-gray-500 shadow-sm">
                {region.name}
              </span>
              <div class="flex items-start justify-center gap-1.5 sm:gap-2">
                <div class="flex flex-col items-center gap-1">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                    <AppWindow size={15} />
                  </span>
                  <p class="text-[7px] font-medium text-gray-500 whitespace-nowrap">
                    epanet-js
                  </p>
                </div>
                <div class="flex flex-col items-center gap-1">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                    <Database size={15} />
                  </span>
                  <p class="text-[7px] font-medium text-gray-500 whitespace-nowrap">
                    Models
                  </p>
                </div>
              </div>
              <p class="mt-1.5 text-center text-[8px] font-medium text-gray-400">
                {region.code}
              </p>
            </div>

            <!-- delivery path, region storage down to the local machine -->
            <div class="relative mx-auto h-9 w-12">
              <svg
                viewBox="0 0 16 36"
                class="mx-auto h-full w-4"
                aria-hidden="true">
                <path
                  d="M8 2 V27"
                  fill="none"
                  stroke="#d1d5db"
                  stroke-width="1.5"
                  stroke-dasharray="4 3"
                />
                <path d="M4.5 26 L8 33 L11.5 26 Z" fill="#d1d5db" />
              </svg>
              <span
                class={`drg-file drg-file-${i + 1} absolute left-1/2 top-0 flex -translate-x-1/2 items-center gap-0.5 rounded border border-gray-200 bg-white px-1 py-px text-[8px] font-medium text-gray-600 shadow-sm`}>
                <FileText size={8} className="text-violet-500" />
                .inp
              </span>
            </div>

            <!-- local machine -->
            <div>
              <div class="overflow-hidden rounded-lg border-2 border-gray-300">
                <div class="relative aspect-[16/10] bg-gray-100">
                  <div class={`drg-screen-${i + 1} absolute inset-0`}>
                    <NetworkMap class="absolute inset-0" />
                  </div>
                  <span
                    class={`drg-tick-${i + 1} absolute top-1 right-1 flex h-3.5 w-3.5 items-center justify-center rounded-full bg-white text-green-500 shadow-sm`}>
                    <CheckCircle2 size={10} />
                  </span>
                </div>
              </div>
              <div class="mx-4 h-1 rounded-b-lg bg-gray-300" />
              <p class="mt-1.5 flex items-center justify-center gap-1 text-[9px] font-medium text-gray-600 whitespace-nowrap">
                <Users size={10} className="text-gray-400" />
                {region.users}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <p class="drg-footer mt-4 text-center text-[10px] text-gray-400">
      Models are stored and served in the region you choose.
    </p>
  </div>
  </div>
</div>

<style>
  /* 12s loop: the action plays in the first 8s, then the finished
     state holds for 4s before fading out. */
  /* lanes fade in left to right, and out together at the loop end */
  .drg-lane-1 {
    animation: drg-lane-1 12s ease-out infinite both;
  }
  .drg-lane-2 {
    animation: drg-lane-2 12s ease-out infinite both;
  }
  .drg-lane-3 {
    animation: drg-lane-3 12s ease-out infinite both;
  }
  @keyframes drg-lane-1 {
    0%, 1% { opacity: 0; }
    5% { opacity: 1; }
    97% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes drg-lane-2 {
    0%, 3% { opacity: 0; }
    7% { opacity: 1; }
    97% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes drg-lane-3 {
    0%, 4% { opacity: 0; }
    8% { opacity: 1; }
    97% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* the .inp chip drops from each region's storage to its machine */
  .drg-file {
    opacity: 0;
  }
  .drg-file-1 {
    animation: drg-file-1 12s ease-in-out infinite both;
  }
  .drg-file-2 {
    animation: drg-file-2 12s ease-in-out infinite both;
  }
  .drg-file-3 {
    animation: drg-file-3 12s ease-in-out infinite both;
  }
  @keyframes drg-file-1 {
    0%, 12% { opacity: 0; transform: translate(-50%, -4px); }
    15% { opacity: 1; }
    21% { opacity: 1; transform: translate(-50%, 24px); }
    24%, 100% { opacity: 0; transform: translate(-50%, 28px); }
  }
  @keyframes drg-file-2 {
    0%, 20% { opacity: 0; transform: translate(-50%, -4px); }
    23% { opacity: 1; }
    29% { opacity: 1; transform: translate(-50%, 24px); }
    32%, 100% { opacity: 0; transform: translate(-50%, 28px); }
  }
  @keyframes drg-file-3 {
    0%, 28% { opacity: 0; transform: translate(-50%, -4px); }
    31% { opacity: 1; }
    37% { opacity: 1; transform: translate(-50%, 24px); }
    40%, 100% { opacity: 0; transform: translate(-50%, 28px); }
  }

  /* each screen lights up as its file lands */
  .drg-screen-1 {
    animation: drg-screen-1 12s ease-out infinite both;
  }
  .drg-screen-2 {
    animation: drg-screen-2 12s ease-out infinite both;
  }
  .drg-screen-3 {
    animation: drg-screen-3 12s ease-out infinite both;
  }
  @keyframes drg-screen-1 {
    0%, 20% { opacity: 0; }
    23%, 100% { opacity: 1; }
  }
  @keyframes drg-screen-2 {
    0%, 28% { opacity: 0; }
    31%, 100% { opacity: 1; }
  }
  @keyframes drg-screen-3 {
    0%, 36% { opacity: 0; }
    39%, 100% { opacity: 1; }
  }

  .drg-tick-1 {
    animation: drg-tick-1 12s ease-out infinite both;
  }
  .drg-tick-2 {
    animation: drg-tick-2 12s ease-out infinite both;
  }
  .drg-tick-3 {
    animation: drg-tick-3 12s ease-out infinite both;
  }
  @keyframes drg-tick-1 {
    0%, 22% { opacity: 0; transform: scale(0.5); }
    25% { opacity: 1; transform: scale(1.2); }
    27%, 100% { opacity: 1; transform: scale(1); }
  }
  @keyframes drg-tick-2 {
    0%, 30% { opacity: 0; transform: scale(0.5); }
    33% { opacity: 1; transform: scale(1.2); }
    35%, 100% { opacity: 1; transform: scale(1); }
  }
  @keyframes drg-tick-3 {
    0%, 38% { opacity: 0; transform: scale(0.5); }
    41% { opacity: 1; transform: scale(1.2); }
    43%, 100% { opacity: 1; transform: scale(1); }
  }

  .drg-footer {
    animation: drg-footer 12s ease-out infinite both;
  }
  @keyframes drg-footer {
    0%, 44% { opacity: 0; transform: translateY(2px); }
    48% { opacity: 1; transform: translateY(0); }
    97% { opacity: 1; }
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .drg-lane-1,
    .drg-lane-2,
    .drg-lane-3,
    .drg-file-1,
    .drg-file-2,
    .drg-file-3,
    .drg-screen-1,
    .drg-screen-2,
    .drg-screen-3,
    .drg-tick-1,
    .drg-tick-2,
    .drg-tick-3,
    .drg-footer {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .drg-file {
      opacity: 0;
    }
    .drg-tick-1,
    .drg-tick-2,
    .drg-tick-3 {
      transform: scale(1);
    }
  }
</style>
