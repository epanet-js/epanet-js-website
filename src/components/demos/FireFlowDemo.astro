---
// Fire flow analysis demo: pass/fail map with a floating results panel,
// rows populating as the analysis "runs". Labels mirror the real tool.
import AppWindow from "./AppWindow.astro";

interface Props {
  /** Render the map as NetworkMapAlt instead of NetworkMap. */
  alt?: boolean;
}

const { alt = false } = Astro.props;

const results = [
  { junction: "J107", flow: "47.2", passes: true },
  { junction: "J67", flow: "30.9", passes: false },
  { junction: "J288", flow: "27.3", passes: true },
];
---

<AppWindow
  variant="passfail"
  hideHeader
  hideFooter
  altNetwork={alt}
  label="Fire flow analysis in epanet-js: results panel showing available flow per junction with pass and fail status over a network map.">
  <div
    class="absolute top-2 left-2 w-[216px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div class="px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Fire flow analysis</p>
      <div class="flex items-center justify-between mt-1.5">
        <span class="text-xs text-gray-500">Minimum pressure (m)</span>
        <span
          class="text-xs text-gray-700 border border-gray-200 rounded px-1.5 py-0.5 bg-white">
          15
        </span>
      </div>
      <div class="ff-progress mt-2 h-0.5 rounded-full bg-gray-100 overflow-hidden">
        <div class="ff-progress-bar h-full bg-violet-500"></div>
      </div>
    </div>
    <table class="w-full text-xs">
      <thead>
        <tr class="text-left text-gray-400">
          <th class="font-medium pl-2 py-2">Junction</th>
          <th class="font-medium py-2 text-right whitespace-nowrap">Available (l/s)</th>
          <th class="font-medium pr-2 py-2 text-right">Status</th>
        </tr>
      </thead>
      <tbody>
        {
          results.map((row, i) => (
            <tr class={`ff-row-${i + 1} border-t border-gray-100 text-gray-600`}>
              <td class="pl-2 py-2 font-medium text-gray-700">{row.junction}</td>
              <td class="py-2 text-right tabular-nums">{row.flow}</td>
              <td class="pr-2 py-2 text-right">
                <span
                  class:list={[
                    "inline-block rounded-full px-2 py-0.5 font-medium",
                    row.passes
                      ? "bg-green-100 text-green-700"
                      : "bg-red-100 text-red-600",
                  ]}>
                  {row.passes ? "Pass" : "Fail"}
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</AppWindow>

<style>
  /* each row's own keyframe bakes in its entrance delay directly (no more
     animation-delay), so all three share the exact same 90%/96% hold-and-
     fade-out point instead of each one's fade-out drifting later by its
     own delay -- the same window the progress bar now holds to, below. */
  .ff-row-1 {
    animation: ff-row-1 7s infinite both;
  }
  .ff-row-2 {
    animation: ff-row-2 7s infinite both;
  }
  .ff-row-3 {
    animation: ff-row-3 7s infinite both;
  }
  @keyframes ff-row-1 {
    0%, 4.286% { opacity: 0; transform: translateY(4px); }
    11.286% { opacity: 1; transform: translateY(0); }
    90% { opacity: 1; }
    96%, 100% { opacity: 0; }
  }
  @keyframes ff-row-2 {
    0%, 12.143% { opacity: 0; transform: translateY(4px); }
    19.143% { opacity: 1; transform: translateY(0); }
    90% { opacity: 1; }
    96%, 100% { opacity: 0; }
  }
  @keyframes ff-row-3 {
    0%, 20% { opacity: 0; transform: translateY(4px); }
    27% { opacity: 1; transform: translateY(0); }
    90% { opacity: 1; }
    96%, 100% { opacity: 0; }
  }
  /* the fade lives on the track (.ff-progress), not just the violet fill
     -- otherwise the empty gray track stays visible after the fill fades,
     making the whole widget look like it lingers past the rows. Both
     pieces share the same 90%/96% point as the rows above; the fill's own
     width animation is independent and just holds at 100% once drawn. */
  .ff-progress {
    animation: ff-progress-vis 7s infinite both;
  }
  @keyframes ff-progress-vis {
    0%,
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .ff-progress-bar {
    width: 0;
    animation: ff-progress-width 7s infinite both;
  }
  @keyframes ff-progress-width {
    0% {
      width: 0;
    }
    38%,
    100% {
      width: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ff-row-1,
    .ff-row-2,
    .ff-row-3,
    .ff-progress,
    .ff-progress-bar {
      animation: none;
    }
    .ff-row-1,
    .ff-row-2,
    .ff-row-3,
    .ff-progress {
      opacity: 1;
      transform: none;
    }
    .ff-progress-bar {
      width: 100%;
    }
  }
</style>
