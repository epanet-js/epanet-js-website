---
// Sustainable open source diagram: the self-reinforcing cycle. People use
// the open source app, some pay for advanced features, and developers
// reinvest in improving the app, which brings more people in.
import { Code2, CreditCard, Users } from "lucide-react";

// Triangle vertices in the 260x220 viewBox (top, bottom-right, bottom-left).
const edges = [
  { cls: "sos-edge-1", x1: 130, y1: 58, x2: 196, y2: 170 },
  { cls: "sos-edge-2", x1: 196, y1: 170, x2: 64, y2: 170 },
  { cls: "sos-edge-3", x1: 64, y1: 170, x2: 130, y2: 58 },
];
---

<div
  class="w-full rounded-xl border border-gray-200 shadow-lg bg-white p-5 sm:p-6 select-none"
  role="img"
  aria-label="Diagram of the sustainable open source cycle: people use the open source app, some users pay for advanced features, and developers reinvest in improving the app.">
  <div class="relative mx-auto aspect-[13/11] max-w-[340px]">
    <svg
      viewBox="0 0 260 220"
      class="absolute inset-0 h-full w-full"
      aria-hidden="true">
      <g stroke-width="5" stroke-linecap="round" fill="none">
        {
          edges.map((edge) => (
            <line
              class={edge.cls}
              x1={edge.x1}
              y1={edge.y1}
              x2={edge.x2}
              y2={edge.y2}
              stroke="#8b5cf6"
              pathLength="100"
            />
          ))
        }
      </g>
      <!-- circulating dashes once the loop closes -->
      <g
        stroke="#ffffff"
        stroke-width="1.5"
        stroke-linecap="round"
        fill="none">
        {
          edges.map((edge) => (
            <line
              class="sos-march"
              x1={edge.x1}
              y1={edge.y1}
              x2={edge.x2}
              y2={edge.y2}
              stroke-dasharray="3 9"
              pathLength="100"
            />
          ))
        }
      </g>
    </svg>

    <!-- cycle nodes -->
    <div
      class="sos-node-top absolute left-1/2 top-0 flex w-[130px] -translate-x-1/2 flex-col items-center gap-1 text-center">
      <span
        class="sos-icon flex h-8 w-8 items-center justify-center rounded-full bg-purple-50 text-purple-600">
        <Users size={15} />
      </span>
      <p class="text-[9px] leading-tight text-gray-600">
        People use the open source app
      </p>
    </div>
    <div
      class="sos-node-br absolute bottom-0 right-0 flex w-[110px] flex-col items-center gap-1 text-center">
      <span
        class="sos-icon flex h-8 w-8 items-center justify-center rounded-full bg-purple-50 text-purple-600">
        <CreditCard size={15} />
      </span>
      <p class="text-[9px] leading-tight text-gray-600">
        Some users pay for advanced features
      </p>
    </div>
    <div
      class="sos-node-bl absolute bottom-0 left-0 flex w-[110px] flex-col items-center gap-1 text-center">
      <span
        class="sos-icon flex h-8 w-8 items-center justify-center rounded-full bg-purple-50 text-purple-600">
        <Code2 size={15} />
      </span>
      <p class="text-[9px] leading-tight text-gray-600">
        Developers reinvest improving the app
      </p>
    </div>

    <p
      class="sos-center absolute left-1/2 top-[58%] w-[110px] -translate-x-1/2 -translate-y-1/2 text-center text-xs font-medium leading-snug text-gray-700">
      Sustainable open source
    </p>
  </div>
</div>

<style>
  /* edges draw clockwise, one leg of the cycle at a time */
  .sos-edge-1,
  .sos-edge-2,
  .sos-edge-3 {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .sos-edge-1 {
    animation: sos-edge-1 8s linear infinite both;
  }
  .sos-edge-2 {
    animation: sos-edge-2 8s linear infinite both;
  }
  .sos-edge-3 {
    animation: sos-edge-3 8s linear infinite both;
  }
  @keyframes sos-edge-1 {
    0%, 8% { stroke-dashoffset: 100; opacity: 1; }
    20% { stroke-dashoffset: 0; }
    94% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes sos-edge-2 {
    0%, 24% { stroke-dashoffset: 100; opacity: 1; }
    36% { stroke-dashoffset: 0; }
    94% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes sos-edge-3 {
    0%, 40% { stroke-dashoffset: 100; opacity: 1; }
    52% { stroke-dashoffset: 0; }
    94% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }

  /* once the loop closes, dashes circulate to show it self-reinforcing */
  .sos-march {
    opacity: 0;
    animation:
      sos-march-vis 8s linear infinite both,
      sos-march-flow 1.3s linear infinite;
  }
  @keyframes sos-march-vis {
    0%,
    54% {
      opacity: 0;
    }
    58%,
    90% {
      opacity: 0.9;
    }
    94%,
    100% {
      opacity: 0;
    }
  }
  @keyframes sos-march-flow {
    0% {
      stroke-dashoffset: 12;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  /* nodes light up as the cycle reaches them; the top node starts it and
     ticks again when the loop closes */
  .sos-node-top {
    animation: sos-node-top 8s ease-out infinite both;
  }
  @keyframes sos-node-top {
    0%, 2% { opacity: 0; transform: translate(-50%, 3px); }
    8% { opacity: 1; transform: translate(-50%, 0); }
    52% { transform: translate(-50%, 0) scale(1); }
    55% { transform: translate(-50%, 0) scale(1.05); }
    58% { transform: translate(-50%, 0) scale(1); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }
  .sos-node-br {
    animation: sos-node-br 8s ease-out infinite both;
  }
  @keyframes sos-node-br {
    0%, 18% { opacity: 0; transform: translateY(3px); }
    24% { opacity: 1; transform: translateY(0); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }
  .sos-node-bl {
    animation: sos-node-bl 8s ease-out infinite both;
  }
  @keyframes sos-node-bl {
    0%, 34% { opacity: 0; transform: translateY(3px); }
    40% { opacity: 1; transform: translateY(0); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }

  .sos-center {
    animation: sos-center-in 8s ease-out infinite both;
  }
  @keyframes sos-center-in {
    0%,
    56% {
      opacity: 0;
    }
    62% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sos-edge-1,
    .sos-edge-2,
    .sos-edge-3,
    .sos-march,
    .sos-node-top,
    .sos-node-br,
    .sos-node-bl,
    .sos-center {
      animation: none;
      opacity: 1;
    }
    .sos-edge-1,
    .sos-edge-2,
    .sos-edge-3 {
      stroke-dashoffset: 0;
    }
    .sos-march {
      opacity: 0;
    }
    .sos-node-top {
      transform: translate(-50%, 0);
    }
    .sos-node-br,
    .sos-node-bl {
      transform: none;
    }
  }
</style>
