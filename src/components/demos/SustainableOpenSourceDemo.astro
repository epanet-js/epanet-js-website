---
// Sustainable open source diagram: the self-reinforcing cycle. People use
// the open source app, some pay for advanced features, and developers
// reinvest in improving the app, which brings more people in.
import { Code2, CreditCard, Users } from "lucide-react";

// Triangle vertices in the 320x240 box (top, bottom-right, bottom-left).
const edges = [
  { cls: "sos-edge-1", x1: 160, y1: 40, x2: 256, y2: 192 },
  { cls: "sos-edge-2", x1: 256, y1: 192, x2: 64, y2: 192 },
  { cls: "sos-edge-3", x1: 64, y1: 192, x2: 160, y2: 40 },
];
---

<div
  class="relative mx-auto aspect-[3/2] w-full max-w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: the sustainable open source cycle. People use the open source app, some users pay for advanced features, and developers reinvest in improving the app.">
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="box-border flex h-full w-full flex-col items-center justify-center px-8 pb-8 pt-8">
        <div class="relative h-60 w-80">
          <svg
            viewBox="0 0 320 240"
            class="absolute inset-0 h-full w-full"
            aria-hidden="true">
            <g stroke-width="5" stroke-linecap="round" fill="none">
              {
                edges.map((edge) => (
                  <line
                    class={edge.cls}
                    x1={edge.x1}
                    y1={edge.y1}
                    x2={edge.x2}
                    y2={edge.y2}
                    stroke="#8b5cf6"
                    pathLength="100"
                  />
                ))
              }
            </g>
            <!-- circulating dashes once the loop closes -->
            <g
              stroke="#ffffff"
              stroke-width="1.5"
              stroke-linecap="round"
              fill="none">
              {
                edges.map((edge) => (
                  <line
                    class="sos-march"
                    x1={edge.x1}
                    y1={edge.y1}
                    x2={edge.x2}
                    y2={edge.y2}
                    stroke-dasharray="3 9"
                    pathLength="100"
                  />
                ))
              }
            </g>
          </svg>

          <!-- cycle nodes: icon badges are positioned so they sit centered
               exactly on their triangle vertex -->
          <span
            class="sos-icon-top absolute left-40 top-4 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full bg-purple-50 text-purple-600">
            <Users size={23} />
          </span>
          <p
            class="sos-label-top absolute left-40 top-2 w-36 -translate-x-1/2 -translate-y-full text-center text-[10px] leading-tight text-gray-600">
            The open source app grows
          </p>
          <div
            class="sos-node-br absolute left-64 top-[168px] flex w-36 -translate-x-1/2 flex-col items-center gap-2 text-center">
            <span
              class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-50 text-purple-600">
              <CreditCard size={23} />
            </span>
            <p class="text-[10px] leading-tight text-gray-600">
              Advanced features are paid
            </p>
          </div>
          <div
            class="sos-node-bl absolute left-16 top-[168px] flex w-36 -translate-x-1/2 flex-col items-center gap-2 text-center">
            <span
              class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-50 text-purple-600">
              <Code2 size={23} />
            </span>
            <p class="text-[10px] leading-tight text-gray-600">
              That funds new development
            </p>
          </div>

          <p
            class="sos-center absolute left-1/2 top-[152px] w-36 -translate-x-1/2 -translate-y-1/2 text-center text-sm font-medium leading-snug text-gray-700">
            Sustainable open source
          </p>
        </div>
      </div>
    </foreignObject>
  </svg>
</div>

<style>
  /* edges draw clockwise, one leg of the cycle at a time */
  .sos-edge-1,
  .sos-edge-2,
  .sos-edge-3 {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .sos-edge-1 {
    animation: sos-edge-1 8s linear infinite both;
  }
  .sos-edge-2 {
    animation: sos-edge-2 8s linear infinite both;
  }
  .sos-edge-3 {
    animation: sos-edge-3 8s linear infinite both;
  }
  @keyframes sos-edge-1 {
    0%, 8% { stroke-dashoffset: 100; opacity: 1; }
    20% { stroke-dashoffset: 0; }
    94% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes sos-edge-2 {
    0%, 24% { stroke-dashoffset: 100; opacity: 1; }
    36% { stroke-dashoffset: 0; }
    94% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes sos-edge-3 {
    0%, 40% { stroke-dashoffset: 100; opacity: 1; }
    52% { stroke-dashoffset: 0; }
    94% { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }

  /* once the loop closes, dashes circulate to show it self-reinforcing */
  .sos-march {
    opacity: 0;
    animation:
      sos-march-vis 8s linear infinite both,
      sos-march-flow 1.3s linear infinite;
  }
  @keyframes sos-march-vis {
    0%,
    54% {
      opacity: 0;
    }
    58%,
    90% {
      opacity: 0.9;
    }
    94%,
    100% {
      opacity: 0;
    }
  }
  @keyframes sos-march-flow {
    0% {
      stroke-dashoffset: 12;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  /* nodes light up as the cycle reaches them; the top node starts it and
     ticks again when the loop closes */
  .sos-icon-top {
    animation: sos-icon-top 8s ease-out infinite both;
  }
  @keyframes sos-icon-top {
    0%, 2% { opacity: 0; transform: translate(-50%, 3px); }
    8% { opacity: 1; transform: translate(-50%, 0); }
    52% { transform: translate(-50%, 0) scale(1); }
    55% { transform: translate(-50%, 0) scale(1.05); }
    58% { transform: translate(-50%, 0) scale(1); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }
  .sos-label-top {
    animation: sos-label-top 8s ease-out infinite both;
  }
  @keyframes sos-label-top {
    0%, 2% { opacity: 0; transform: translate(-50%, calc(-100% + 3px)); }
    8% { opacity: 1; transform: translate(-50%, -100%); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }
  .sos-node-br {
    animation: sos-node-br 8s ease-out infinite both;
  }
  @keyframes sos-node-br {
    0%, 18% { opacity: 0; transform: translate(-50%, 3px); }
    24% { opacity: 1; transform: translate(-50%, 0); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }
  .sos-node-bl {
    animation: sos-node-bl 8s ease-out infinite both;
  }
  @keyframes sos-node-bl {
    0%, 34% { opacity: 0; transform: translate(-50%, 3px); }
    40% { opacity: 1; transform: translate(-50%, 0); }
    94% { opacity: 1; }
    100% { opacity: 0; }
  }

  .sos-center {
    animation: sos-center-in 8s ease-out infinite both;
  }
  @keyframes sos-center-in {
    0%,
    56% {
      opacity: 0;
    }
    62% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sos-edge-1,
    .sos-edge-2,
    .sos-edge-3,
    .sos-march,
    .sos-icon-top,
    .sos-label-top,
    .sos-node-br,
    .sos-node-bl,
    .sos-center {
      animation: none;
      opacity: 1;
    }
    .sos-edge-1,
    .sos-edge-2,
    .sos-edge-3 {
      stroke-dashoffset: 0;
    }
    .sos-march {
      opacity: 0;
    }
    .sos-icon-top {
      transform: translate(-50%, 0);
    }
    .sos-label-top {
      transform: translate(-50%, -100%);
    }
    .sos-node-br,
    .sos-node-bl {
      transform: translate(-50%, 0);
    }
  }
</style>
