---
// Flushing plan demo (concept): a unidirectional flushing sequence. Three
// runs of mains highlight in order, water marches along each one, and the
// sequence panel checks each run off as it hits its cleaning velocity.
import AppWindow from "./AppWindow.astro";
import { pipes } from "./network-geometry";

// Flushing runs as ordered pipe lists; `swap` orients the draw so the flow
// reads outward along the run.
type RunPipe = { index: number; swap?: boolean };

const runs: {
  name: string;
  velocity: string;
  badge: { left: string; top: string };
  drawCls: string;
  marchCls: string;
  pipes: RunPipe[];
}[] = [
  {
    name: "Run 1",
    velocity: "1.6 m/s",
    badge: { left: "37.5%", top: "20%" },
    drawCls: "flp-draw-1",
    marchCls: "flp-march-1",
    pipes: [{ index: 3 }, { index: 9 }],
  },
  {
    name: "Run 2",
    velocity: "1.4 m/s",
    badge: { left: "42.5%", top: "66.7%" },
    drawCls: "flp-draw-2",
    marchCls: "flp-march-2",
    pipes: [{ index: 11 }, { index: 12 }],
  },
  {
    name: "Run 3",
    velocity: "1.7 m/s",
    badge: { left: "75%", top: "73.3%" },
    drawCls: "flp-draw-3",
    marchCls: "flp-march-3",
    pipes: [{ index: 17 }, { index: 19 }],
  },
];

const segment = ({ index, swap }: RunPipe) => {
  const [x1, y1, x2, y2] = pipes[index];
  return swap ? { x1: x2, y1: y2, x2: x1, y2: y1 } : { x1, y1, x2, y2 };
};
---

<AppWindow
  variant="plain"
  label="Unidirectional flushing in epanet-js: three flushing runs highlighting in order, each checked off in the sequence panel as it hits its cleaning velocity.">
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <g stroke-linecap="round" fill="none">
      {
        runs.map((run) =>
          run.pipes.map((p, i) => {
            const { x1, y1, x2, y2 } = segment(p);
            return (
              <line
                class={run.drawCls}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke="#8b5cf6"
                stroke-width="4"
                pathLength="100"
                style={`animation-delay: ${(i * 0.64).toFixed(2)}s`}
              />
            );
          }),
        )
      }
      {
        runs.map((run) =>
          run.pipes.map((p) => {
            const { x1, y1, x2, y2 } = segment(p);
            return (
              <line
                class={run.marchCls}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke="#ffffff"
                stroke-width="1.5"
                stroke-dasharray="4 10"
                pathLength="100"
              />
            );
          }),
        )
      }
    </g>
  </svg>

  <!-- run order badges -->
  {
    runs.map((run, i) => (
      <span
        class={`flp-badge-${i + 1} absolute flex h-4 w-4 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-violet-600 text-[9px] font-semibold text-white shadow-sm ring-2 ring-white`}
        style={`left: ${run.badge.left}; top: ${run.badge.top};`}>
        {i + 1}
      </span>
    ))
  }

  <!-- flushing sequence panel -->
  <div
    class="flp-panel absolute top-2 right-2 w-[180px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-[11px] font-semibold text-gray-700">Flushing sequence</p>
      <p class="text-[10px] text-gray-400">UDF</p>
    </div>
    <div class="py-1 text-[10px]">
      {
        runs.map((run, i) => (
          <div class="flex items-center justify-between px-3 py-1">
            <span class="text-gray-600">{run.name}</span>
            <span class="relative">
              <span class="text-gray-400">Queued</span>
              <span
                class={`flp-stat-${i + 1} absolute inset-0 flex items-center justify-end gap-0.5 bg-white font-medium text-green-600 tabular-nums whitespace-nowrap`}>
                {run.velocity} ✓
              </span>
            </span>
          </div>
        ))
      }
    </div>
  </div>
</AppWindow>

<style>
  /* runs draw in order; the second pipe of each run follows via delay */
  .flp-draw-1,
  .flp-draw-2,
  .flp-draw-3 {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    opacity: 0.85;
  }
  .flp-draw-1 {
    animation: flp-draw-1 8s linear infinite both;
  }
  .flp-draw-2 {
    animation: flp-draw-2 8s linear infinite both;
  }
  .flp-draw-3 {
    animation: flp-draw-3 8s linear infinite both;
  }
  @keyframes flp-draw-1 {
    0%, 12% { stroke-dashoffset: 100; opacity: 0.85; }
    20% { stroke-dashoffset: 0; }
    90% { stroke-dashoffset: 0; opacity: 0.85; }
    96%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes flp-draw-2 {
    0%, 37% { stroke-dashoffset: 100; opacity: 0.85; }
    45% { stroke-dashoffset: 0; }
    90% { stroke-dashoffset: 0; opacity: 0.85; }
    96%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes flp-draw-3 {
    0%, 62% { stroke-dashoffset: 100; opacity: 0.85; }
    70% { stroke-dashoffset: 0; }
    90% { stroke-dashoffset: 0; opacity: 0.85; }
    96%, 100% { stroke-dashoffset: 0; opacity: 0; }
  }

  /* white dashes march along each run while it flushes */
  .flp-march-1,
  .flp-march-2,
  .flp-march-3 {
    opacity: 0;
  }
  .flp-march-1 {
    animation:
      flp-march-vis-1 8s linear infinite both,
      flp-march 1.1s linear infinite;
  }
  .flp-march-2 {
    animation:
      flp-march-vis-2 8s linear infinite both,
      flp-march 1.1s linear infinite;
  }
  .flp-march-3 {
    animation:
      flp-march-vis-3 8s linear infinite both,
      flp-march 1.1s linear infinite;
  }
  @keyframes flp-march {
    0% {
      stroke-dashoffset: 14;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }
  @keyframes flp-march-vis-1 {
    0%, 14% { opacity: 0; }
    20%, 88% { opacity: 0.9; }
    94%, 100% { opacity: 0; }
  }
  @keyframes flp-march-vis-2 {
    0%, 39% { opacity: 0; }
    45%, 88% { opacity: 0.9; }
    94%, 100% { opacity: 0; }
  }
  @keyframes flp-march-vis-3 {
    0%, 64% { opacity: 0; }
    70%, 88% { opacity: 0.9; }
    94%, 100% { opacity: 0; }
  }

  /* numbered badges pop at the start of each run */
  .flp-badge-1,
  .flp-badge-2,
  .flp-badge-3 {
    opacity: 0;
  }
  .flp-badge-1 {
    animation: flp-badge-1 8s ease-out infinite both;
  }
  .flp-badge-2 {
    animation: flp-badge-2 8s ease-out infinite both;
  }
  .flp-badge-3 {
    animation: flp-badge-3 8s ease-out infinite both;
  }
  @keyframes flp-badge-1 {
    0%, 10% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
    13% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
    15% { transform: translate(-50%, -50%) scale(1); }
    90% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    96%, 100% { opacity: 0; transform: translate(-50%, -50%) scale(1); }
  }
  @keyframes flp-badge-2 {
    0%, 35% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
    38% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
    40% { transform: translate(-50%, -50%) scale(1); }
    90% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    96%, 100% { opacity: 0; transform: translate(-50%, -50%) scale(1); }
  }
  @keyframes flp-badge-3 {
    0%, 60% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
    63% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
    65% { transform: translate(-50%, -50%) scale(1); }
    90% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    96%, 100% { opacity: 0; transform: translate(-50%, -50%) scale(1); }
  }

  .flp-panel {
    animation: flp-panel-in 8s ease-out infinite both;
  }
  @keyframes flp-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  /* each run checks off as it completes */
  .flp-stat-1 {
    animation: flp-stat-1 8s linear infinite both;
  }
  .flp-stat-2 {
    animation: flp-stat-2 8s linear infinite both;
  }
  .flp-stat-3 {
    animation: flp-stat-3 8s linear infinite both;
  }
  @keyframes flp-stat-1 {
    0%, 28% { opacity: 0; }
    31% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes flp-stat-2 {
    0%, 53% { opacity: 0; }
    56% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes flp-stat-3 {
    0%, 78% { opacity: 0; }
    81% { opacity: 1; }
    100% { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flp-draw-1,
    .flp-draw-2,
    .flp-draw-3,
    .flp-march-1,
    .flp-march-2,
    .flp-march-3,
    .flp-badge-1,
    .flp-badge-2,
    .flp-badge-3,
    .flp-panel,
    .flp-stat-1,
    .flp-stat-2,
    .flp-stat-3 {
      animation: none;
    }
    .flp-draw-1,
    .flp-draw-2,
    .flp-draw-3 {
      stroke-dashoffset: 0;
      opacity: 0.85;
    }
    .flp-march-1,
    .flp-march-2,
    .flp-march-3 {
      opacity: 0;
    }
    .flp-badge-1,
    .flp-badge-2,
    .flp-badge-3 {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
    .flp-panel,
    .flp-stat-1,
    .flp-stat-2,
    .flp-stat-3 {
      opacity: 1;
      transform: none;
    }
  }
</style>
