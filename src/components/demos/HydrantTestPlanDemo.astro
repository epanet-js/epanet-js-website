---
// Hydrant test plan demo: a flow test laid out before going to the field.
// The test hydrant pulses, observation points connect with dashed lines, and
// each one gets its expected pressure drawdown so the informative tests
// stand out.
import AppWindow from "./AppWindow.astro";

// Test hydrant at [240, 210]; observation junctions with expected drawdowns.
const observations = [
  { id: "J12", x: 170, y: 200, drawdown: "−8.4 m", chip: "left-[33%] top-[55%]" },
  { id: "J67", x: 300, y: 220, drawdown: "−5.1 m", chip: "left-[77%] top-[62%]" },
  { id: "J31", x: 230, y: 150, drawdown: "−2.9 m", chip: "left-[59%] top-[38%]" },
];
---

<AppWindow
  hideHeader
  hideFooter
  label="Hydrant test planning in epanet-js: a test hydrant with three observation points, each showing its expected pressure drawdown.">
  <!-- hydrant, observation rings, and connecting lines -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    {
      observations.map((obs, i) => (
        <line
          class="ht-line"
          x1="240"
          y1="210"
          x2={obs.x}
          y2={obs.y}
          stroke="#9ca3af"
          stroke-width="1.2"
          stroke-dasharray="4 3"
          style={`animation-delay: ${(i * 0.64).toFixed(2)}s`}
        />
      ))
    }
    {
      observations.map((obs, i) => (
        <circle
          class={`ht-obs-${i + 1}`}
          cx={obs.x}
          cy={obs.y}
          r="5.5"
          fill="none"
          stroke="#312e81"
          stroke-width="2"
        />
      ))
    }
    <g class="ht-hydrant">
      <rect
        x="235"
        y="205"
        width="10"
        height="10"
        rx="2"
        fill="#8b5cf6"
        stroke="#ffffff"
        stroke-width="1.5"></rect>
    </g>
    <g class="ht-hydrant-pulse-gate">
      <circle
        class="ht-hydrant-pulse"
        cx="240"
        cy="210"
        r="8"
        fill="none"
        stroke="#8b5cf6"
        stroke-width="1.5"></circle>
    </g>
  </svg>

  <!-- expected drawdown chips at the observation points -->
  {
    observations.map((obs, i) => (
      <span
        class:list={[
          `ht-chip-${i + 1}`,
          "absolute whitespace-nowrap rounded border border-gray-200 bg-white px-1 py-px text-xs font-medium text-gray-700 shadow-sm",
          obs.chip,
        ]}>
        {obs.drawdown}
      </span>
    ))
  }

  <!-- test plan panel -->
  <div
    class="ht-panel absolute top-2 right-2 w-[180px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Hydrant test plan</p>
      <p class="text-xs text-gray-400">FH-7</p>
    </div>
    <div
      class="flex items-center justify-between px-3 py-1.5 text-xs border-b border-gray-100">
      <span class="text-gray-500">Test flow</span>
      <span class="font-medium text-gray-700 tabular-nums">30 l/s</span>
    </div>
    <div class="py-1 text-xs">
      {
        observations.map((obs, i) => (
          <div
            class={`ht-row-${i + 1} flex items-center justify-between px-3 py-1`}>
            <span class="text-gray-600">{obs.id}</span>
            <span class="font-medium text-gray-700 tabular-nums">
              {obs.drawdown}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</AppWindow>

<style>
  .ht-hydrant {
    transform-box: fill-box;
    transform-origin: center;
    animation: ht-hydrant-in 10s ease-out infinite both;
  }
  /* Whole 10s cycle, all times rounded to clean seconds. Hydrant settles
     at 1s; the panel waits until 3s (2s after that) to fade in, each
     row/chip pair 1s after the previous starts; everything (hydrant,
     its pulse, lines, rings, panel, rows, chips) holds until 8s, fades
     out together over 8s→9s, then sits blank for a full extra second
     (9s→10s) before the loop restarts. */
  @keyframes ht-hydrant-in {
    0%,
    4% {
      opacity: 0;
      transform: scale(0);
    }
    7% {
      opacity: 1;
      transform: scale(1.2);
    }
    10% {
      transform: scale(1);
    }
    80% {
      opacity: 1;
      transform: scale(1);
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  /* the pulse ring's own opacity is already driven by ht-pulse (the
     ripple fading as it expands each 1.8s beat), so the 8s→9s cutoff is
     applied via a wrapping .ht-hydrant-pulse-gate element instead of a
     second animation on the same element — two animations both setting
     `opacity` on one element don't compose, the later one just wins for
     the whole time it runs, which would silently kill the ripple fade */
  .ht-hydrant-pulse-gate {
    animation: ht-pulse-vis 10s linear infinite both;
  }
  @keyframes ht-pulse-vis {
    0%,
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-hydrant-pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: ht-pulse 1.8s ease-out infinite;
  }
  @keyframes ht-pulse {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    70%,
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  /* dashed lines reach out to the observation points and march slowly */
  .ht-line {
    animation:
      ht-line-in 10s ease-out infinite both,
      ht-march 1.4s linear infinite;
  }
  @keyframes ht-line-in {
    0%,
    10% {
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  @keyframes ht-march {
    0% {
      stroke-dashoffset: 7;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  /* each ring appears in step with its matching chip (same start/settle
     percentages as ht-chip-1/2/3), then holds and fades out with
     everything else at 80%/90% */
  .ht-obs-1,
  .ht-obs-2,
  .ht-obs-3 {
    transform-box: fill-box;
    transform-origin: center;
  }
  .ht-obs-1 {
    animation: ht-obs-1 10s ease-out infinite both;
  }
  @keyframes ht-obs-1 {
    0%,
    40% {
      opacity: 0;
      transform: scale(0.4);
    }
    45% {
      opacity: 1;
      transform: scale(1.15);
    }
    50% {
      transform: scale(1);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-obs-2 {
    animation: ht-obs-2 10s ease-out infinite both;
  }
  @keyframes ht-obs-2 {
    0%,
    50% {
      opacity: 0;
      transform: scale(0.4);
    }
    55% {
      opacity: 1;
      transform: scale(1.15);
    }
    60% {
      transform: scale(1);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-obs-3 {
    animation: ht-obs-3 10s ease-out infinite both;
  }
  @keyframes ht-obs-3 {
    0%,
    60% {
      opacity: 0;
      transform: scale(0.4);
    }
    65% {
      opacity: 1;
      transform: scale(1.15);
    }
    70% {
      transform: scale(1);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }

  /* each chip appears in step with its matching row (same start/settle
     percentages as ht-row-1/2/3), stays visible continuously, and fades
     out together with everything else at 80%/90% */
  .ht-chip-1 {
    animation: ht-chip-1 10s ease-out infinite both;
  }
  @keyframes ht-chip-1 {
    0%,
    40% {
      opacity: 0;
      transform: translateY(3px);
    }
    50% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-chip-2 {
    animation: ht-chip-2 10s ease-out infinite both;
  }
  @keyframes ht-chip-2 {
    0%,
    50% {
      opacity: 0;
      transform: translateY(3px);
    }
    60% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-chip-3 {
    animation: ht-chip-3 10s ease-out infinite both;
  }
  @keyframes ht-chip-3 {
    0%,
    60% {
      opacity: 0;
      transform: translateY(3px);
    }
    70% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }

  /* the panel waits to fade in until 3s (1s after the hydrant settles at
     1s, plus another 1s), holds visible until 80%, then fades out
     together with everything else over 80%→90% */
  .ht-panel {
    animation: ht-panel-in 10s ease-out infinite both;
  }
  @keyframes ht-panel-in {
    0%,
    30% {
      opacity: 0;
      transform: translateY(4px);
    }
    40% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }

  /* rows fade in back-to-back, each taking the same 1s span as the
     panel's own fade-in (§ht-panel-in); row 1 starts right where the
     panel finishes at 4s, and each subsequent pair's fade-in starts 1s
     after the previous pair's, matching ht-chip-1/2/3. All three fade
     out together with everything else at 80%/90%. */
  .ht-row-1 {
    animation: ht-row-1 10s ease-out infinite both;
  }
  @keyframes ht-row-1 {
    0%,
    40% {
      opacity: 0;
      transform: translateY(4px);
    }
    50% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-row-2 {
    animation: ht-row-2 10s ease-out infinite both;
  }
  @keyframes ht-row-2 {
    0%,
    50% {
      opacity: 0;
      transform: translateY(4px);
    }
    60% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }
  .ht-row-3 {
    animation: ht-row-3 10s ease-out infinite both;
  }
  @keyframes ht-row-3 {
    0%,
    60% {
      opacity: 0;
      transform: translateY(4px);
    }
    70% {
      opacity: 1;
      transform: translateY(0);
    }
    80% {
      opacity: 1;
    }
    90%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ht-hydrant,
    .ht-hydrant-pulse-gate,
    .ht-line,
    .ht-obs-1,
    .ht-obs-2,
    .ht-obs-3,
    .ht-chip-1,
    .ht-chip-2,
    .ht-chip-3,
    .ht-panel,
    .ht-row-1,
    .ht-row-2,
    .ht-row-3 {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .ht-hydrant-pulse-gate {
      opacity: 0;
    }
  }
</style>
