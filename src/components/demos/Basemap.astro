---
// The light illustrative basemap used behind the demo network: gray ground,
// white roads, and a few building footprints. Render inside an SVG with
// viewBox="0 0 400 300".
---

<rect width="400" height="300" fill="#f3f4f6"></rect>
<g stroke="#ffffff" stroke-width="6" fill="none" opacity="0.9">
  <path d="M-10 100 C 80 90, 180 110, 410 95"></path>
  <path d="M-10 230 C 120 215, 260 245, 410 225"></path>
  <path d="M70 -10 C 80 90, 60 200, 75 310"></path>
  <path d="M250 -10 C 240 100, 265 220, 255 310"></path>
  <path d="M340 -10 L 330 310"></path>
</g>
<g fill="#e7e8ea">
  <rect x="105" y="15" width="60" height="32" rx="3"></rect>
  <rect x="290" y="30" width="38" height="28" rx="3"></rect>
  <rect x="120" y="240" width="70" height="36" rx="3"></rect>
  <rect x="285" y="255" width="40" height="30" rx="3"></rect>
  <rect x="20" y="150" width="38" height="44" rx="3"></rect>
</g>
