    18.889% { opacity: 1; }
    93.778% { opacity: 1; }
    100% { opacity: 0; }
  }

  .vca-node-out-1 {
    animation: vca-node-out-1 9s infinite both;
  }
  .vca-node-out-2 {
    animation: vca-node-out-2 9s infinite both;
  }
  .vca-node-out-3 {
    animation: vca-node-out-3 9s infinite both;
  }
  @keyframes vca-node-out-1 {
    0%, 11% { opacity: 0; }
    17.222% { opacity: 1; }
    93.778% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes vca-node-out-2 {
    0%, 12.667% { opacity: 0; }
    18.889% { opacity: 1; }
    93.778% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes vca-node-out-3 {
    0%, 14.334% { opacity: 0; }
    20.556% { opacity: 1; }
    93.778% { opacity: 1; }
    100% { opacity: 0; }
  }

  .vca-valve-gray {
    animation: vca-valve-gray 9s infinite both;
  }
  @keyframes vca-valve-gray {
    0%,
    3.111% {
      opacity: 1;
    }
    9.333%,
    93.778% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  .vca-valve-red {
    transform-box: fill-box;
    transform-origin: center;
    animation: vca-valve-red 9s infinite both;
  }
  @keyframes vca-valve-red {
    0%,
    3.111% {
      opacity: 0;
      transform: scale(1);
    }
    6.222% {
      opacity: 0.7;
      transform: scale(1.45);
    }
    9.333% {
      opacity: 1;
      transform: scale(1.15);
    }
    12.444% {
      transform: scale(1);
    }
    93.778% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1);
    }
  }

  .vca-ring-1,
  .vca-ring-2,
  .vca-ring-3 {
    transform-box: fill-box;
    transform-origin: center;
  }
  .vca-ring-1 {
    animation: vca-ring-1 9s infinite both;
  }
  .vca-ring-2 {
    animation: vca-ring-2 9s infinite both;
  }
  .vca-ring-3 {
    animation: vca-ring-3 9s infinite both;
  }
  @keyframes vca-ring-1 {
    0%, 21.778% { opacity: 0; transform: scale(0.4); }
    25.667% { opacity: 1; transform: scale(1.25); }
    29.556% { transform: scale(1); }
    38.889% { transform: scale(1.18); }
    48.222% { transform: scale(1); }
    57.556% { transform: scale(1.18); }
    66.889% { transform: scale(1); }
    93.778% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1); }
  }
  @keyframes vca-ring-2 {
    0%, 23.445% { opacity: 0; transform: scale(0.4); }
    27.333% { opacity: 1; transform: scale(1.25); }
    31.222% { transform: scale(1); }
    40.556% { transform: scale(1.18); }
    49.889% { transform: scale(1); }
    59.222% { transform: scale(1.18); }
    68.556% { transform: scale(1); }
    93.778% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1); }
  }
  @keyframes vca-ring-3 {
    0%, 25.111% { opacity: 0; transform: scale(0.4); }
    29% { opacity: 1; transform: scale(1.25); }
    32.889% { transform: scale(1); }
    42.222% { transform: scale(1.18); }
    51.556% { transform: scale(1); }
    60.889% { transform: scale(1.18); }
