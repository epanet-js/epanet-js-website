  }

  .vca-pill {
    animation: vca-pill 9s infinite both;
  }
  @keyframes vca-pill {
    0%,
    46.667% {
      opacity: 0;
    }
    51.333% {
      opacity: 1;
    }
    57.556% {
      opacity: 0.55;
    }
    63.778% {
      opacity: 1;
    }
    68.444% {
      opacity: 0.6;
    }
    93.778% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vca-pipe-out-1,
    .vca-pipe-out-2,
    .vca-pipe-out-3,
    .vca-node-out-1,
    .vca-node-out-2,
    .vca-node-out-3,
    .vca-valve-gray,
    .vca-valve-red,
    .vca-ring-1,
    .vca-ring-2,
    .vca-ring-3,
    .vca-row-1,
    .vca-row-2,
    .vca-row-3,
    .vca-pill {
      animation: none;
    }
