---
// Browser app diagram: the URL types out, the app loads in the tab, and
// the no-install, no-login, runs-on-your-device chips land. Grounded in
// the homepage's "no login and no install" line.
import { CheckCircle2, Lock } from "lucide-react";
import NetworkMap from "./NetworkMap.astro";

const urlParts = ["app", ".", "epanetjs", ".", "com"];
const chips = ["No install", "No login", "Runs on your device"];
---

<div
  class="w-full rounded-xl border border-gray-200 shadow-lg bg-white p-5 sm:p-6 select-none"
  role="img"
  aria-label="Diagram: typing the epanet-js address into a browser, the app loading in the tab, with no install and no login required.">
  <!-- browser mockup -->
  <div
    class="mx-auto max-w-[380px] overflow-hidden rounded-lg border-2 border-gray-300">
    <div
      class="flex items-center gap-2 border-b border-gray-200 bg-gray-50 px-2.5 py-1.5">
      <span class="flex gap-1">
        <span class="h-2 w-2 rounded-full bg-gray-300"></span>
        <span class="h-2 w-2 rounded-full bg-gray-300"></span>
        <span class="h-2 w-2 rounded-full bg-gray-300"></span>
      </span>
      <span
        class="flex flex-1 items-center gap-1 rounded-full border border-gray-200 bg-white px-2 py-0.5">
        <Lock size={9} className="shrink-0 text-gray-400" />
        <span class="flex items-center text-[10px] font-medium text-gray-700">
          {
            urlParts.map((part, i) => (
              <span
                class="bap-url"
                style={`animation-delay: ${(i * 0.3).toFixed(1)}s`}>
                {part}
              </span>
            ))
          }
          <span class="bap-caret ml-px inline-block h-3 w-px bg-violet-500">
          </span>
        </span>
      </span>
    </div>
    <div class="relative aspect-[16/9] bg-gray-100">
      <div class="bap-app absolute inset-0 flex flex-col">
        <div
          class="flex h-5 shrink-0 items-center gap-1 border-b border-gray-200 bg-white px-2">
          <span class="h-2 w-2 rounded-sm bg-violet-500"></span>
          <span class="text-[8px] font-medium text-gray-600">epanet-js</span>
        </div>
        <div class="relative flex-1">
          <NetworkMap class="absolute inset-0" />
        </div>
      </div>
      <span
        class="bap-status absolute bottom-1.5 right-1.5 flex items-center gap-1 rounded-full bg-white px-1.5 py-0.5 text-[8px] font-medium text-green-600 shadow-sm">
        <CheckCircle2 size={9} />
        Simulation was successful
      </span>
    </div>
  </div>

  <!-- claims -->
  <div class="mt-3 flex flex-wrap items-center justify-center gap-1.5">
    {
      chips.map((chip, i) => (
        <span
          class="bap-chip rounded-full border border-gray-200 bg-gray-50 px-2 py-0.5 text-[9px] font-medium text-gray-600"
          style={`animation-delay: ${(i * 0.48).toFixed(2)}s`}>
          {chip}
        </span>
      ))
    }
  </div>
</div>

<style>
  /* the address types out in chunks */
  .bap-url {
    opacity: 0;
    animation: bap-url-in 8s linear infinite both;
  }
  @keyframes bap-url-in {
    0%,
    8% {
      opacity: 0;
    }
    9% {
      opacity: 1;
    }
    96% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  .bap-caret {
    animation: bap-caret-blink 1s steps(1) infinite;
  }
  @keyframes bap-caret-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  /* the app loads in the tab */
  .bap-app {
    animation: bap-app-in 8s ease-out infinite both;
  }
  @keyframes bap-app-in {
    0%,
    30% {
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .bap-status {
    animation: bap-status-in 8s ease-out infinite both;
  }
  @keyframes bap-status-in {
    0%,
    68% {
      opacity: 0;
      transform: translateY(2px);
    }
    74% {
      opacity: 1;
      transform: translateY(0);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .bap-chip {
    animation: bap-chip-in 8s ease-out infinite both;
  }
  @keyframes bap-chip-in {
    0%,
    50% {
      opacity: 0;
      transform: translateY(3px);
    }
    55% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    97%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bap-url,
    .bap-caret,
    .bap-app,
    .bap-status,
    .bap-chip {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .bap-caret {
      opacity: 0;
    }
  }
</style>
