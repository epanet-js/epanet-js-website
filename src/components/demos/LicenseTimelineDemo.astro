---
// License timeline diagram: source code public from day one under the
// Functional Source License, with each release becoming fully open source
// under MIT two years on.
import { FileCode2 } from "lucide-react";
---

<div
  class="relative mx-auto h-80 w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
  role="img"
  aria-label="Diagram: source code public from day one under the Functional Source License, becoming fully open source under the MIT license after two years.">
  <svg
    viewBox="0 0 480 320"
    preserveAspectRatio="xMidYMid meet"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true">
    <foreignObject x="0" y="0" width="480" height="320">
      <div
        {...{ xmlns: "http://www.w3.org/1999/xhtml" }}
        class="flex h-full w-full flex-col items-center justify-between">
        <div class="box-border flex w-full flex-1 flex-col items-center justify-center px-8 pt-8">
          <div class="flex items-center justify-center gap-2">
            <!-- FSL -->
            <div class="lic-left w-40 shrink-0 text-center">
              <p class="text-3xl font-bold tracking-tight text-indigo-950">
                FSL
              </p>
              <p class="mt-0.5 whitespace-nowrap text-xs font-medium text-gray-500">
                Functional Source License
              </p>
              <p class="mt-1 text-xs text-gray-400">
                Source public from day one
              </p>
            </div>

            <!-- transition -->
            <div class="flex shrink-0 flex-col items-center">
              <!-- code files drifting across as releases age into MIT -->
              <div class="relative mt-12 h-7 w-20" aria-hidden="true">
                <span class="lic-file lic-file-0 absolute left-0 top-0 text-gray-400">
                  <FileCode2 size={14} />
                </span>
                <span class="lic-file lic-file-1 absolute left-0 top-1 text-gray-400">
                  <FileCode2 size={14} />
                </span>
                <span class="lic-file lic-file-2 absolute left-0 top-2 text-gray-400">
                  <FileCode2 size={14} />
                </span>
              </div>
              <svg viewBox="0 0 100 12" class="mt-2 mb-4 w-20 translate-x-2" aria-hidden="true">
                <path
                  class="lic-arrow"
                  d="M2 6 H86"
                  fill="none"
                  stroke="#8b5cf6"
                  stroke-width="2.5"
                  pathLength="100"></path>
                <path
                  class="lic-arrow-head"
                  d="M86 1.5 L96 6 L86 10.5 Z"
                  fill="#8b5cf6"></path>
              </svg>
              <span class="translate-x-2">
                <span
                  class="lic-pill mt-1.5 whitespace-nowrap rounded-full bg-violet-500 px-2 py-1 text-xs font-semibold uppercase tracking-wide text-white">
                  Two years
                </span>
              </span>
            </div>

            <!-- MIT -->
            <div class="lic-right w-40 shrink-0 text-center">
              <p class="text-3xl font-bold tracking-tight text-indigo-950">
                MIT
              </p>
              <p class="mt-0.5 text-xs font-medium text-gray-500">
                MIT License
              </p>
              <p class="mt-1 text-xs text-gray-400">
                Fully open source code
              </p>
            </div>
          </div>
        </div>
        <p class="lic-footer pb-6 text-center text-sm font-medium text-gray-700">
          Each release becomes MIT two years on
        </p>
      </div>
    </foreignObject>
  </svg>
</div>

<style>
  .lic-left {
    animation: lic-left-in 8s ease-out infinite both;
  }
  @keyframes lic-left-in {
    0%,
    4% {
      opacity: 0;
      transform: translateY(3px);
    }
    10% {
      opacity: 1;
      transform: translateY(0);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .lic-arrow {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: lic-arrow-draw 8s linear infinite both;
  }
  @keyframes lic-arrow-draw {
    0%,
    24% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    42% {
      stroke-dashoffset: 0;
    }
    94% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  .lic-arrow-head {
    animation: lic-head-in 8s linear infinite both;
  }
  @keyframes lic-head-in {
    0%,
    40% {
      opacity: 0;
    }
    44% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .lic-pill {
    animation: lic-pill-in 8s ease-out infinite both;
  }
  @keyframes lic-pill-in {
    0%,
    46% {
      opacity: 0;
      transform: scale(0.9);
    }
    51% {
      opacity: 1;
      transform: scale(1.04);
    }
    53% {
      transform: scale(1);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* releases drift from FSL toward MIT, each file on its own staggered
     keyframe so the loop doesn't rely on per-instance animation-delay */
  .lic-file {
    opacity: 0;
  }
  .lic-file-0 {
    animation: lic-file-0-drift 8s ease-in-out infinite both;
  }
  @keyframes lic-file-0-drift {
    0%,
    48% {
      opacity: 0;
      transform: translateX(-48px);
    }
    53% {
      opacity: 1;
    }
    63% {
      opacity: 1;
      transform: translateX(88px);
    }
    68%,
    100% {
      opacity: 0;
      transform: translateX(95px);
    }
  }
  .lic-file-1 {
    animation: lic-file-1-drift 8s ease-in-out infinite both;
  }
  @keyframes lic-file-1-drift {
    0% {
      opacity: 0;
      transform: translateX(95px);
    }
    6.875%,
    54.875% {
      opacity: 0;
      transform: translateX(-48px);
    }
    59.875% {
      opacity: 1;
    }
    69.875% {
      opacity: 1;
      transform: translateX(88px);
    }
    74.875%,
    100% {
      opacity: 0;
      transform: translateX(95px);
    }
  }
  .lic-file-2 {
    animation: lic-file-2-drift 8s ease-in-out infinite both;
  }
  @keyframes lic-file-2-drift {
    0% {
      opacity: 0;
      transform: translateX(95px);
    }
    13.75%,
    61.75% {
      opacity: 0;
      transform: translateX(-48px);
    }
    66.75% {
      opacity: 1;
    }
    76.75% {
      opacity: 1;
      transform: translateX(88px);
    }
    81.75%,
    100% {
      opacity: 0;
      transform: translateX(95px);
    }
  }

  /* MIT side lights up as the first release crosses over */
  .lic-right {
    animation: lic-right-lit 8s ease-in-out infinite both;
  }
  @keyframes lic-right-lit {
    0%,
    10% {
      opacity: 0;
    }
    14%,
    56% {
      opacity: 0.35;
    }
    62% {
      opacity: 1;
      transform: scale(1.04);
    }
    66% {
      transform: scale(1);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .lic-footer {
    animation: lic-footer-in 8s ease-out infinite both;
  }
  @keyframes lic-footer-in {
    0%,
    6% {
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lic-left,
    .lic-arrow,
    .lic-arrow-head,
    .lic-pill,
    .lic-file-0,
    .lic-file-1,
    .lic-file-2,
    .lic-right,
    .lic-footer {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .lic-arrow {
      stroke-dashoffset: 0;
    }
    .lic-file {
      opacity: 0;
    }
  }
</style>
