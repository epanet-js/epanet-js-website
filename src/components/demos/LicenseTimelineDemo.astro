---
// License timeline diagram: source code public from day one under the
// Functional Source License, with each release becoming fully open source
// under MIT two years on.
import { FileCode2 } from "lucide-react";
---

<div
  class="w-full rounded-xl border border-gray-200 shadow-lg bg-white p-5 sm:p-6 select-none"
  role="img"
  aria-label="Diagram: source code public from day one under the Functional Source License, becoming fully open source under the MIT license after two years.">
  <div class="flex items-center justify-center gap-4 sm:gap-8">
    <!-- FSL -->
    <div class="lic-left max-w-[150px] text-center">
      <p class="text-3xl font-bold tracking-tight text-indigo-950">FSL</p>
      <p class="mt-0.5 text-[10px] font-medium text-gray-500">
        Functional Source License
      </p>
      <p class="mt-1 text-[10px] text-gray-400">Source public from day one</p>
    </div>

    <!-- transition -->
    <div class="flex flex-col items-center">
      <!-- code files drifting across as releases age into MIT -->
      <div class="relative h-7 w-24 sm:w-32" aria-hidden="true">
        {
          [0, 1, 2].map((i) => (
            <span
              class="lic-file absolute left-0 text-gray-400"
              style={`top: ${i * 4}px; animation-delay: ${(i * 0.55).toFixed(2)}s`}>
              <FileCode2 size={13} />
            </span>
          ))
        }
      </div>
      <svg viewBox="0 0 100 12" class="w-24 sm:w-32" aria-hidden="true">
        <path
          class="lic-arrow"
          d="M2 6 H86"
          fill="none"
          stroke="#8b5cf6"
          stroke-width="2.5"
          pathLength="100"></path>
        <path class="lic-arrow-head" d="M86 1.5 L96 6 L86 10.5 Z" fill="#8b5cf6"
        ></path>
      </svg>
      <span
        class="lic-pill mt-1.5 whitespace-nowrap rounded-full bg-violet-600 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-white">
        Two years
      </span>
    </div>

    <!-- MIT -->
    <div class="lic-right max-w-[150px] text-center">
      <p class="text-3xl font-bold tracking-tight text-indigo-950">MIT</p>
      <p class="mt-0.5 text-[10px] font-medium text-gray-500">MIT License</p>
      <p class="mt-1 text-[10px] text-gray-400">Fully open source code</p>
    </div>
  </div>
  <p class="lic-footer mt-4 text-center text-[10px] text-gray-400">
    Each release becomes MIT two years on.
  </p>
</div>

<style>
  .lic-left {
    animation: lic-left-in 8s ease-out infinite both;
  }
  @keyframes lic-left-in {
    0%,
    4% {
      opacity: 0;
      transform: translateY(3px);
    }
    10% {
      opacity: 1;
      transform: translateY(0);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .lic-arrow {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: lic-arrow-draw 8s linear infinite both;
  }
  @keyframes lic-arrow-draw {
    0%,
    24% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    42% {
      stroke-dashoffset: 0;
    }
    94% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  .lic-arrow-head {
    animation: lic-head-in 8s linear infinite both;
  }
  @keyframes lic-head-in {
    0%,
    40% {
      opacity: 0;
    }
    44% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .lic-pill {
    animation: lic-pill-in 8s ease-out infinite both;
  }
  @keyframes lic-pill-in {
    0%,
    46% {
      opacity: 0;
      transform: scale(0.9);
    }
    51% {
      opacity: 1;
      transform: scale(1.04);
    }
    53% {
      transform: scale(1);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* releases drift from FSL toward MIT */
  .lic-file {
    opacity: 0;
    animation: lic-file-drift 8s ease-in-out infinite both;
  }
  @keyframes lic-file-drift {
    0%,
    48% {
      opacity: 0;
      transform: translateX(0);
    }
    53% {
      opacity: 1;
    }
    63% {
      opacity: 1;
      transform: translateX(64px);
    }
    68%,
    100% {
      opacity: 0;
      transform: translateX(76px);
    }
  }

  /* MIT side lights up as the first release crosses over */
  .lic-right {
    animation: lic-right-lit 8s ease-in-out infinite both;
  }
  @keyframes lic-right-lit {
    0%,
    10% {
      opacity: 0;
    }
    14%,
    56% {
      opacity: 0.35;
    }
    62% {
      opacity: 1;
      transform: scale(1.04);
    }
    66% {
      transform: scale(1);
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .lic-footer {
    animation: lic-footer-in 8s ease-out infinite both;
  }
  @keyframes lic-footer-in {
    0%,
    70% {
      opacity: 0;
    }
    76% {
      opacity: 1;
    }
    94% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lic-left,
    .lic-arrow,
    .lic-arrow-head,
    .lic-pill,
    .lic-file,
    .lic-right,
    .lic-footer {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .lic-arrow {
      stroke-dashoffset: 0;
    }
    .lic-file {
      opacity: 0;
    }
  }
</style>
