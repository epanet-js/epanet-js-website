---
// Time series plot demo (concept): three assets selected as chips, then
// their pressure, level, and flow traces draw on one shared 24-hour chart.
// Depicts the roadmap's multi-element plot.

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const chips = [
  { id: "J288", dot: "bg-violet-500", cls: "border-violet-200 bg-violet-50 text-violet-700" },
  { id: "T2", dot: "bg-blue-500", cls: "border-blue-200 bg-blue-50 text-blue-700" },
  { id: "PMP-1", dot: "bg-green-500", cls: "border-green-200 bg-green-50 text-green-700" },
];
---

<div
  class:list={[
    "bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden select-none",
    className,
  ]}
  role="img"
  aria-label="Time series plot panel: junction J288, tank T2, and pump PMP-1 selected as chips, with their three traces drawing on one shared 24-hour chart.">
  <div
    class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
    <p class="text-[11px] font-semibold text-gray-700">Time series</p>
    <p class="text-[10px] text-gray-400">24 h</p>
  </div>
  <div class="px-3 py-2.5">
    <!-- selected asset chips -->
    <div class="flex items-center gap-1.5">
      {
        chips.map((chip, i) => (
          <span
            class:list={[
              "tsp-chip flex items-center gap-1 rounded-full border px-2 py-0.5 text-[9px] font-medium",
              chip.cls,
            ]}
            style={`animation-delay: ${(i * 0.5).toFixed(1)}s`}>
            <span class:list={["h-1.5 w-1.5 rounded-full", chip.dot]} />
            {chip.id}
          </span>
        ))
      }
    </div>

    <!-- shared chart -->
    <svg viewBox="0 0 220 90" class="mt-2 w-full" aria-hidden="true">
      <g stroke="#e5e7eb" stroke-width="0.75" stroke-dasharray="3 3">
        <line x1="4" y1="22" x2="216" y2="22"></line>
        <line x1="4" y1="46" x2="216" y2="46"></line>
        <line x1="4" y1="70" x2="216" y2="70"></line>
      </g>
      <g font-size="6" fill="#9ca3af">
        <text x="4" y="86">00:00</text>
        <text x="110" y="86" text-anchor="middle">12:00</text>
        <text x="216" y="86" text-anchor="end">24:00</text>
      </g>

      <!-- J288 pressure -->
      <polyline
        class="tsp-trace tsp-trace-1"
        pathLength="100"
        points="4,30 40,42 76,26 112,38 148,48 184,32 216,28"
        fill="none"
        stroke="#8b5cf6"
        stroke-width="1.5"
        stroke-linejoin="round"></polyline>
      <!-- T2 level -->
      <polyline
        class="tsp-trace tsp-trace-2"
        pathLength="100"
        points="4,40 60,60 96,28 150,58 216,34"
        fill="none"
        stroke="#3b82f6"
        stroke-width="1.5"
        stroke-linejoin="round"></polyline>
      <!-- PMP-1 flow (step-shaped) -->
      <polyline
        class="tsp-trace tsp-trace-3"
        pathLength="100"
        points="4,70 36,70 36,24 88,24 88,70 128,70 128,24 176,24 176,70 216,70"
        fill="none"
        stroke="#22c55e"
        stroke-width="1.5"
        stroke-linejoin="round"></polyline>
    </svg>

    <p class="tsp-footer mt-1 text-[9px] text-gray-400">
      J288 pressure · T2 level · PMP-1 flow
    </p>
  </div>
</div>

<style>
  .tsp-chip {
    animation: tsp-chip-in 8s ease-out infinite both;
  }
  @keyframes tsp-chip-in {
    0%,
    5% {
      opacity: 0;
      transform: scale(0.9);
    }
    9% {
      opacity: 1;
      transform: scale(1.04);
    }
    11% {
      transform: scale(1);
    }
    92% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  .tsp-trace {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .tsp-trace-1 {
    animation: tsp-draw-1 8s linear infinite both;
  }
  .tsp-trace-2 {
    animation: tsp-draw-2 8s linear infinite both;
  }
  .tsp-trace-3 {
    animation: tsp-draw-3 8s linear infinite both;
  }
  @keyframes tsp-draw-1 {
    0%,
    22% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    46% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes tsp-draw-2 {
    0%,
    32% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    56% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes tsp-draw-3 {
    0%,
    42% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    66% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  .tsp-footer {
    animation: tsp-footer-in 8s ease-out infinite both;
  }
  @keyframes tsp-footer-in {
    0%,
    70% {
      opacity: 0;
    }
    76% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tsp-chip,
    .tsp-trace-1,
    .tsp-trace-2,
    .tsp-trace-3,
    .tsp-footer {
      animation: none;
    }
    .tsp-chip {
      opacity: 1;
      transform: none;
    }
    .tsp-trace {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .tsp-footer {
      opacity: 1;
    }
  }
</style>
