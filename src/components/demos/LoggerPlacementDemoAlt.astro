---
// Alternate version of LoggerPlacementDemo, dropping loggers onto the alt
// network instead of NetworkMap's. Same timing/panel content; the marker
// positions are their own hand-picked set (not network-geometry-alt.ts's
// shared markerPoints, which other alt demos still use), explicitly chosen
// to land clear of the bottom-left panel below.
import AppWindow from "./AppWindow.astro";

const sortedMarkerPoints: [number, number][] = [
  [370, 86],
  [170, 196],
  [570, 196],
  [370, 306],
];

const coverageSteps = ["0%", "52%", "71%", "86%", "94%"];
---

<AppWindow
  variant="plain"
  altNetwork
  hideHeader
  hideFooter
  label="Logger placement in epanet-js: proposed pressure loggers dropping onto the map one by one while the coverage figure climbs to 94% of demand observable.">
  <!-- proposed loggers with coverage halos -->
  <svg
    viewBox="0 0 640 400"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    {
      sortedMarkerPoints.map(([x, y], i) => (
        <circle
          class={`lpa-halo lpa-halo-${i + 1}`}
          cx={x}
          cy={y}
          r="102"
          fill="#8b5cf6"
          fill-opacity="0.12"
        />
      ))
    }
    {
      sortedMarkerPoints.map(([x, y], i) => (
        <circle
          class={`lpa-pin lpa-pin-${i + 1}`}
          cx={x}
          cy={y}
          r="8"
          fill="#8b5cf6"
          stroke="#ffffff"
          stroke-width="2.4"
        />
      ))
    }
  </svg>

  <!-- placement panel -->
  <div
    class="lpa-panel absolute bottom-2 left-2 w-[180px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-[12px] font-semibold text-gray-700">Logger placement</p>
      <p class="text-[11px] text-gray-400">DMA-3</p>
    </div>
    <div class="px-3 py-2">
      <div class="flex items-center justify-between text-[12px]">
        <span class="text-gray-500">Demand observable</span>
        <span class="relative inline-block min-w-[28px] text-right font-medium text-gray-700 tabular-nums">
          {
            coverageSteps.map((step, i) => (
              <span
                class:list={[
                  `lpa-cov-${i}`,
                  i > 0 && "absolute inset-0 bg-white text-right",
                ]}>
                {step}
              </span>
            ))
          }
        </span>
      </div>
      <div class="mt-1.5 h-1 rounded-full bg-gray-100 overflow-hidden">
        <div class="lpa-progress h-full rounded-full bg-violet-500"></div>
      </div>
    </div>
    <p
      class="lpa-footer px-3 py-1.5 border-t border-gray-100 text-[12px] text-gray-500">
      4 loggers proposed
    </p>
  </div>
</AppWindow>

<style>
  /* pins drop in one at a time with a small bounce */
  .lpa-pin {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
  }
  .lpa-pin-1 {
    animation: lpa-drop-1 8s ease-out infinite both;
  }
  .lpa-pin-2 {
    animation: lpa-drop-2 8s ease-out infinite both;
  }
  .lpa-pin-3 {
    animation: lpa-drop-3 8s ease-out infinite both;
  }
  .lpa-pin-4 {
    animation: lpa-drop-4 8s ease-out infinite both;
  }
  @keyframes lpa-drop-1 {
    0%, 10% { opacity: 0; transform: translateY(-12px); }
    13% { opacity: 1; transform: translateY(0); }
    14.5% { transform: translateY(-3px); }
    16% { transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes lpa-drop-2 {
    0%, 24% { opacity: 0; transform: translateY(-12px); }
    27% { opacity: 1; transform: translateY(0); }
    28.5% { transform: translateY(-3px); }
    30% { transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes lpa-drop-3 {
    0%, 38% { opacity: 0; transform: translateY(-12px); }
    41% { opacity: 1; transform: translateY(0); }
    42.5% { transform: translateY(-3px); }
    44% { transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes lpa-drop-4 {
    0%, 52% { opacity: 0; transform: translateY(-12px); }
    55% { opacity: 1; transform: translateY(0); }
    56.5% { transform: translateY(-3px); }
    58% { transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }

  /* each halo spreads once its logger lands */
  .lpa-halo {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
  }
  .lpa-halo-1 {
    animation: lpa-halo-1 8s ease-out infinite both;
  }
  .lpa-halo-2 {
    animation: lpa-halo-2 8s ease-out infinite both;
  }
  .lpa-halo-3 {
    animation: lpa-halo-3 8s ease-out infinite both;
  }
  .lpa-halo-4 {
    animation: lpa-halo-4 8s ease-out infinite both;
  }
  @keyframes lpa-halo-1 {
    0%, 13% { opacity: 0; transform: scale(0.2); }
    20% { opacity: 1; transform: scale(1); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes lpa-halo-2 {
    0%, 27% { opacity: 0; transform: scale(0.2); }
    34% { opacity: 1; transform: scale(1); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes lpa-halo-3 {
    0%, 41% { opacity: 0; transform: scale(0.2); }
    48% { opacity: 1; transform: scale(1); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes lpa-halo-4 {
    0%, 55% { opacity: 0; transform: scale(0.2); }
    62% { opacity: 1; transform: scale(1); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }

  .lpa-panel {
    animation: lpa-panel-in 8s ease-out infinite both;
  }
  @keyframes lpa-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  /* coverage value steps up just after each logger lands */
  .lpa-cov-0 {
    animation: lpa-cov-0 8s linear infinite both;
  }
  .lpa-cov-1 {
    animation: lpa-cov-1 8s linear infinite both;
  }
  .lpa-cov-2 {
    animation: lpa-cov-2 8s linear infinite both;
  }
  .lpa-cov-3 {
    animation: lpa-cov-3 8s linear infinite both;
  }
  .lpa-cov-4 {
    animation: lpa-cov-4 8s linear infinite both;
  }
  @keyframes lpa-cov-0 {
    0%, 14% { opacity: 1; }
    15%, 100% { opacity: 0; }
  }
  @keyframes lpa-cov-1 {
    0%, 14% { opacity: 0; }
    15%, 28% { opacity: 1; }
    29%, 100% { opacity: 0; }
  }
  @keyframes lpa-cov-2 {
    0%, 28% { opacity: 0; }
    29%, 42% { opacity: 1; }
    43%, 100% { opacity: 0; }
  }
  @keyframes lpa-cov-3 {
    0%, 42% { opacity: 0; }
    43%, 56% { opacity: 1; }
    57%, 100% { opacity: 0; }
  }
  @keyframes lpa-cov-4 {
    0%, 56% { opacity: 0; }
    57% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }

  .lpa-progress {
    width: 0;
    animation: lpa-progress 8s ease-in-out infinite both;
  }
  @keyframes lpa-progress {
    0%, 13% { width: 0; }
    16%, 27% { width: 52%; }
    30%, 41% { width: 71%; }
    44%, 55% { width: 86%; }
    58% { width: 94%; }
    100% { width: 94%; }
  }

  .lpa-footer {
    animation: lpa-footer-in 8s ease-out infinite both;
  }
  @keyframes lpa-footer-in {
    0%,
    64% {
      opacity: 0;
    }
    70% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lpa-pin,
    .lpa-halo,
    .lpa-panel,
    .lpa-cov-0,
    .lpa-cov-1,
    .lpa-cov-2,
    .lpa-cov-3,
    .lpa-cov-4,
    .lpa-progress,
    .lpa-footer {
      animation: none;
    }
    .lpa-pin,
    .lpa-halo,
    .lpa-panel,
    .lpa-cov-4,
    .lpa-footer {
      opacity: 1;
      transform: none;
    }
    .lpa-cov-0,
    .lpa-cov-1,
    .lpa-cov-2,
    .lpa-cov-3 {
      opacity: 0;
    }
    .lpa-progress {
      width: 94%;
    }
  }
</style>
