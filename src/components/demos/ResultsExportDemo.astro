---
// Results export demo: format pills picked one after another, with a file
// row appearing and checking off as each export finishes.
import { CheckCircle2, FileText } from "lucide-react";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const formats = ["GeoJSON", "CSV", "XLSX"];

const files = [
  { name: "results.geojson", size: "2.4 MB" },
  { name: "junctions.csv", size: "312 KB" },
  { name: "report.xlsx", size: "1.1 MB" },
];
---

<div
  class:list={[
    "relative mx-auto aspect-[3/2] w-full max-w-[480px] rounded-xl shadow-lg select-none",
    className,
  ]}
  role="img"
  aria-label="Export results panel: GeoJSON, CSV, and XLSX formats picked one after another, with each file checking off as ready.">
  <div class="absolute inset-0 overflow-hidden rounded-xl border border-gray-200 bg-white">
    <svg
      viewBox="0 0 480 320"
      preserveAspectRatio="xMidYMid meet"
      class="absolute inset-0 h-full w-full"
      aria-hidden="true">
      <foreignObject x="0" y="0" width="480" height="320">
        <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="flex h-full w-full flex-col justify-between">
          <div
            class="flex items-baseline justify-between px-4 py-3.5 border-b border-gray-100">
            <p class="text-base font-semibold text-gray-700">Export results</p>
            <p class="text-sm text-gray-400">All timesteps</p>
          </div>
          <div class="py-1">
            <div class="flex items-center gap-2 px-4 py-2.5">
              {
                formats.map((format, i) => (
                  <span class="relative">
                    <span class="block rounded-full border border-gray-200 bg-gray-100 px-2.5 py-1 text-sm font-medium text-nowrap text-gray-500">
                      {format}
                    </span>
                    <span
                      class={`rex-pill-${i + 1} absolute inset-0 flex items-center justify-center rounded-full border border-violet-500 bg-violet-500 px-2.5 py-1 text-sm font-medium text-nowrap text-white`}>
                      {format}
                    </span>
                  </span>
                ))
              }
            </div>
            {
              files.map((file, i) => (
                <div class={`rex-row-${i + 1} flex items-center gap-2 px-4 py-2.5`}>
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-purple-50 text-purple-600">
                    <FileText size={14} />
                  </span>
                  <span class="text-sm font-medium text-gray-700">{file.name}</span>
                  <span class="text-sm text-gray-400 tabular-nums">{file.size}</span>
                  <span class="relative ml-auto h-8 w-20 shrink-0">
                    <span class="absolute inset-0 flex items-center justify-end text-sm text-nowrap text-gray-400">
                      Writing…
                    </span>
                    <span
                      class={`rex-check-${i + 1} absolute inset-0 flex items-center justify-end bg-white`}>
                      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-green-50 text-green-600">
                        <CheckCircle2 size={14} />
                      </span>
                    </span>
                  </span>
                </div>
              ))
            }
          </div>
          <p
            class="rex-footer flex items-center gap-3 border-t border-gray-100 px-4 py-2.5">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-green-50 text-green-600">
              <CheckCircle2 size={14} />
            </span>
            <span class="relative text-sm font-medium text-green-600">
              <span class="invisible">3 files ready</span>
              <span class="rex-count-1 absolute inset-0">1 file ready</span>
              <span class="rex-count-2 absolute inset-0">2 files ready</span>
              <span class="rex-count-3 absolute inset-0">3 files ready</span>
            </span>
          </p>
        </div>
      </foreignObject>
    </svg>
  </div>
</div>

<style>
  /* 10s cycle: same entrance timing as before (0-6.4s), but the fully
     settled state (all pills active, all rows checked, footer showing
     "3 files ready") now holds 2s longer before the shared fade-out,
     which still runs 92%->98% of its own local window, just pushed
     later in absolute time (9.36s-9.84s instead of 7.36s-7.84s). */
  .rex-pill-1 {
    animation: rex-pill-1 10s ease-out infinite both;
  }
  .rex-pill-2 {
    animation: rex-pill-2 10s ease-out infinite both;
  }
  .rex-pill-3 {
    animation: rex-pill-3 10s ease-out infinite both;
  }
  @keyframes rex-pill-1 {
    0%, 6.4% { opacity: 0; }
    9.6% { opacity: 1; }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }
  @keyframes rex-pill-2 {
    0%, 28.8% { opacity: 0; }
    32% { opacity: 1; }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }
  @keyframes rex-pill-3 {
    0%, 48% { opacity: 0; }
    51.2% { opacity: 1; }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }

  .rex-row-1 {
    animation: rex-row-1 10s ease-out infinite both;
  }
  .rex-row-2 {
    animation: rex-row-2 10s ease-out infinite both;
  }
  .rex-row-3 {
    animation: rex-row-3 10s ease-out infinite both;
  }
  @keyframes rex-row-1 {
    0%, 9.6% { opacity: 0; transform: translateY(3px); }
    12.8% { opacity: 1; transform: translateY(0); }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }
  @keyframes rex-row-2 {
    0%, 32% { opacity: 0; transform: translateY(3px); }
    35.2% { opacity: 1; transform: translateY(0); }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }
  @keyframes rex-row-3 {
    0%, 51.2% { opacity: 0; transform: translateY(3px); }
    54.4% { opacity: 1; transform: translateY(0); }
    93.6% { opacity: 1; }
    98.4%, 100% { opacity: 0; }
  }

  .rex-check-1 {
    animation: rex-check-1 10s ease-out infinite both;
  }
  .rex-check-2 {
    animation: rex-check-2 10s ease-out infinite both;
  }
  .rex-check-3 {
    animation: rex-check-3 10s ease-out infinite both;
  }
  @keyframes rex-check-1 {
    0%, 20.8% { opacity: 0; }
    24% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes rex-check-2 {
    0%, 41.6% { opacity: 0; }
    44.8% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes rex-check-3 {
    0%, 60.8% { opacity: 0; }
    64% { opacity: 1; }
    100% { opacity: 1; }
  }

  .rex-count-1 {
    animation: rex-count-1 10s ease-out infinite both;
  }
  .rex-count-2 {
    animation: rex-count-2 10s ease-out infinite both;
  }
  .rex-count-3 {
    animation: rex-count-3 10s ease-out infinite both;
  }
  @keyframes rex-count-1 {
    0%, 20.8% { opacity: 0; }
    24% { opacity: 1; }
    41.6% { opacity: 1; }
    44.8% { opacity: 0; }
    100% { opacity: 0; }
  }
  @keyframes rex-count-2 {
    0%, 41.6% { opacity: 0; }
    44.8% { opacity: 1; }
    60.8% { opacity: 1; }
    64% { opacity: 0; }
    100% { opacity: 0; }
  }
  @keyframes rex-count-3 {
    0%, 60.8% { opacity: 0; }
    64% { opacity: 1; }
    100% { opacity: 1; }
  }

  .rex-footer {
    animation: rex-footer-in 10s ease-out infinite both;
  }
  @keyframes rex-footer-in {
    0%,
    20.8% {
      opacity: 0;
    }
    24% {
      opacity: 1;
    }
    93.6% {
      opacity: 1;
    }
    98.4%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rex-pill-1,
    .rex-pill-2,
    .rex-pill-3,
    .rex-row-1,
    .rex-row-2,
    .rex-row-3,
    .rex-check-1,
    .rex-check-2,
    .rex-check-3,
    .rex-count-1,
    .rex-count-2,
    .rex-count-3,
    .rex-footer {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .rex-count-1,
    .rex-count-2 {
      opacity: 0;
    }
  }
</style>
