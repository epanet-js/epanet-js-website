---
// Results export demo (concept): format pills picked one after another,
// with a file row appearing and checking off as each export finishes.
import { CheckCircle2, FileText } from "lucide-react";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const files = [
  { name: "results.geojson", size: "2.4 MB" },
  { name: "junctions.csv", size: "312 KB" },
  { name: "report.xlsx", size: "1.1 MB" },
];
---

<div
  class:list={[
    "bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden select-none",
    className,
  ]}
  role="img"
  aria-label="Export results panel: GeoJSON, CSV, and XLSX formats picked one after another, with each file checking off as ready.">
  <div
    class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
    <p class="text-[11px] font-semibold text-gray-700">Export results</p>
    <p class="text-[10px] text-gray-400">All timesteps</p>
  </div>
  <div class="px-3 py-2.5">
    <!-- format pills -->
    <div class="flex items-center gap-1.5">
      {
        ["GeoJSON", "CSV", "XLSX"].map((format, i) => (
          <span class="relative">
            <span class="block rounded-full bg-gray-100 px-2 py-0.5 text-[9px] font-medium text-gray-500">
              {format}
            </span>
            <span
              class={`rex-pill-${i + 1} absolute inset-0 flex items-center justify-center rounded-full bg-violet-500 px-2 py-0.5 text-[9px] font-medium text-white`}>
              {format}
            </span>
          </span>
        ))
      }
    </div>

    <!-- file rows -->
    <div class="mt-2 space-y-1">
      {
        files.map((file, i) => (
          <div
            class={`rex-row-${i + 1} flex items-center gap-1.5 rounded-md border border-gray-100 px-2 py-1.5 text-[10px]`}>
            <FileText size={11} className="shrink-0 text-gray-400" />
            <span class="font-medium text-gray-700">{file.name}</span>
            <span class="text-[9px] text-gray-400">{file.size}</span>
            <span class="relative ml-auto">
              <span class="text-[9px] text-gray-400">Writing…</span>
              <span
                class={`rex-check-${i + 1} absolute inset-0 flex items-center justify-end gap-1 bg-white text-[9px] font-medium text-green-600`}>
                <CheckCircle2 size={11} />
              </span>
            </span>
          </div>
        ))
      }
    </div>

    <p
      class="rex-footer mt-2 flex items-center gap-1 border-t border-gray-100 pt-1.5 text-[10px] text-green-600">
      <CheckCircle2 size={11} />
      3 files ready · 1,284 rows
    </p>
  </div>
</div>

<style>
  .rex-pill-1 {
    animation: rex-pill-1 8s ease-out infinite both;
  }
  .rex-pill-2 {
    animation: rex-pill-2 8s ease-out infinite both;
  }
  .rex-pill-3 {
    animation: rex-pill-3 8s ease-out infinite both;
  }
  @keyframes rex-pill-1 {
    0%, 8% { opacity: 0; }
    12% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes rex-pill-2 {
    0%, 36% { opacity: 0; }
    40% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes rex-pill-3 {
    0%, 60% { opacity: 0; }
    64% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }

  .rex-row-1 {
    animation: rex-row-1 8s ease-out infinite both;
  }
  .rex-row-2 {
    animation: rex-row-2 8s ease-out infinite both;
  }
  .rex-row-3 {
    animation: rex-row-3 8s ease-out infinite both;
  }
  @keyframes rex-row-1 {
    0%, 12% { opacity: 0; transform: translateY(3px); }
    16% { opacity: 1; transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes rex-row-2 {
    0%, 40% { opacity: 0; transform: translateY(3px); }
    44% { opacity: 1; transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes rex-row-3 {
    0%, 64% { opacity: 0; transform: translateY(3px); }
    68% { opacity: 1; transform: translateY(0); }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }

  .rex-check-1 {
    animation: rex-check-1 8s ease-out infinite both;
  }
  .rex-check-2 {
    animation: rex-check-2 8s ease-out infinite both;
  }
  .rex-check-3 {
    animation: rex-check-3 8s ease-out infinite both;
  }
  @keyframes rex-check-1 {
    0%, 26% { opacity: 0; }
    30% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes rex-check-2 {
    0%, 52% { opacity: 0; }
    56% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes rex-check-3 {
    0%, 76% { opacity: 0; }
    80% { opacity: 1; }
    100% { opacity: 1; }
  }

  .rex-footer {
    animation: rex-footer-in 8s ease-out infinite both;
  }
  @keyframes rex-footer-in {
    0%,
    82% {
      opacity: 0;
    }
    87% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rex-pill-1,
    .rex-pill-2,
    .rex-pill-3,
    .rex-row-1,
    .rex-row-2,
    .rex-row-3,
    .rex-check-1,
    .rex-check-2,
    .rex-check-3,
    .rex-footer {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
