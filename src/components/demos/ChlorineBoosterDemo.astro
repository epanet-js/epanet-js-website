---
// Chlorine booster demo: residual decays along the network toward the
// 0.2 mg/l floor, the tail of the system flags below it, then a booster
// added mid-network lifts the tail back above the minimum, with the map
// tint following.
import AppWindow from "./AppWindow.astro";
import { pipes } from "./network-geometry";

// Pipes grouped by residual band along the path from the works.
const bands = [
  { color: "#22c55e", cls: "clb-src", pipes: pipes.slice(0, 7) },
  { color: "#f59e0b", cls: "clb-mid", pipes: pipes.slice(7, 14) },
  { color: "#ef4444", cls: "clb-tail", pipes: pipes.slice(14) },
];

// After the booster, everything downstream comes back to green.
const fixedPipes = pipes.slice(7);
---

<AppWindow
  variant="plain"
  label="Chlorine residual in epanet-js: the network tinted by residual as it decays from the works, then a booster lifting the tail back above the 0.2 milligram per liter minimum.">
  <!-- residual tint overlay -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <g stroke-width="2.5" stroke-linecap="round" fill="none">
      {
        bands.map((band) =>
          band.pipes.map(([x1, y1, x2, y2]) => (
            <line
              class={band.cls}
              x1={x1}
              y1={y1}
              x2={x2}
              y2={y2}
              stroke={band.color}
            />
          )),
        )
      }
      {
        fixedPipes.map(([x1, y1, x2, y2]) => (
          <line
            class="clb-fix"
            x1={x1}
            y1={y1}
            x2={x2}
            y2={y2}
            stroke="#22c55e"
          />
        ))
      }
    </g>

    <!-- booster station added mid-network -->
    <circle
      class="clb-booster-pulse"
      cx="210"
      cy="75"
      r="8"
      fill="none"
      stroke="#8b5cf6"
      stroke-width="1.5"></circle>
    <circle
      class="clb-booster"
      cx="210"
      cy="75"
      r="5"
      fill="#8b5cf6"
      stroke="#ffffff"
      stroke-width="1.5"></circle>
  </svg>

  <!-- residual panel -->
  <div
    class="clb-panel absolute top-2 right-2 w-[200px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-[11px] font-semibold text-gray-700">Chlorine residual</p>
      <p class="text-[10px] text-gray-400">mg/l</p>
    </div>
    <div class="px-3 pt-2 pb-1">
      <svg viewBox="0 0 170 70" class="w-full" aria-hidden="true">
        <!-- minimum residual floor -->
        <line
          x1="4"
          y1="46"
          x2="160"
          y2="46"
          stroke="#d1d5db"
          stroke-width="1"
          stroke-dasharray="3 2"></line>
        <text x="160" y="43" text-anchor="end" font-size="5.5" fill="#9ca3af">
          0.2 min
        </text>

        <!-- decay from the works; the tail drops below the floor -->
        <polyline
          class="clb-curve-head"
          pathLength="100"
          points="4,12 30,22 56,31 82,39 108,46"
          fill="none"
          stroke="#8b5cf6"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>
        <polyline
          class="clb-curve-tail"
          pathLength="100"
          points="108,46 130,52 160,56"
          fill="none"
          stroke="#8b5cf6"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>
        <polyline
          class="clb-tail-flash"
          points="108,46 130,52 160,56"
          fill="none"
          stroke="#f59e0b"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>

        <!-- booster location and the lifted tail -->
        <line
          class="clb-marker"
          x1="100"
          y1="8"
          x2="100"
          y2="62"
          stroke="#8b5cf6"
          stroke-width="1"
          stroke-dasharray="3 2"></line>
        <polyline
          class="clb-lift"
          pathLength="100"
          points="100,44 106,24 132,32 160,38"
          fill="none"
          stroke="#22c55e"
          stroke-width="1.5"
          stroke-linejoin="round"></polyline>
      </svg>
      <p class="mt-0.5 text-[9px] text-gray-400">
        Residual vs distance from works
      </p>
    </div>
    <p
      class="clb-chip px-3 py-1.5 border-t border-gray-100 text-[10px] font-medium text-green-600">
      ≥ 0.2 mg/l network-wide
    </p>
  </div>
</AppWindow>

<style>
  /* residual bands tint the map outward from the works */
  .clb-src {
    animation: clb-band-1 8s ease-in-out infinite both;
  }
  .clb-mid {
    animation: clb-band-2 8s ease-in-out infinite both;
  }
  .clb-tail {
    animation: clb-band-3 8s ease-in-out infinite both;
  }
  @keyframes clb-band-1 {
    0%, 6% { opacity: 0; }
    14% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes clb-band-2 {
    0%, 9% { opacity: 0; }
    17% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }
  @keyframes clb-band-3 {
    0%, 12% { opacity: 0; }
    20% { opacity: 1; }
    92% { opacity: 1; }
    98%, 100% { opacity: 0; }
  }

  /* downstream pipes come back to green after the booster */
  .clb-fix {
    animation: clb-fix-in 8s ease-in-out infinite both;
  }
  @keyframes clb-fix-in {
    0%,
    58% {
      opacity: 0;
    }
    72% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .clb-booster {
    transform-box: fill-box;
    transform-origin: center;
    animation: clb-booster-in 8s ease-out infinite both;
  }
  @keyframes clb-booster-in {
    0%,
    46% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      opacity: 1;
      transform: scale(1.3);
    }
    52% {
      transform: scale(1);
    }
    92% {
      opacity: 1;
      transform: scale(1);
    }
    98%,
    100% {
      opacity: 0;
    }
  }
  .clb-booster-pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: clb-booster-pulse 8s ease-out infinite both;
  }
  @keyframes clb-booster-pulse {
    0%,
    50% {
      opacity: 0;
      transform: scale(0.8);
    }
    54% {
      opacity: 0.7;
      transform: scale(1);
    }
    64% {
      opacity: 0;
      transform: scale(2);
    }
    70%,
    74% {
      opacity: 0.5;
      transform: scale(1);
    }
    84%,
    100% {
      opacity: 0;
      transform: scale(2);
    }
  }

  .clb-panel {
    animation: clb-panel-in 8s ease-out infinite both;
  }
  @keyframes clb-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .clb-curve-head {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: clb-head-draw 8s linear infinite both;
  }
  @keyframes clb-head-draw {
    0%,
    12% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    25% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  /* the tail draws, then dims once the lifted curve takes over */
  .clb-curve-tail {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: clb-tail-draw 8s linear infinite both;
  }
  @keyframes clb-tail-draw {
    0%,
    25% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    32% {
      stroke-dashoffset: 0;
    }
    52% {
      opacity: 1;
    }
    62% {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  .clb-tail-flash {
    animation: clb-tail-flash 8s linear infinite both;
  }
  @keyframes clb-tail-flash {
    0%,
    36% {
      opacity: 0;
    }
    39%,
    42% {
      opacity: 1;
    }
    44% {
      opacity: 0;
    }
    46%,
    49% {
      opacity: 1;
    }
    52%,
    100% {
      opacity: 0;
    }
  }

  .clb-marker {
    animation: clb-marker-in 8s ease-out infinite both;
  }
  @keyframes clb-marker-in {
    0%,
    48% {
      opacity: 0;
    }
    52% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .clb-lift {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: clb-lift-draw 8s linear infinite both;
  }
  @keyframes clb-lift-draw {
    0%,
    52% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    66% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  .clb-chip {
    animation: clb-chip-in 8s ease-out infinite both;
  }
  @keyframes clb-chip-in {
    0%,
    76% {
      opacity: 0;
    }
    82% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .clb-src,
    .clb-mid,
    .clb-tail,
    .clb-fix,
    .clb-booster,
    .clb-booster-pulse,
    .clb-panel,
    .clb-curve-head,
    .clb-curve-tail,
    .clb-tail-flash,
    .clb-marker,
    .clb-lift,
    .clb-chip {
      animation: none;
    }
    .clb-src,
    .clb-mid,
    .clb-tail,
    .clb-fix,
    .clb-panel,
    .clb-marker,
    .clb-chip {
      opacity: 1;
      transform: none;
    }
    .clb-booster {
      opacity: 1;
      transform: scale(1);
    }
    .clb-booster-pulse,
    .clb-tail-flash {
      opacity: 0;
    }
    .clb-curve-head,
    .clb-lift {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .clb-curve-tail {
      stroke-dashoffset: 0;
      opacity: 0.25;
    }
  }
</style>
