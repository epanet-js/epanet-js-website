---
// Zone fit demo: the network decomposes into three colored zones with a
// fit figure per zone, and the worst-fitting zone pulses for attention.
import { CheckCircle2, TriangleAlert } from "lucide-react";
import AppWindow from "./AppWindow.astro";
import { pipes, junctions } from "./network-geometry";

// Pipe indexes grouped into calibration zones (local to this demo).
// Each zone's label/row entrance is a dedicated keyframe (no
// animation-delay) so every element's 90/96/100% hold-and-fade-out lands
// on the same real-time clock — see the style block for why.
const zones = [
  {
    name: "Zone A",
    color: "#3b82f6",
    cls: "zf-zone-a",
    labelCls: "zf-label-a",
    rowCls: "zf-row-a",
    fit: "0.9 m",
    pipes: [0, 1, 2, 3, 4, 5, 6],
    label: { left: "22%", top: "24%" },
  },
  {
    name: "Zone B",
    color: "#22c55e",
    cls: "zf-zone-b",
    labelCls: "zf-label-b",
    rowCls: "zf-row-b",
    fit: "1.4 m",
    pipes: [7, 8, 9, 10, 11, 12, 13],
    label: { left: "40%", top: "76%" },
  },
  {
    name: "Zone C",
    color: "#f59e0b",
    cls: "zf-zone-c",
    labelCls: "zf-label-c",
    fit: "3.8 m",
    pipes: [14, 15, 16, 17, 18, 19],
    label: { left: "73%", top: "82%" },
  },
];
---

<AppWindow
  variant="plain"
  hideHeader
  hideFooter
  label="Zone fit in epanet-js: the network split into three colored calibration zones with a fit figure per zone, the worst-fitting zone pulsing.">
  <!-- zone coloring overlay -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <g stroke-width="2.5" stroke-linecap="round" fill="none">
      {
        zones.map((zone) =>
          zone.pipes.map((index, i) => {
            const [x1, y1, x2, y2] = pipes[index];
            return (
              <line
                class={zone.cls}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke={zone.color}
                pathLength="100"
                style={`animation-delay: ${(i * 0.08).toFixed(2)}s`}
              />
            );
          }),
        )
      }
    </g>
    <!-- redraw the junction dots on top of the zone-colored lines, since
         this overlay is a separate sibling painted after NetworkMap's own
         junctions and would otherwise cover them -->
    <g stroke="#ffffff" stroke-width="1">
      {
        junctions.map(([x, y]) => (
          <circle cx={x} cy={y} r="3.5" fill="#312e81" />
        ))
      }
    </g>
  </svg>

  <!-- zone labels -->
  {
    zones.map((zone) => (
      <span
        class:list={[
          "absolute -translate-x-1/2 rounded border border-gray-200 bg-white px-1.5 py-px text-xs font-medium text-gray-600 shadow-sm",
          zone.labelCls,
        ]}
        style={`left: ${zone.label.left}; top: ${zone.label.top}`}>
        {zone.name}
      </span>
    ))
  }

  <!-- fit-by-zone panel -->
  <div
    class="zf-panel absolute top-2 right-2 w-[168px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-xs font-semibold text-gray-700">Fit by zone</p>
      <p class="text-xs text-gray-400">Mean error</p>
    </div>
    <div class="py-1 text-xs">
      {
        zones.map((zone, i) => (
          <div
            class:list={[
              "flex items-center justify-between px-3 py-1",
              i === 2 ? "zf-row-warn" : zone.rowCls,
            ]}>
            <span class="flex items-center gap-1.5 text-gray-600">
              <span
                class="inline-block h-2 w-2 rounded-sm"
                style={`background: ${zone.color}`}
              />
              {zone.name}
            </span>
            <span class="flex items-center gap-1 font-medium text-gray-700 tabular-nums">
              {zone.fit}
              {i === 2 ? (
                <TriangleAlert size={14} className="text-amber-500" />
              ) : (
                <CheckCircle2 size={14} className="text-green-500" />
              )}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</AppWindow>

<style>
  /* zones sweep in one after another */
  .zf-zone-a,
  .zf-zone-b,
  .zf-zone-c {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .zf-zone-a {
    animation: zf-draw-a 8s linear infinite both;
  }
  .zf-zone-b {
    animation: zf-draw-b 8s linear infinite both;
  }
  .zf-zone-c {
    animation: zf-draw-c 8s linear infinite both;
  }
  @keyframes zf-draw-a {
    0%,
    10% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    18% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes zf-draw-b {
    0%,
    22% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    30% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  /* the worst zone throbs during the hold */
  @keyframes zf-draw-c {
    0%,
    34% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    42% {
      stroke-dashoffset: 0;
    }
    66% {
      opacity: 1;
    }
    72% {
      opacity: 0.45;
    }
    78% {
      opacity: 1;
    }
    84% {
      opacity: 0.45;
    }
    90% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  /* each label lands ~0.2s after its own zone finishes drawing (zone A's
     slowest pipe finishes at 1.92s, B at 2.88s, C at 3.76s — see the
     per-pipe stagger in zf-draw-a/b/c above), instead of arriving before
     the zone is done. No animation-delay: the offset is baked into each
     keyframe's own percentages so all three share the same 90/96/100%
     hold-and-fade-out clock and reset in sync at the end of the loop. */
  .zf-label-a {
    animation: zf-label-a-in 8s ease-out infinite both;
  }
  @keyframes zf-label-a-in {
    0%,
    20.5% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    26.5% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .zf-label-b {
    animation: zf-label-b-in 8s ease-out infinite both;
  }
  @keyframes zf-label-b-in {
    0%,
    32.5% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    38.5% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .zf-label-c {
    animation: zf-label-c-in 8s ease-out infinite both;
  }
  @keyframes zf-label-c-in {
    0%,
    43.5% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    49.5% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  .zf-panel {
    animation: zf-panel-in 8s ease-out infinite both;
  }
  @keyframes zf-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  /* each row now fades in at the exact same percentages as its zone's
     on-map label (zf-label-a/b/c above), so "Zone A" popping up on the
     map and its row appearing in the panel read as one simultaneous
     event, not two staggered ones. Still baked into each keyframe's own
     percentages (no animation-delay) so all three share the same
     90/96/100% hold-and-fade-out clock and reset in sync. */
  .zf-row-a {
    animation: zf-row-a-in 8s ease-out infinite both;
  }
  @keyframes zf-row-a-in {
    0%,
    20.5% {
      opacity: 0;
      transform: translateY(4px);
    }
    26.5% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  .zf-row-b {
    animation: zf-row-b-in 8s ease-out infinite both;
  }
  @keyframes zf-row-b-in {
    0%,
    32.5% {
      opacity: 0;
      transform: translateY(4px);
    }
    38.5% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  @keyframes zf-row-c-in {
    0%,
    43.5% {
      opacity: 0;
      transform: translateY(4px);
    }
    49.5% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  /* the worst zone's row tints amber while its pipes throb; zf-row-tint
     was already undelayed, so it stays in sync with zf-draw-c unchanged */
  .zf-row-warn {
    animation:
      zf-row-c-in 8s ease-out infinite both,
      zf-row-tint 8s ease-in-out infinite both;
  }
  @keyframes zf-row-tint {
    0%,
    66% {
      background-color: transparent;
    }
    72% {
      background-color: #fef3c7;
    }
    78% {
      background-color: #fffbeb;
    }
    84% {
      background-color: #fef3c7;
    }
    92%,
    100% {
      background-color: transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zf-zone-a,
    .zf-zone-b,
    .zf-zone-c,
    .zf-label-a,
    .zf-label-b,
    .zf-label-c,
    .zf-panel,
    .zf-row-a,
    .zf-row-b,
    .zf-row-warn {
      animation: none;
    }
    .zf-zone-a,
    .zf-zone-b,
    .zf-zone-c {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .zf-label-a,
    .zf-label-b,
    .zf-label-c {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    .zf-panel,
    .zf-row-a,
    .zf-row-b,
    .zf-row-warn {
      opacity: 1;
      transform: none;
    }
  }
</style>
