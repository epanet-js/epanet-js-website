---
// Zone fit demo: the network decomposes into three colored zones with a
// fit figure per zone, and the worst-fitting zone pulses for attention.
import { CheckCircle2, TriangleAlert } from "lucide-react";
import AppWindow from "./AppWindow.astro";
import { pipes } from "./network-geometry";

// Pipe indexes grouped into calibration zones (local to this demo).
const zones = [
  {
    name: "Zone A",
    color: "#3b82f6",
    cls: "zf-zone-a",
    fit: "0.9 m",
    pipes: [0, 1, 2, 3, 4, 5, 6],
    label: { left: "22%", top: "24%" },
  },
  {
    name: "Zone B",
    color: "#22c55e",
    cls: "zf-zone-b",
    fit: "1.4 m",
    pipes: [7, 8, 9, 10, 11, 12, 13],
    label: { left: "40%", top: "76%" },
  },
  {
    name: "Zone C",
    color: "#f59e0b",
    cls: "zf-zone-c",
    fit: "3.8 m",
    pipes: [14, 15, 16, 17, 18, 19],
    label: { left: "76%", top: "36%" },
  },
];
---

<AppWindow
  variant="plain"
  label="Zone fit in epanet-js: the network split into three colored calibration zones with a fit figure per zone, the worst-fitting zone pulsing.">
  <!-- zone coloring overlay -->
  <svg
    viewBox="0 0 400 300"
    preserveAspectRatio="xMidYMid slice"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true">
    <g stroke-width="2.5" stroke-linecap="round" fill="none">
      {
        zones.map((zone) =>
          zone.pipes.map((index, i) => {
            const [x1, y1, x2, y2] = pipes[index];
            return (
              <line
                class={zone.cls}
                x1={x1}
                y1={y1}
                x2={x2}
                y2={y2}
                stroke={zone.color}
                pathLength="100"
                style={`animation-delay: ${(i * 0.08).toFixed(2)}s`}
              />
            );
          }),
        )
      }
    </g>
  </svg>

  <!-- zone labels -->
  {
    zones.map((zone, i) => (
      <span
        class="zf-label absolute -translate-x-1/2 rounded border border-gray-200 bg-white px-1.5 py-px text-[9px] font-medium text-gray-600 shadow-sm"
        style={`left: ${zone.label.left}; top: ${zone.label.top}; animation-delay: ${(i * 0.96).toFixed(2)}s`}>
        {zone.name}
      </span>
    ))
  }

  <!-- fit-by-zone panel -->
  <div
    class="zf-panel absolute top-2 right-2 w-[170px] max-w-[70%] bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
    <div
      class="flex items-baseline justify-between px-3 pt-2.5 pb-2 border-b border-gray-100">
      <p class="text-[11px] font-semibold text-gray-700">Fit by zone</p>
      <p class="text-[10px] text-gray-400">Mean error</p>
    </div>
    <div class="py-1 text-[10px]">
      {
        zones.map((zone, i) => (
          <div
            class:list={[
              "zf-row flex items-center justify-between px-3 py-1",
              i === 2 && "zf-row-warn",
            ]}
            style={`animation-delay: ${(i * 0.64).toFixed(2)}s${i === 2 ? ", 0s" : ""}`}>
            <span class="flex items-center gap-1.5 text-gray-600">
              <span
                class="inline-block h-2 w-2 rounded-sm"
                style={`background: ${zone.color}`}
              />
              {zone.name}
            </span>
            <span class="flex items-center gap-1 font-medium text-gray-700 tabular-nums">
              {zone.fit}
              {i === 2 ? (
                <TriangleAlert size={11} className="text-amber-500" />
              ) : (
                <CheckCircle2 size={11} className="text-green-500" />
              )}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</AppWindow>

<style>
  /* zones sweep in one after another */
  .zf-zone-a,
  .zf-zone-b,
  .zf-zone-c {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .zf-zone-a {
    animation: zf-draw-a 8s linear infinite both;
  }
  .zf-zone-b {
    animation: zf-draw-b 8s linear infinite both;
  }
  .zf-zone-c {
    animation: zf-draw-c 8s linear infinite both;
  }
  @keyframes zf-draw-a {
    0%,
    10% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    18% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  @keyframes zf-draw-b {
    0%,
    22% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    30% {
      stroke-dashoffset: 0;
    }
    92% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }
  /* the worst zone throbs during the hold */
  @keyframes zf-draw-c {
    0%,
    34% {
      stroke-dashoffset: 100;
      opacity: 1;
    }
    42% {
      stroke-dashoffset: 0;
    }
    66% {
      opacity: 1;
    }
    72% {
      opacity: 0.45;
    }
    78% {
      opacity: 1;
    }
    84% {
      opacity: 0.45;
    }
    90% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    98%,
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  .zf-label {
    animation: zf-label-in 8s ease-out infinite both;
  }
  @keyframes zf-label-in {
    0%,
    14% {
      opacity: 0;
      transform: translate(-50%, 3px);
    }
    20% {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  .zf-panel {
    animation: zf-panel-in 8s ease-out infinite both;
  }
  @keyframes zf-panel-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    92% {
      opacity: 1;
    }
    98%,
    100% {
      opacity: 0;
    }
  }

  .zf-row {
    animation: zf-row-in 8s ease-out infinite both;
  }
  @keyframes zf-row-in {
    0%,
    44% {
      opacity: 0;
      transform: translateY(4px);
    }
    49% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  /* the worst zone's row tints amber while its pipes throb */
  .zf-row-warn {
    animation:
      zf-row-in 8s ease-out infinite both,
      zf-row-tint 8s ease-in-out infinite both;
  }
  @keyframes zf-row-tint {
    0%,
    66% {
      background-color: transparent;
    }
    72% {
      background-color: #fef3c7;
    }
    78% {
      background-color: #fffbeb;
    }
    84% {
      background-color: #fef3c7;
    }
    92%,
    100% {
      background-color: transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zf-zone-a,
    .zf-zone-b,
    .zf-zone-c,
    .zf-label,
    .zf-panel,
    .zf-row,
    .zf-row-warn {
      animation: none;
    }
    .zf-zone-a,
    .zf-zone-b,
    .zf-zone-c {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    .zf-label {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    .zf-panel,
    .zf-row,
    .zf-row-warn {
      opacity: 1;
      transform: none;
    }
  }
</style>
