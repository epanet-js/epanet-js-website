---
// Projection finder concept: search for a coordinate system by name, pick the
// matching EPSG code, and the model seats onto the basemap in the right place.
import { CheckCircle2, Search } from "lucide-react";
import NetworkMap from "./NetworkMap.astro";

const candidates = [
  { code: "EPSG:27700", name: "OSGB36 / British National Grid" },
  { code: "EPSG:7405", name: "British National Grid + ODN heights" },
  { code: "EPSG:4326", name: "WGS 84" },
];

// Rows populate between 12% and 35% of the 7s cycle.
const rowDelay = (i: number) => 0.84 + i * 0.6;
---

<div
  class="w-full rounded-xl border border-gray-200 shadow-lg bg-white p-4 sm:p-5 select-none"
  role="img"
  aria-label="Concept diagram: the network projection finder searching for British National Grid, selecting EPSG:27700 from the candidate list, and the model seating onto the basemap in its correct location.">
  <div class="grid sm:grid-cols-[1fr_1.2fr] gap-3">
    <!-- search panel -->
    <div
      class="bg-white rounded-lg border border-gray-100 shadow-md overflow-hidden">
      <div
        class="flex items-baseline justify-between gap-2 px-3 pt-2.5 pb-2 border-b border-gray-100">
        <p class="text-[11px] font-semibold text-gray-700">
          Network projection finder
        </p>
        <p class="text-[10px] text-gray-400">No coordinates found</p>
      </div>
      <div class="px-3 py-2.5">
        <div
          class="rounded border border-gray-200 px-2 py-1 flex items-center gap-1.5">
          <Search size={11} className="text-gray-400 shrink-0" />
          <span class="pf-query flex items-center text-[10px] text-gray-700">
            British National Grid
            <span class="pf-caret inline-block w-px h-2.5 ml-px bg-gray-400"
            ></span>
          </span>
        </div>
        <ul class="mt-2 space-y-1">
          {
            candidates.map((candidate, i) => (
              <li
                class="pf-row relative"
                style={`animation-delay: ${rowDelay(i)}s`}>
                <div
                  class:list={[
                    "border-l-2 border-transparent px-2 py-1",
                    i === 0 && "pf-cand-plain",
                  ]}>
                  <p class="text-[10px] font-medium text-gray-700 tabular-nums">
                    {candidate.code}
                  </p>
                  <p class="text-[9px] text-gray-400">{candidate.name}</p>
                </div>
                {i === 0 && (
                  <div class="pf-cand-selected absolute inset-0 bg-violet-50 border-l-2 border-violet-500 px-2 py-1">
                    <p class="text-[10px] font-medium text-violet-700 tabular-nums">
                      {candidate.code}
                    </p>
                    <p class="text-[9px] text-gray-400">{candidate.name}</p>
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- map pane -->
    <div
      class="relative aspect-[16/10] rounded-lg border border-gray-200 overflow-hidden bg-gray-100">
      <div class="pf-map absolute inset-0">
        <NetworkMap variant="plain" />
      </div>
      <div
        class="pf-chip absolute bottom-2 left-2 bg-white rounded-md border border-gray-100 shadow-md px-2 py-1 flex items-center gap-1.5 text-[10px] text-gray-700">
        <span class="pf-chip-pulse flex items-center justify-center">
          <CheckCircle2 size={11} className="text-green-500" />
        </span>
        Placed in EPSG:27700
      </div>
    </div>
  </div>
</div>

<style>
  /* search text fades in over the first 12% of the cycle */
  .pf-query {
    animation: pf-query 7s linear infinite both;
  }
  @keyframes pf-query {
    0% {
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  .pf-caret {
    animation: pf-caret 1.1s ease-in-out infinite;
  }
  @keyframes pf-caret {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  /* candidate rows populate with a stagger, 12-35% */
  .pf-row {
    animation: pf-row-in 7s infinite both;
  }
  @keyframes pf-row-in {
    0% {
      opacity: 0;
      transform: translateY(4px);
    }
    7% {
      opacity: 1;
      transform: translateY(0);
    }
    90% {
      opacity: 1;
    }
    96%,
    100% {
      opacity: 0;
    }
  }
  /* first row crossfades to its selected state at ~40% */
  .pf-cand-plain {
    animation: pf-cand-plain 7s linear infinite both;
  }
  @keyframes pf-cand-plain {
    0%,
    40% {
      opacity: 1;
    }
    45% {
      opacity: 0;
    }
    92% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  .pf-cand-selected {
    animation: pf-cand-selected 7s linear infinite both;
  }
  @keyframes pf-cand-selected {
    0%,
    40% {
      opacity: 0;
    }
    45% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  /* network seats onto the basemap, 42-62% */
  .pf-map {
    animation: pf-map-seat 7s linear infinite both;
  }
  @keyframes pf-map-seat {
    0%,
    42% {
      transform: translate(8%, -6%) scale(0.92);
      opacity: 0.35;
      animation-timing-function: ease-out;
    }
    62%,
    92% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(8%, -6%) scale(0.92);
      opacity: 0.35;
    }
  }
  /* confirmation chip pops at 64-72% */
  .pf-chip {
    animation: pf-chip 7s linear infinite both;
  }
  @keyframes pf-chip {
    0%,
    64% {
      opacity: 0;
      transform: translateY(4px) scale(0.9);
      animation-timing-function: ease-out;
    }
    69% {
      opacity: 1;
      transform: translateY(0) scale(1.03);
    }
    72% {
      transform: translateY(0) scale(1);
    }
    92% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translateY(0) scale(1);
    }
  }
  .pf-chip-pulse {
    animation: pf-chip-pulse 1.8s ease-in-out infinite;
  }
  @keyframes pf-chip-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.15);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pf-query,
    .pf-caret,
    .pf-row,
    .pf-cand-plain,
    .pf-cand-selected,
    .pf-map,
    .pf-chip,
    .pf-chip-pulse {
      animation: none;
    }
    .pf-query {
      opacity: 1;
    }
    .pf-caret {
      opacity: 0;
    }
    .pf-row {
      opacity: 1;
      transform: translateY(0);
    }
    .pf-cand-plain {
      opacity: 0;
    }
    .pf-cand-selected {
      opacity: 1;
    }
    .pf-map {
      opacity: 1;
      transform: translate(0, 0) scale(1);
    }
    .pf-chip {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    .pf-chip-pulse {
      transform: scale(1);
    }
  }
</style>
