---
import Link from "@components/ui/link.astro";
import { CircleMinus } from "lucide-react";

// --- Data model for non-commercial plans ---
interface NonCommercialPlan {
  name: string;
  price: number;
  suffix: string;
  description: string;
  limitations: string[];
  limitationSubtitle?: string;
  buttonText: string;
  buttonVariant?: "outline" | "default";
  buttonUrl?: string;
}

const NON_COMMERCIAL_PLANS: NonCommercialPlan[] = [
  {
    name: "Personal",
    price: 100,
    suffix: "year",
    description: "For curious minds and personal growth.",
    limitations: ["Community support only", "Non-commercial usage"],
    limitationSubtitle: "Everything in Pro, but:",
    buttonText: "Buy personal access",
    buttonVariant: "outline",
    buttonUrl: "https://app.epanetjs.com/?dialog=upgrade&plan=personal",
  },
  {
    name: "Education",
    price: 0,
    suffix: "year",
    description: "Free for students and teachers.",
    limitations: ["Community support only", "Non-commercial usage"],
    limitationSubtitle: "Everything in Pro, but:",
    buttonText: "Use your school email account",
    buttonVariant: "outline",
    buttonUrl:
      "https://help.epanetjs.com/Free-educational-licenses-for-epanet-js-2a1e18c9f0f68192a785cbe61747addf",
  },
];

const getFinalUrl = (plan: NonCommercialPlan) => {
  if (!plan.buttonUrl) return undefined;

  if (plan.name === "Personal") {
    return `${plan.buttonUrl}&paymentType=yearly&startCheckout=true`;
  }

  return plan.buttonUrl;
};

const getButtonStyle = (plan: NonCommercialPlan) =>
  plan.buttonVariant === "outline" ? "outline" : "primary";

---

<div class="container mx-auto mt-20 mb-10 px-4 md:px-6 relative">
  {/* Header */}
  <div class="flex flex-col items-center justify-center space-y-4 text-center">
    <div class="space-y-2">
      <div class="space-y-1 max-w-[700px] mx-auto">
        <h3 class="text-2xl font-bold">
          Special access for personal and educational use
        </h3>
        <p class="text-sm text-muted-foreground md:text-base">
          Available for non-commercial projects, learning, and student work.
        </p>
      </div>
    </div>
  </div>

  {/* --- Special Access Grid --- */}
  <div
    class="grid gap-4 pt-10 grid-cols-1 md:grid-cols-2 lg:gap-8 max-w-3xl mx-auto"
  >
    {NON_COMMERCIAL_PLANS.map((plan) => {
      const finalUrl = getFinalUrl(plan);
      const buttonStyle = getButtonStyle(plan);

      return (
        <div
          class="rounded-lg border bg-background shadow-sm transition-shadow hover:shadow-md mx-auto md:mx-0 w-full max-w-[450px] md:min-w-0"
        >
          <div
            class="grid grid-cols-1 md:grid-cols-2 grid-rows-[auto_auto] gap-3 p-4"
          >
            {/* Left Column */}
            <div class="flex flex-col gap-1">
              <h3
                class="whitespace-nowrap tracking-tight flex items-center gap-x-2 text-lg font-semibold"
              >
                {plan.name}
              </h3>
              <span class="inline-block whitespace-nowrap leading-none">
                <span class="text-2xl font-bold">
                  ${plan.price}
                </span>
                <span class="inline-block text-sm text-gray-500">
                  {`/${plan.suffix}`}
                </span>
              </span>
              <p class="text-sm text-gray-900 min-h-[1.5rem]">
                {plan.description}
              </p>
            </div>

            {/* Right Column */}
            <div class="flex flex-col justify-start">
              {plan.limitationSubtitle && (
                <span class="mt-[.625rem] mb-2 block text-xs text-gray-500">
                  {plan.limitationSubtitle}
                </span>
              )}
              <ul class="space-y-1 text-xs">
                {plan.limitations.map((limitation) => (
                  <li class="flex items-start">
                    <CircleMinus
                      className="mr-1.5 mt-0.5 h-3.5 w-3.5 text-green-500 flex-shrink-0"
                    />
                    <span>{limitation}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Button Row */}
            <div class="col-span-1 md:col-span-2 mt-2">
              {finalUrl && (
                <a href={finalUrl} class="block rounded-full text-center transition focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-indigo-500 focus-visible:outline-none focus-visible:shadow-outline-indigo w-full px-7 py-2.5 bg-gray-100 hover:bg-gray-200   border-2 border-transparent">
                  {plan.buttonText}
                </a>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>
