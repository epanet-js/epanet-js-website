---
type Tier = "priority" | "paid";

interface Props {
  tier: Tier;
}

const { tier } = Astro.props;

const styles: Record<Tier, string> = {
  priority: "bg-blue-50   text-blue-700   ring-blue-200",
  paid:     "bg-indigo-50 text-indigo-700 ring-indigo-200",
};

const defaultLabel: Record<Tier, string> = {
  priority: "Priority Access",
  paid:     "Paid Plans",
};
---

<span
  class:list={[
    "not-prose block w-max -mt-4 items-center rounded-full px-3 py-2",
    "text-sm font-medium leading-none ring-1 ring-inset",
    styles[tier],
  ]}
>
  <slot>{defaultLabel[tier]}</slot>
</span>
