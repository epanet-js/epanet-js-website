---
import Container from "@components/container.astro";

interface Props {
  active: "case-study" | "paper";
}

const { active } = Astro.props;

const variants = [
  {
    key: "case-study",
    label: "Case study",
    href: "/case-studies/warren-county-utility-district",
    title:
      "How Warren County Utility District brought hydraulic modeling in-house",
    subtitle:
      "A Tennessee utility went from sending every hydraulic question to its consultant to answering most of them the same day, starting with its GIS data and one rainy afternoon.",
  },
  {
    key: "paper",
    label: "Engineering paper",
    href: "/case-studies/warren-county-utility-district-engineering-paper",
    title:
      "Building an in-house distribution system hydraulic model at a mid-size Tennessee utility district",
    subtitle: "Warren County Utility District, McMinnville, Tennessee",
  },
] as const;

const titleClasses =
  "text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl xl:text-5xl/none text-pretty";
const subtitleClasses = "text-muted-foreground md:text-xl max-w-[600px] mx-auto";
---

<section
  class="w-full pt-12 pb-12 md:pt-20 md:pb-16 bg-gradient-to-br from-blue-50 via-purple-50 to-white overflow-hidden">
  <Container>
    <div class="mx-auto max-w-3xl text-center">
      {/* Both variants are stacked in the same grid cell, the inactive one
          invisible, so the hero has the same height on both pages and the
          toggle below never moves during the view transition. */}
      <div class="grid">
        {
          variants.map((variant) => (
            <div
              class:list={[
                "col-start-1 row-start-1 space-y-4",
                variant.key !== active && "invisible",
              ]}
              aria-hidden={variant.key !== active ? "true" : undefined}>
              {variant.key === active ? (
                <h1 class={titleClasses}>{variant.title}</h1>
              ) : (
                <p class={titleClasses}>{variant.title}</p>
              )}
              <p class={subtitleClasses}>{variant.subtitle}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8 md:mt-10 flex flex-col items-center gap-4">
        <p class="text-sm text-muted-foreground">
          How do you want to read about Warren County bringing hydraulic
          modeling in-house?
        </p>
        <div
          transition:name="wcud-format-toggle"
          role="group"
          aria-label="Reading format"
          class="inline-flex rounded-full border border-gray-200 bg-gray-100 p-1">
          {
            variants.map((variant) => (
              <a
                href={variant.href}
                aria-current={variant.key === active ? "page" : undefined}
                class:list={[
                  "relative isolate rounded-full px-5 py-2 text-sm font-medium transition-colors",
                  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2",
                  variant.key === active
                    ? "text-gray-900"
                    : "text-gray-500 hover:text-gray-900",
                ]}>
                {variant.key === active && (
                  <span
                    transition:name="wcud-format-toggle-active"
                    aria-hidden="true"
                    class="absolute inset-0 -z-10 rounded-full bg-white shadow-sm ring-1 ring-gray-200"
                  />
                )}
                {variant.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
