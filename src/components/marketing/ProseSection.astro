---
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";

interface Props {
  eyebrow?: string;
  title?: string;
  align?: "left" | "center";
  class?: string;
}

const { eyebrow, title, align = "left", class: className } = Astro.props;
const isCentered = align === "center";
---

<section class:list={["w-full py-12 md:py-16", className]}>
  <Container>
    <div
      class:list={[
        "max-w-3xl",
        isCentered && "mx-auto text-center",
      ]}>
      {eyebrow && <Badge color="indigo">{eyebrow}</Badge>}
      {
        title && (
          <h2
            class:list={[
              "text-2xl font-bold tracking-tight md:text-3xl",
              eyebrow && "mt-4",
            ]}>
            {title}
          </h2>
        )
      }
      <div
        class:list={[
          "space-y-4 text-muted-foreground md:text-lg/relaxed",
          (eyebrow || title) && "mt-5",
        ]}>
        <slot />
      </div>
    </div>
  </Container>
</section>
