---
import Container from "@components/container.astro";
import type { LucideIcon } from "lucide-react";

interface Benefit {
  icon?: LucideIcon;
  title: string;
  description: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  items: Benefit[];
  columns?: 2 | 3 | 4;
  class?: string;
}

const {
  heading,
  subheading,
  items,
  columns = 3,
  class: className,
} = Astro.props;

const colsClass = {
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-2 lg:grid-cols-3",
  4: "sm:grid-cols-2 lg:grid-cols-4",
}[columns];
---

<section class:list={["w-full py-12 md:py-16", className]}>
  <Container>
    {
      (heading || subheading) && (
        <div class="max-w-2xl mb-10 md:mb-12">
          {heading && (
            <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
              {heading}
            </h2>
          )}
          {subheading && (
            <p class="mt-3 text-muted-foreground md:text-lg">{subheading}</p>
          )}
        </div>
      )
    }
    <div class:list={["grid gap-6", colsClass]}>
      {
        items.map((item) => (
          <div class="rounded-xl border border-gray-200 shadow-sm p-6 bg-white">
            {item.icon && (
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-blue-100 to-purple-100 text-purple-600 mb-4">
                <item.icon size={20} />
              </div>
            )}
            <h3 class="font-semibold text-gray-900">{item.title}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{item.description}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
