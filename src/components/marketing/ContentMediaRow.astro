---
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";

interface Cta {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  reverse?: boolean;
  cta?: Cta;
  class?: string;
}

const { eyebrow, title, reverse = false, cta, class: className } = Astro.props;
---

<section class:list={["w-full py-12 md:py-16", className]}>
  <Container>
    <div class="grid items-center gap-10 lg:gap-16 lg:grid-cols-2">
      <div class:list={["space-y-4", reverse && "lg:order-last"]}>
        {eyebrow && <Badge color="indigo">{eyebrow}</Badge>}
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">{title}</h2>
        <div class="space-y-3 text-muted-foreground md:text-lg/relaxed">
          <slot />
        </div>
        {
          cta && (
            <a
              href={cta.href}
              class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
              {cta.label}
              <span aria-hidden="true">→</span>
            </a>
          )
        }
      </div>
      <div class="w-full">
        <slot name="media" />
      </div>
    </div>
  </Container>
</section>
