---
import Container from "@components/container.astro";

interface Cta {
  label: string;
  href: string;
}

interface Props {
  title: string;
  reverse?: boolean;
  cta?: Cta;
  caption?: string;
  class?: string;
}

const { title, reverse = false, cta, caption, class: className } = Astro.props;

const hasMedia = Astro.slots.has("media");
---

<section class:list={["w-full py-12 md:py-16", className]}>
  <Container>
    <div
      class:list={[
        "grid items-center gap-10 lg:gap-16",
        hasMedia ? "lg:grid-cols-2" : "max-w-3xl",
      ]}>
      <div class:list={["space-y-4", reverse && hasMedia && "lg:order-last"]}>
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">{title}</h2>
        <div class="space-y-3 text-muted-foreground md:text-lg/relaxed">
          <slot />
        </div>
        {
          cta && (
            <a
              href={cta.href}
              class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
              {cta.label}
              <span aria-hidden="true">→</span>
            </a>
          )
        }
      </div>
      {
        hasMedia && (
          <div class="w-full">
            <slot name="media" />
            {caption && <p class="mt-2 text-xs text-gray-400">{caption}</p>}
          </div>
        )
      }
    </div>
  </Container>
</section>
