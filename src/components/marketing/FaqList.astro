---
import Container from "@components/container.astro";

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  items: FaqItem[];
  class?: string;
}

const {
  heading = "Frequently asked questions",
  subheading,
  items,
  class: className,
} = Astro.props;
---

<section class:list={["w-full py-12 md:py-16", className]}>
  <Container>
    <div class="max-w-3xl mx-auto">
      {
        (heading || subheading) && (
          <div class="mb-8 md:mb-10">
            {heading && (
              <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
                {heading}
              </h2>
            )}
            {subheading && (
              <p class="mt-3 text-muted-foreground md:text-lg">{subheading}</p>
            )}
          </div>
        )
      }
      <dl class="divide-y divide-gray-200 border-t border-gray-200">
        {
          items.map((item) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
                <dt class="font-semibold text-gray-900">{item.question}</dt>
                <span
                  aria-hidden="true"
                  class="shrink-0 text-purple-500 transition-transform group-open:rotate-45">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round">
                    <line x1="10" y1="4" x2="10" y2="16" />
                    <line x1="4" y1="10" x2="16" y2="10" />
                  </svg>
                </span>
              </summary>
              <dd
                class="mt-3 text-muted-foreground md:text-lg/relaxed"
                set:html={item.answer}
              />
            </details>
          ))
        }
      </dl>
    </div>
  </Container>
</section>
