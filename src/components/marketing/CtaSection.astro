---
interface Cta {
  label: string;
  href: string;
}

interface Props {
  heading: string;
  subheading?: string;
  primaryCta?: Cta | null;
  secondaryCta?: Cta | null;
  dark?: boolean;
}

const { heading, subheading, dark = true } = Astro.props;

const defaultPrimary: Cta = {
  label: "Launch epanet-js",
  href: "https://app.epanetjs.com",
};
const defaultSecondary: Cta = {
  label: "Book a demo",
  href: "https://cal.com/epanet-js/",
};

const primaryCta =
  Astro.props.primaryCta === undefined ? defaultPrimary : Astro.props.primaryCta;
const secondaryCta =
  Astro.props.secondaryCta === undefined
    ? defaultSecondary
    : Astro.props.secondaryCta;
---

<section
  class:list={[
    "w-full py-12 md:py-16",
    dark ? "bg-gray-800 text-white" : "bg-gradient-to-br from-blue-50 to-purple-100",
  ]}>
  <div class="container mx-auto px-4 md:px-6 text-center">
    <h2 class="text-2xl md:text-3xl font-bold tracking-tight">{heading}</h2>
    {
      subheading && (
        <p
          class:list={[
            "max-w-[600px] mx-auto mt-4 md:text-lg",
            dark ? "text-gray-200" : "text-muted-foreground",
          ]}>
          {subheading}
        </p>
      )
    }
    <div class="flex flex-col gap-3 sm:flex-row justify-center mt-8">
      {
        primaryCta && (
          <a
            href={primaryCta.href}
            class:list={[
              "inline-flex items-center justify-center rounded-md px-7 py-3 text-sm font-medium transition-colors",
              dark
                ? "bg-white text-gray-900 hover:bg-gray-100"
                : "text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700",
            ]}>
            {primaryCta.label}
          </a>
        )
      }
      {
        secondaryCta && (
          <a
            href={secondaryCta.href}
            class:list={[
              "inline-flex items-center justify-center rounded-md px-7 py-3 text-sm font-medium border transition-colors",
              dark
                ? "border-gray-500 text-white hover:bg-gray-700"
                : "border-gray-300 text-gray-700 hover:bg-white/60",
            ]}>
            {secondaryCta.label}
          </a>
        )
      }
    </div>
  </div>
</section>
