---
import { Dropdown as NavDropdown, DropdownItems } from "astro-navbar";
import type { NavColumn } from "@config/navigation";

interface Props {
  title: string;
  columns: NavColumn[];
  hubHref?: string;
  lastItem?: boolean;
  width?: "sm" | "lg";
}

const { title, columns, hubHref, lastItem = false, width = "lg" } = Astro.props;

const colCount = columns.length;
const panelWidth = width === "lg" ? "lg:w-[560px]" : "lg:w-[300px]";
const gridCols = colCount >= 2 ? "lg:grid-cols-2" : "lg:grid-cols-1";
---

<li class="relative z-50 isolate">
  <NavDropdown class="group">
    <button
      class="flex items-center gap-1 text-sm w-full lg:w-auto transition lg:px-3 py-2 text-gray-600 hover:text-indigo-600 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-indigo-500 focus-visible:outline-none focus-visible:shadow-outline-indigo rounded-full">
      <span>{title}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="3"
        stroke="currentColor"
        class="w-3 h-3 mt-0.5 group-open:rotate-180">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
      </svg>
    </button>
    <DropdownItems>
      <div
        class:list={[
          "lg:absolute w-full z-50 border-l lg:border-0 border-slate-200",
          panelWidth,
          lastItem ? "lg:right-0 origin-top-right" : "lg:left-0 origin-top-left",
        ]}>
        <div
          class="px-3 py-2 lg:p-4 lg:bg-white lg:rounded-xl lg:shadow-lg lg:border lg:border-gray-100">
          <div class:list={["grid grid-cols-1 gap-x-6 gap-y-1", gridCols]}>
            {
              columns.map((column) => (
                <div class="flex flex-col">
                  {column.heading && (
                    <p class="px-3 lg:px-2 pt-2 pb-1 text-[0.7rem] font-semibold uppercase tracking-wide text-gray-400">
                      {column.heading}
                    </p>
                  )}
                  {column.items.map((item) => (
                    <a
                      href={item.href}
                      target={item.external ? "_blank" : undefined}
                      rel={item.external ? "noopener noreferrer" : undefined}
                      class="group/item flex items-start gap-3 rounded-lg px-3 lg:px-2 py-2 hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-indigo-500 focus-visible:outline-none transition-colors">
                      {item.icon && (
                        <span class="mt-0.5 flex items-center justify-center w-8 h-8 shrink-0 rounded-lg bg-gradient-to-br from-blue-100 to-purple-100 text-purple-600">
                          <item.icon size={16} />
                        </span>
                      )}
                      <span class="flex flex-col">
                        <span class="text-sm font-medium text-gray-800 group-hover/item:text-indigo-600">
                          {item.label}
                        </span>
                        {item.description && (
                          <span class="text-xs text-gray-500 leading-snug">
                            {item.description}
                          </span>
                        )}
                      </span>
                    </a>
                  ))}
                </div>
              ))
            }
          </div>
          {
            hubHref && (
              <a
                href={hubHref}
                class="mt-2 lg:mt-3 flex items-center gap-1 px-3 lg:px-2 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-800 border-t border-gray-100 lg:pt-3 transition-colors">
                View all {title.toLowerCase()}
                <span aria-hidden="true">→</span>
              </a>
            )
          }
        </div>
      </div>
    </DropdownItems>
  </NavDropdown>
</li>
