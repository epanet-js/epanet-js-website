---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import Media from "@components/marketing/Media.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";
import LocalFirstFlowDemo from "@components/demos/LocalFirstFlowDemo.astro";
import FileTransferDemo from "@components/demos/FileTransferDemo.astro";
import CloudOptionalDemo from "@components/demos/CloudOptionalDemo.astro";
import TeamAccessDemo from "@components/demos/TeamAccessDemo.astro";
import EncryptedTransitDemo from "@components/demos/EncryptedTransitDemo.astro";
import CloudYourStorageDiagram from "@components/demos/CloudYourStorageDiagram.astro";
import OnPremDeploymentDiagram from "@components/demos/OnPremDeploymentDiagram.astro";
import { Cloud, Database, HardDrive, Server } from "lucide-react";

export const prerender = true;
const lang = "en";

const setups = [
  {
    id: "local-files",
    icon: HardDrive,
    title: "Keep everything on your machine",
    description:
      "No cloud at all. Files on your file system, shared the way you already share them.",
    enterprise: false,
  },
  {
    id: "cloud-sharing",
    icon: Cloud,
    title: "Share models through the cloud",
    description:
      "One synced copy of the model, workspace roles, encrypted in transit.",
    enterprise: false,
  },
  {
    id: "your-storage",
    icon: Database,
    title: "Bring your own storage",
    description: "We run the app; model data stays in storage you manage.",
    enterprise: true,
  },
  {
    id: "on-premises",
    icon: Server,
    title: "Run it on-premises",
    description: "The whole deployment inside your own network.",
    enterprise: true,
  },
];

const linkClass =
  "text-indigo-600 hover:text-indigo-800 underline hover:no-underline";
---

<Layout
  title="Security"
  description="Where your model data lives is up to you: on your machine by default, shared through our cloud, in storage you manage, or deployed on-premises."
  lang={lang}>
  <PageHero
    title="Security and privacy by design"
    subtitle="Network models often contain sensitive infrastructure data, so you choose where yours lives. This page walks through the four ways teams run epanet-js, from files on your machine to a deployment inside your own network."
    primaryCta={{ label: "Contact us", href: "mailto:support@epanetjs.com" }}
    secondaryCta={{ label: "Read our privacy policy", href: "/privacy-policy" }}
    align="center"
  />

  <section class="w-full py-10 md:py-12">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Find your setup
        </h2>
        <p class="mt-3 text-muted-foreground md:text-lg">
          Four ways to run epanet-js, ordered from most local to most managed.
          Jump to the one that sounds like you.
        </p>
      </div>
      <nav aria-label="Choose your setup" class="mt-8">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            setups.map((setup) => (
              <a
                href={`#${setup.id}`}
                class="group flex flex-col rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-purple-300 hover:shadow-md">
                <div class="flex items-center justify-between gap-2">
                  <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                    <setup.icon size={18} />
                  </span>
                  {setup.enterprise && (
                    <Badge
                      color="purple"
                      class="whitespace-nowrap !px-2 !py-0.5 !text-[11px]">
                      Enterprise
                    </Badge>
                  )}
                </div>
                <p class="mt-3 font-semibold text-gray-900">
                  {setup.title}
                </p>
                <p class="mt-1 text-sm text-muted-foreground">
                  {setup.description}
                </p>
              </a>
            ))
          }
        </div>
      </nav>
    </Container>
  </section>

  <section id="local-files" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Keep everything on your machine
        </h2>
        <p class="mt-3 text-muted-foreground md:text-lg">
          This is the default. Projects are created, run, and saved on your
          machine, and nothing is uploaded to our servers.
        </p>
      </div>
    </Container>

    <ContentMediaRow
      headingLevel="h3"
      title="A project file on your file system">
      <p>
        An epanet-js model is a standard file. It lives on your disk or a
        network drive, the same way WaterGEMS and InfoWater keep their project
        files.
      </p>
      <p>
        The application loads over HTTPS, but your model stays where you saved
        it and simulations run on your machine. Neither your network data nor
        your customer data touches our servers.
      </p>
      <LocalFirstFlowDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow
      headingLevel="h3"
      title="Share models the way you already do"
      reverse>
      <p>
        Email a model to a colleague, put it on a shared drive, or copy it to a
        USB stick. Whoever receives the file opens it and picks up where you
        left off.
      </p>
      <p>
        Because there is no new data pathway, your existing IT policies and
        approval processes keep applying as they are.
      </p>
      <FileTransferDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow headingLevel="h3" title="Open source you can inspect">
      <p>
        You don't have to take our word for any of this. The epanet-js source
        code is public from day one under the Functional Source License and
        becomes fully open source (MIT) after two years.
      </p>
      <p>Anyone can review how the application handles your data.</p>
      <Media
        slot="media"
        src="/assets/landing/github-open-source.webp"
        alt="The public epanet-js source repository on GitHub."
        frame={false}
      />
    </ContentMediaRow>

    <Container>
      <div
        class="max-w-3xl rounded-xl border border-gray-200 bg-gray-50 p-5 md:p-6">
        <p class="font-semibold text-gray-900">
          If this is your setup, you can stop reading here.
        </p>
        <p class="mt-2 text-muted-foreground">
          Cloud features are opt-in per project. If you never turn them on, the
          three setups below never touch your data.
        </p>
      </div>
    </Container>
  </section>

  <section id="cloud-sharing" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Share models through the cloud
        </h2>
        <p class="mt-3 text-muted-foreground md:text-lg">
          When a team wants one model available across devices and people,
          cloud projects keep every copy in sync. Turning on the cloud for one
          project changes nothing for the rest.
        </p>
      </div>
    </Container>

    <ContentMediaRow headingLevel="h3" title="One synced source of truth">
      <p>
        A cloud project has a single source of truth. Every device works
        against the same copy, so nobody hunts through email threads for the
        current version of the model.
      </p>
      <p>
        The sync point can be our managed cloud or, for enterprise customers,
        one of the deployments described below.
      </p>
      <CloudOptionalDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow
      headingLevel="h3"
      title="Workspace roles control who can open it"
      reverse>
      <p>
        Models stored in the cloud belong to your workspace, and access to them
        is explicit. Every member has a role: editors can change a model,
        viewers can only read it.
      </p>
      <p>
        Invite a colleague by email, change their role, or remove them from the
        workspace, and their access changes with it. Nobody outside your
        workspace can see your network.
      </p>
      <TeamAccessDemo
        slot="media"
        class="w-full max-w-[340px] mx-auto [zoom:1.2]"
      />
    </ContentMediaRow>

    <ContentMediaRow headingLevel="h3" title="Encrypted in transit">
      <p>
        Everything that moves between your machine and epanet-js travels over
        HTTPS and is encrypted with TLS. That covers loading the application
        itself as well as any model data you choose to sync through a cloud
        project.
      </p>
      <EncryptedTransitDemo slot="media" />
    </ContentMediaRow>
  </section>

  <section id="your-storage" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3">
          <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
            Bring your own storage
          </h2>
          <Badge color="purple">Enterprise</Badge>
        </div>
        <p class="mt-3 text-muted-foreground md:text-lg">
          An option for enterprise customers: we host and run the application,
          and your model data lives in a storage layer your organization
          manages, such as your own S3 bucket. To set it up, email
          <a href="mailto:sales@epanetjs.com" class={linkClass}
            >sales@epanetjs.com</a
          > or <a href="https://cal.com/epanet-js/" class={linkClass}
            >book a call</a
          >.
        </p>
      </div>
    </Container>

    <ContentMediaRow
      headingLevel="h3"
      title="We run the app, you hold the data"
      reverse>
      <p>
        You get the managed application, kept up to date by us, without running
        any servers yourselves. Model reads and writes go to storage you
        control.
      </p>
      <p>
        Retention, data region, and access policies are set by you, in your own
        account. We operate the application; we don't hold your data.
      </p>
      <CloudYourStorageDiagram slot="media" />
    </ContentMediaRow>
  </section>

  <section id="on-premises" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3">
          <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
            Run it on-premises
          </h2>
          <Badge color="purple">Enterprise</Badge>
        </div>
        <p class="mt-3 text-muted-foreground md:text-lg">
          Also an enterprise option: the entire deployment, application and
          data, runs inside your own network. To talk it through, email
          <a href="mailto:sales@epanetjs.com" class={linkClass}
            >sales@epanetjs.com</a
          > or <a href="https://cal.com/epanet-js/" class={linkClass}
            >book a call</a
          >.
        </p>
      </div>
    </Container>

    <ContentMediaRow
      headingLevel="h3"
      title="Everything inside your network boundary">
      <p>
        epanet-js runs on your own infrastructure, behind your firewall, under
        your governance. Network data is often treated as sensitive
        critical-infrastructure information, and an on-premises deployment
        keeps all of it within your environment.
      </p>
      <p>
        If you have a security questionnaire or specific compliance
        requirements, we're happy to work through them with you directly.
      </p>
      <OnPremDeploymentDiagram slot="media" />
    </ContentMediaRow>
  </section>

  <section class="w-full py-12 md:py-16 bg-gray-50">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Found a security issue?
        </h2>
        <p class="mt-4 text-muted-foreground md:text-lg">
          We take security reports seriously. If you believe you've found a
          vulnerability, please email us at <a
            href="mailto:support@epanetjs.com"
            class={linkClass}>support@epanetjs.com</a
          > and we'll work with you to investigate and resolve it. For questions
          about how we handle your data, see our <a
            href="/privacy-policy"
            class={linkClass}>Privacy Policy</a
          > and <a href="/cookies-policy" class={linkClass}>Cookies Policy</a>.
        </p>
      </div>
    </Container>
  </section>

  <CtaSection
    heading="Questions about security or compliance?"
    subheading="Talk to us about security questionnaires, customer-managed storage, or an on-premises deployment. We're glad to help."
    primaryCta={{ label: "Book a call", href: "https://cal.com/epanet-js/" }}
    secondaryCta={{ label: "Email us", href: "mailto:support@epanetjs.com" }}
  />
</Layout>
