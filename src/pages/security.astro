---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import Media from "@components/marketing/Media.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";
import LocalFirstFlowDemo from "@components/demos/LocalFirstFlowDemo.astro";
import FileTransferDemo from "@components/demos/FileTransferDemo.astro";
import CloudOptionalDemo from "@components/demos/CloudOptionalDemo.astro";
import TeamAccessDemo from "@components/demos/TeamAccessDemo.astro";
import DataRegionsDemo from "@components/demos/DataRegionsDemo.astro";
import EncryptedTransitDemo from "@components/demos/EncryptedTransitDemo.astro";
import CloudYourStorageDiagram from "@components/demos/CloudYourStorageDiagram.astro";
import OnPremDeploymentDiagram from "@components/demos/OnPremDeploymentDiagram.astro";
import { Cloud, Database, HardDrive, Server } from "lucide-react";

export const prerender = true;
const lang = "en";

const setups = [
  {
    id: "local-files",
    icon: HardDrive,
    title: "Run on your machine",
    description:
      "No cloud at all. Files on your file system, shared the way you already share them.",
    enterprise: null,
  },
  {
    id: "cloud-sharing",
    icon: Cloud,
    title: "Share models through the cloud",
    description:
      "One synced copy of the model, workspace roles, encrypted in transit.",
    enterprise: "Teams",
  },
  {
    id: "your-storage",
    icon: Database,
    title: "Bring your own storage",
    description: "We run the app; model data stays in storage you manage.",
    enterprise: "Enterprise",
  },
  {
    id: "on-premises",
    icon: Server,
    title: "Run it on-premises",
    description: "The whole deployment inside your own network.",
    enterprise: "Enterprise",
  },
];

const linkClass =
  "text-indigo-600 hover:text-indigo-800 underline hover:no-underline";
---

<Layout
  title="Security"
  description="Where your model data lives is up to you: on your machine by default, shared through our cloud, in storage you manage, or deployed on-premises."
  lang={lang}>
  <PageHero
    title="Security and privacy by design"
    subtitle="Protecting critical infrastructure data and private customer information requires absolute control. This page outlines our four deployment models, giving you the flexibility to keep data isolated on your machine, sync it securely via the cloud, or run it entirely within your own network."
    primaryCta={{ label: "Contact us", href: "mailto:support@epanetjs.com" }}
    secondaryCta={{ label: "Read our privacy policy", href: "/privacy-policy" }}
    align="center"
  />

  <section class="w-full py-10 md:py-12">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Find your setup
        </h2>
        <p class="mt-3 text-muted-foreground md:text-lg">
          Four deployment models ranging from local execution to custom enterprise architectures.
          Select the configuration that aligns with your organization's security and compliance requirements.
        </p>
      </div>
      <nav aria-label="Choose your setup" class="mt-8">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            setups.map((setup) => (
              <a
                href={`#${setup.id}`}
                class="group flex flex-col rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-purple-300 hover:shadow-md">
                <div class="flex items-center justify-between gap-2">
                  <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-purple-50 text-purple-600">
                    <setup.icon size={18} />
                  </span>
                  {setup.enterprise && (
                    <Badge
                      color="purple"
                      class="whitespace-nowrap !px-2 !py-0.5 !text-[11px]">
                      {setup.enterprise}
                    </Badge>
                  )}
                </div>
                <p class="mt-3 font-semibold text-gray-900">
                  {setup.title}
                </p>
                <p class="mt-1 text-sm text-muted-foreground">
                  {setup.description}
                </p>
              </a>
            ))
          }
        </div>
      </nav>
    </Container>
  </section>

  <section id="local-files" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Run on your machine
        </h2>
        <p class="mt-3 text-muted-foreground md:text-lg">
          By default, your hydraulic modeling projects are created, run, and saved entirely on your machine. Nothing is ever uploaded to our servers.
        </p>
      </div>
    </Container>

    <ContentMediaRow
      headingLevel="h3"
      title="Project files stay on your local drive">
      <p>
        An epanet-js model is simply a file on your hard drive or network drive, just like 
        the project files used in other traditional modeling software packages like WaterGEMS and InfoWater.
      </p>
      <p>
      While the app loads over HTTPS, your model stays put and simulations run entirely in your browser. Neither your network nor
      customer data ever touches our servers—once loaded, you can even disconnect from the internet and work completely offline.

      </p>
      <LocalFirstFlowDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow
      headingLevel="h3"
      title="Share models the way you already do"
      reverse>
      <p>
        Email a model to a colleague, put it on a shared drive, or copy it to a
        USB stick. Whoever receives the file opens it and picks up where you
        left off.
      </p>
      <p>
        No new data pathways means your current company security policies apply automatically.
      </p>
      <FileTransferDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow headingLevel="h3" title="Open source you can inspect">
      <p>
        You don't have to take our word for any of this. The epanet-js source
        code is public from day one under the Functional Source License and
        becomes fully open source (MIT) after two years.
      </p>
      <p>Anyone can review how the application handles your data. <a href="https://github.com/epanet-js/epanet-js" class={linkClass} target="_blank" rel="noopener noreferrer">Explore the repository</a> to audit the code yourself.</p>
      <Media
        slot="media"
        src="/assets/landing/github-open-source.webp"
        alt="The public epanet-js source repository on GitHub."
        frame={false}
      />
    </ContentMediaRow>

    <Container>
      <div
        class="max-w-3xl rounded-xl border border-gray-200 bg-gray-50 p-5 md:p-6">
        <p class="font-semibold text-gray-900">
          Only need local modeling? You're all set.
        </p>
        <p class="mt-2 text-muted-foreground">
          Cloud features are entirely opt-in on a per-project basis. If you choose never to enable them, your infrastructure and customer
          data remain 100% isolated on your machine. If you are looking for shared cloud workspaces or a dedicated enterprise deployment,
          keep reading to see how they work.
        </p>
      </div>
    </Container>
  </section>

  <section id="cloud-sharing" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
    
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3">
          <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
            Share models through the cloud
          </h2>
          <Badge color="purple">Teams</Badge>
        </div>
        <p class="mt-3 text-muted-foreground md:text-lg">
          When a team wants one model available across devices and people, cloud projects keep every copy in sync. Turning on the cloud
          for one project changes nothing for the rest, which remain entirely local.
        </p>
      </div>
    </Container>

    <ContentMediaRow headingLevel="h3" title="One synced source of truth">
      <p>
        A cloud project has a single source of truth. Every device works
        against the same copy, so nobody hunts through email threads for the
        current version of the model.
      </p>
      <p>
        By default, the sync point is our secure, managed cloud, allowing you to choose
        the data region that meets your local compliance requirements. For enterprise teams,
        you also have the option to host and control your own data entirely.
      </p>
      <CloudOptionalDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow
      headingLevel="h3"
      title="Select your data region"
      reverse>
      <p>
        You decide which geographic region handles your data. When a user
        uploads or syncs a model, that data remains entirely within their
        selected region.
      </p>
      <p>
        This guarantees your team strictly complies with local data residency
        and privacy mandates.
      </p>
      <DataRegionsDemo slot="media" />
    </ContentMediaRow>

    <ContentMediaRow
      headingLevel="h3"
      title="Workspace roles control who can open it">
      <p>
        Models stored in the cloud belong to your workspace, and access to them
        is explicit. Every member has a role: editors can change a model,
        viewers can only read it.
      </p>
      <p>
        Invite a colleague by email, change their role, or remove them from the
        workspace, and their access changes with it. Nobody outside your
        workspace can see your network.
      </p>
      <TeamAccessDemo
        slot="media"
        class="w-full max-w-[340px] mx-auto [zoom:1.2]"
      />
    </ContentMediaRow>

    <ContentMediaRow
      headingLevel="h3"
      title="Encrypted in transit and at rest"
      reverse>
      <p>
        Data security is enforced at every stage. Everything moving between your machine and epanet-js
        travels over HTTPS and is encrypted with TLS.
      </p>
      <p>
        For cloud projects, any model data stored on our servers is fully encrypted at
        rest using industry-standard encryption (AES-256). This covers both the application itself and
        any project data you choose to sync.
      </p>
      <EncryptedTransitDemo slot="media" />
    </ContentMediaRow>
  </section>

  <section id="your-storage" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3">
          <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
            Bring your own storage
          </h2>
          <Badge color="purple">Enterprise</Badge>
        </div>
        <p class="mt-3 text-muted-foreground md:text-lg">
          Retain absolute ownership of your data without the overhead of hosting software.
          Under this enterprise option, we host and manage the application, but your project
          files are written directly to your organization's own cloud object storage—such as
          Amazon S3, Azure Blob Storage, or any S3-compatible service.
          
          </p>
          <p class="mt-3 text-muted-foreground md:text-lg">
          To configure your own storage layer, email us at <a href="mailto:sales@epanetjs.com" class={linkClass}
            >sales@epanetjs.com</a
          > or <a href="https://cal.com/epanet-js/" class={linkClass}
            >book a call</a
          >.
        </p>
      </div>
    </Container>

    <ContentMediaRow
      headingLevel="h3"
      title="We run the app, you hold the data"
      reverse>
      <p>
        You get a fully managed web application that is kept up to date by us, without your team
        needing to spin up or maintain servers. All model reads and writes route directly to storage
        environments you control.
      </p>
      <p>
        Because the data layer lives inside your own corporate cloud account, data retention, geographic
        residency regions, and access policies are set entirely by you. We operate the application interface;
        we never hold your data.
      </p>
      <CloudYourStorageDiagram slot="media" />
    </ContentMediaRow>
  </section>

  <section id="on-premises" class="scroll-mt-24 pt-12 md:pt-16">
    <Container>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3">
          <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
            Run it on-premises
          </h2>
          <Badge color="purple">Enterprise</Badge>
        </div>
        <p class="mt-3 text-muted-foreground md:text-lg">
          For total data sovereignty and air-gapped environments, the entire epanet-js stack—both
          the application and the data layer—can be deployed directly inside your corporate infrastructure.
          This option is built for organizations that require complete network isolation.
          
          </p>
          <p class="mt-3 text-muted-foreground md:text-lg">
          To discuss an on-premises deployment for your team, email us at <a href="mailto:sales@epanetjs.com" class={linkClass}
            >sales@epanetjs.com</a
          > or <a href="https://cal.com/epanet-js/" class={linkClass}
            >book a call</a
          >.
        </p>
      </div>
    </Container>

    <ContentMediaRow
      headingLevel="h3"
      title="Total control behind your firewall">
      <p>
        The platform runs entirely on your own servers, behind your security perimeter, and strictly under your own IT governance.
      </p>
      <p>
        An on-premises deployment guarantees that all application traffic, hydraulic models, and private customer data remain fully
        self-contained within your network boundary, with zero external data dependencies or required internet access.
      </p>
      <OnPremDeploymentDiagram slot="media" />
    </ContentMediaRow>
  </section>

  <section class="w-full py-12 md:py-16 bg-gray-50">
    <Container>
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
          Found a security issue?
        </h2>
        <p class="mt-4 text-muted-foreground md:text-lg">
          We take security reports seriously. If you believe you've found a
          vulnerability, please email us at <a
            href="mailto:support@epanetjs.com"
            class={linkClass}>support@epanetjs.com</a
          > and we'll work with you to investigate and resolve it. For questions
          about how we handle your data, see our <a
            href="/privacy-policy"
            class={linkClass}>Privacy Policy</a
          > and <a href="/cookies-policy" class={linkClass}>Cookies Policy</a>.
        </p>
      </div>
    </Container>
  </section>

  <CtaSection
    heading="Questions about security or compliance?"
    subheading="Talk to us about security questionnaires, customer-managed storage, or an on-premises deployment. We're glad to help."
    primaryCta={{ label: "Book a call", href: "https://cal.com/epanet-js/" }}
    secondaryCta={{ label: "Email us", href: "mailto:support@epanetjs.com" }}
  />
</Layout>
