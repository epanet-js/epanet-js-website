---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ProseSection from "@components/marketing/ProseSection.astro";
import PullQuote from "@components/marketing/PullQuote.astro";
import BenefitGrid from "@components/marketing/BenefitGrid.astro";
import CardGrid from "@components/marketing/CardGrid.astro";
import FaqList from "@components/marketing/FaqList.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import { whoItsFor, solutions } from "@config/navigation";
import { Zap, Lock, Cpu, Scale } from "lucide-react";

export const prerender = true;
const lang = "en";

const liveColumn = solutions.columns.find((c) => c.heading === "Available now");

const benefits = [
  {
    icon: Zap,
    title: "Speed to a working model",
    description:
      "Whatever you do with the network, you get from data to a running model in minutes, not weeks.",
  },
  {
    icon: Lock,
    title: "Own your data",
    description:
      "Local-first by default. Your network — or your client's — stays on your machine unless you choose otherwise.",
  },
  {
    icon: Cpu,
    title: "The real EPANET engine",
    description:
      "The same trusted engine the industry runs, so skills and models carry across teams and tools.",
  },
  {
    icon: Scale,
    title: "Affordable and open",
    description:
      "A free tier, free for education, fair per-seat pricing, and source that's public from day one.",
  },
];

const faqs = [
  {
    question: "Is there a free option?",
    answer:
      "Yes. You can launch epanet-js and build models on the free tier without logging in. Paid plans add professional features and team licensing — see <a href=\"/pricing\">pricing</a>.",
  },
  {
    question: "Is it really free for education?",
    answer:
      "Students and teachers get free access for non-commercial learning and coursework, with eligibility detected from your school email. See <a href=\"/who-its-for/education\">education</a> for how it works.",
  },
  {
    question: "Do you support humanitarian and nonprofit work?",
    answer:
      "Yes — affordable and free options mean more of your funding reaches the communities you serve. Tell us about your project on the <a href=\"/who-its-for/humanitarian-ngos\">humanitarian &amp; NGOs</a> page.",
  },
  {
    question: "How does licensing work for a team?",
    answer:
      "Teams use shared, per-seat licensing with self-service seat management and invoicing. The full breakdown is on the <a href=\"/pricing\">pricing page</a>.",
  },
  {
    question: "Can consultants keep client data confidential?",
    answer:
      "Yes. Because epanet-js is local-first, sensitive client data stays on your machine rather than someone else's cloud. Read more on <a href=\"/security\">security</a>.",
  },
];
---

<Layout
  title="Who it's for"
  description="Whatever your role — utility, consultant, educator, or NGO — epanet-js helps you build and use hydraulic models faster, keep your data in your hands, and work on the trusted EPANET engine."
  lang={lang}>
  <PageHero
    title="Whatever your role, get to the answer faster"
    subtitle="epanet-js is built for everyone who works with water networks — from utilities running the system every day to students learning the craft. Find your fit."
    align="center"
  />

  <ProseSection
    title="Different jobs, the same need"
    align="center">
    <p>
      A utility operator, a consultant on a deadline, a professor in a computer
      lab, and an engineer designing a community supply are doing very different
      work. What they share is the need to get to a trustworthy model quickly,
      keep their data in their hands, and not have the software get in the way.
    </p>
    <p>
      That's what epanet-js is built for. The same tool serves all of them
      because it's fast to a working model, local-first, runs anywhere, and is
      built on the EPANET engine the whole industry already trusts.
    </p>
  </ProseSection>

  <PullQuote>
    The fastest, easiest way to build and use hydraulic models — whoever you are
    and wherever you work.
  </PullQuote>

  <CardGrid items={whoItsFor.columns[0].items} columns={4} />

  <BenefitGrid
    heading="The common ground, whatever your role"
    items={benefits}
    columns={4}
  />

  <ProseSection
    title="Backed by utilities, consultancies, and the community">
    <p>
      epanet-js is built in the open with the people who use it. Our founding
      partners span the industry — <strong>Affinity Water</strong> and
      <strong>Anglian Water</strong> among the utilities,
      <strong>AtkinsRéalis</strong> among the global consultancies, and
      <strong>Optimatics</strong>, with three decades helping utilities optimize
      their networks.
    </p>
    <p>
      Around them is a growing community of more than 2,000 registered members,
      university courses teaching on the tool, and a workshop run with the US EPA
      at the 2026 World Environmental &amp; Water Resources Congress.
    </p>
  </ProseSection>

  <PullQuote>
    We believe the future of hydraulic modeling should be built in the open.
  </PullQuote>

  <CtaSection
    heading="Ready to see it for your team?"
    subheading="Launch epanet-js free in your browser, or book a demo tailored to how you work."
    dark={false}
  />

  {
    liveColumn && (
      <CardGrid
        heading="See what epanet-js can do"
        subheading="The everyday jobs the tool helps teams get done."
        items={liveColumn.items}
        columns={4}
      />
    )
  }

  <FaqList
    subheading="Common questions about fit, access, and pricing."
    items={faqs}
  />

  <CtaSection
    heading="Find your fit"
    subheading="Whatever your role, the fastest way to see it is to try it. Launch epanet-js free, or book a demo."
  />
</Layout>
