---
import Layout from "@layouts/Layout.astro";
import HomeRedesign from "@components/landing/HomeRedesign.astro";
import HomeLegacy from "@components/landing/HomeLegacy.astro";
import { showRedesignedHome } from "@config/feature-flags";

export const prerender = false;
const lang = "en";
---

<Layout footerMargin={false} lang={lang}>
  {showRedesignedHome ? <HomeRedesign lang={lang} /> : <HomeLegacy lang={lang} />}
</Layout>
