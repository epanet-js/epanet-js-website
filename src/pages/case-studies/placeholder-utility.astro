---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import Media from "@components/marketing/Media.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import Container from "@components/container.astro";
import Badge from "@components/ui/badge.astro";
import ScenarioCompareDemo from "@components/demos/ScenarioCompareDemo.astro";
import { TriangleAlert } from "lucide-react";

export const prerender = true;
const lang = "en";

// PLACEHOLDER PAGE — example content to preview the case-study layout.
// Replace the story, quotes, and stats with a real customer story before
// linking this page anywhere beyond the case-studies index.
const stats = [
  { value: "3 weeks → 2 days", label: "Time to a working model" },
  { value: "1", label: "Shared model the whole team uses" },
  { value: "0", label: "Installs or IT tickets" },
];
---

<Layout
  title="Utility cuts model build time from weeks to days"
  description="Placeholder case study — example content to preview the layout."
  lang={lang}
  noindex>
  <div class="w-full bg-amber-50 border-b border-amber-200">
    <Container>
      <p class="flex items-center gap-2 py-3 text-sm text-amber-800">
        <TriangleAlert size={16} className="shrink-0" />
        <span>
          <strong>Placeholder case study.</strong> This is example content to
          preview the layout — a real customer story will replace it before
          launch.
        </span>
      </p>
    </Container>
  </div>

  <PageHero
    title="Utility cuts model build time from weeks to days"
    subtitle="How a mid-size water utility went from scattered GIS exports and an out-of-date hydraulic study to a model the whole team runs in the browser."
    primaryCta={null}
    secondaryCta={null}
    align="center">
  </PageHero>

  <section class="w-full pb-12 md:pb-16 -mt-4">
    <Container>
      <div class="flex justify-center mb-10">
        <Badge color="purple">Utility</Badge>
      </div>
      <div class="grid gap-6 sm:grid-cols-3 max-w-3xl mx-auto">
        {
          stats.map((stat) => (
            <div class="rounded-xl border border-gray-200 shadow-sm bg-white p-6 text-center">
              <p class="text-xl font-bold tracking-tight bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                {stat.value}
              </p>
              <p class="mt-2 text-sm text-muted-foreground">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <ContentMediaRow title="The starting point">
    <p>
      The utility's last full hydraulic study was years old, and the model
      behind it lived with an external consultant. Day-to-day questions — can
      we take this main out of service, will pressures hold during the works —
      went unanswered or waited weeks for an external review.
    </p>
    <p>
      The GIS data was good. What was missing was a way to turn it into a
      model the in-house team could own and run themselves.
    </p>
    <Media
      slot="media"
      src="/assets/landing/Complex.webp"
      alt="A large water network model with colour-coded results across the service area."
    />
  </ContentMediaRow>

  <ContentMediaRow title="From GIS export to running model" reverse>
    <p>
      The team imported their pipe and asset layers directly into epanet-js,
      let auto-junctions and automatic elevations handle the setup, and had a
      connected, running model within two days — work they had budgeted three
      weeks for.
    </p>
    <p>
      Because epanet-js runs in the browser, the model is now something the
      whole team opens like any other tab: no licenses to shuffle, nothing for
      IT to install.
    </p>
    <ScenarioCompareDemo slot="media" />
  </ContentMediaRow>

  <section class="w-full py-12 md:py-16">
    <Container>
      <blockquote
        class="max-w-2xl mx-auto border-l-4 border-purple-300 pl-5 italic text-gray-600 md:text-lg">
        "We used to wait weeks for answers about our own network. Now an
        engineer tests the shutdown in the model before the morning meeting."
        <footer class="mt-3 not-italic text-sm text-gray-500">
          — Example quote, Network Planning Lead
        </footer>
      </blockquote>
    </Container>
  </section>

  <CtaSection
    heading="See it on your own network"
    subheading="Launch epanet-js free in your browser, or book a demo to talk through your utility's needs."
  />
</Layout>
