---
import Features from "@components/landing/features.tsx";
import Hero from "@components/landing/hero.tsx";
import Layout from "@layouts/Layout.astro";
import UserDilemma from "@components/landing/user-dilemma";
import NewsletterCTA from "@components/landing/middle-cta";
import OpenSource from "@components/landing/open-source";
import Pricing from "@components/landing/pricing";
import FrequentlyAskedQuestions from "@components/landing/faq.tsx";
import CTAJustOpen from "@components/landing/cta-just-open.tsx";
import WhyWeBuilt from "@components/landing/why-we-built.tsx";
import BottomCTA from "@components/landing/bottom-cta.tsx";
import MiddleCTA from "@components/landing/newsletter-cta";

export const prerender = true;
const lang = "es";
---

<Layout footerMargin={false} lang={lang}>
  <Hero lang={lang} client:load />
  <UserDilemma lang={lang} />
  <Features lang={lang} client:load />
  <MiddleCTA lang={lang} />
  <OpenSource lang={lang} />
  <Pricing lang={lang} client:load />
  <FrequentlyAskedQuestions lang={lang} client:load />
  <CTAJustOpen lang={lang} />
  <WhyWeBuilt lang={lang} />
  <BottomCTA lang={lang} />
</Layout>
