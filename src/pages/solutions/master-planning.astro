---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import MediaPlaceholder from "@components/marketing/MediaPlaceholder.astro";
import BenefitGrid from "@components/marketing/BenefitGrid.astro";
import CardGrid from "@components/marketing/CardGrid.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import { solutions } from "@config/navigation";
import { CalendarRange, TrendingUp, Network, Wallet } from "lucide-react";

export const prerender = true;
const lang = "en";

const benefits = [
  {
    icon: CalendarRange,
    title: "Plan over the long term",
    description:
      "Understand how your network will perform years into the future as demand and the system evolve.",
  },
  {
    icon: TrendingUp,
    title: "Test growth scenarios",
    description:
      "Model new developments, demand growth, and changing conditions to see where the network needs to keep up.",
  },
  {
    icon: Network,
    title: "Size future infrastructure",
    description:
      "Work out the upgrades and reinforcements your network will need, and when.",
  },
  {
    icon: Wallet,
    title: "Support capital planning",
    description:
      "Build the evidence base for a master plan and prioritise investment with confidence.",
  },
];

const related = solutions.columns
  .flatMap((c) => c.items)
  .filter((i) => i.href !== "/solutions/master-planning")
  .slice(0, 3);
---

<Layout
  title="Master planning"
  description="Plan your water network years ahead with tools to support long-term master planning. Coming soon to epanet-js."
  lang={lang}>
  <PageHero
    eyebrow="Master planning"
    title="Plan your network years ahead"
    subtitle="Understand how your network will perform over the long term, and get the tools you need to build a master plan for your water system with confidence."
    comingSoon
    primaryCta={{ label: "Talk to us", href: "https://cal.com/epanet-js/" }}
    secondaryCta={{ label: "Launch epanet-js", href: "https://app.epanetjs.com" }}>
    <MediaPlaceholder
      slot="media"
      label="Concept: a network evolving over a long planning horizon, with future demand and reinforcement highlighted."
    />
  </PageHero>

  <ContentMediaRow
    eyebrow="The challenge"
    title="The long view is the hardest to model">
    <p>
      Master planning means looking years ahead — accounting for growth, new
      developments, and changing demand — and deciding what to build and when.
      It's some of the most valuable work you do, and the most demanding.
    </p>
    <p>
      epanet-js is building the tools to make long-horizon planning workable, so
      you can turn analysis into a defensible master plan.
    </p>
    <MediaPlaceholder
      slot="media"
      kind="image"
      label="Concept diagram: present-day network vs. a future scenario with growth and required upgrades."
    />
  </ContentMediaRow>

  <BenefitGrid
    eyebrow="What it will do"
    heading="Master planning, the epanet-js way"
    items={benefits}
    columns={4}
  />

  <CardGrid
    heading="Available now"
    subheading="While master planning is in development, explore what you can do today."
    items={related}
    columns={3}
  />

  <CtaSection
    heading="Planning for the long term?"
    subheading="Tell us about your master planning process — it helps shape what we build."
    primaryCta={{ label: "Talk to us", href: "https://cal.com/epanet-js/" }}
    secondaryCta={{ label: "Launch epanet-js", href: "https://app.epanetjs.com" }}
  />
</Layout>
