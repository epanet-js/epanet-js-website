---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import MediaPlaceholder from "@components/marketing/MediaPlaceholder.astro";
import BenefitGrid from "@components/marketing/BenefitGrid.astro";
import CardGrid from "@components/marketing/CardGrid.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import { solutions } from "@config/navigation";
import { Scale, BarChart3, MapPinned, Target } from "lucide-react";

export const prerender = true;
const lang = "en";

const benefits = [
  {
    icon: Target,
    title: "Accurate demand",
    description:
      "Build a representation of demand that reflects how water is really used across your network.",
  },
  {
    icon: BarChart3,
    title: "Profiles and consumption",
    description:
      "Allocate consumption and apply demand profiles so loading matches reality through the day.",
  },
  {
    icon: MapPinned,
    title: "Balanced across zones",
    description:
      "Reconcile metered inflows with consumption so every zone in your network adds up.",
  },
  {
    icon: Scale,
    title: "A trustworthy foundation",
    description:
      "Good demand is the foundation of every result — calibration, planning, and operations all depend on it.",
  },
];

const related = solutions.columns
  .flatMap((c) => c.items)
  .filter((i) => i.href !== "/solutions/flow-balance")
  .slice(0, 3);
---

<Layout
  title="Flow balance"
  description="Build an accurate picture of demand across your network — profiles and consumption allocation. Coming soon to epanet-js."
  lang={lang}>
  <PageHero
    eyebrow="Flow balance"
    title="Build an accurate picture of demand across your network"
    subtitle="Understand the flows in your network and create an accurate representation of demand — profiles and consumption — so your model reflects how water is really used."
    comingSoon
    primaryCta={{ label: "Talk to us", href: "https://cal.com/epanet-js/" }}
    secondaryCta={{ label: "Launch epanet-js", href: "https://app.epanetjs.com" }}>
    <MediaPlaceholder
      slot="media"
      label="Concept: demand being allocated across a network, with consumption profiles balancing against metered inflow."
    />
  </PageHero>

  <ContentMediaRow
    eyebrow="The problem"
    title="Demand is where models drift from reality">
    <p>
      A model is only as good as the demand it's built on. Getting consumption,
      profiles, and zonal balance right is painstaking work — and when it's
      wrong, every downstream result is too.
    </p>
    <p>
      Flow balance in epanet-js is designed to make this faster and more
      accurate, so you can trust the loading on your network.
    </p>
    <MediaPlaceholder
      slot="media"
      kind="image"
      label="Concept diagram: metered inflow reconciled against allocated consumption across demand zones."
    />
  </ContentMediaRow>

  <BenefitGrid
    eyebrow="What it will do"
    heading="Flow balance, the epanet-js way"
    items={benefits}
    columns={4}
  />

  <CardGrid
    heading="Available now"
    subheading="While flow balance is in development, explore what you can do today."
    items={related}
    columns={3}
  />

  <CtaSection
    heading="Want flow balance for your network?"
    subheading="Tell us how you handle demand today — it helps us build the right thing."
    primaryCta={{ label: "Talk to us", href: "https://cal.com/epanet-js/" }}
    secondaryCta={{ label: "Launch epanet-js", href: "https://app.epanetjs.com" }}
  />
</Layout>
