---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ProseSection from "@components/marketing/ProseSection.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import Media from "@components/marketing/Media.astro";
import NetworkMap from "@components/demos/NetworkMap.astro";
import LegendPanel from "@components/demos/LegendPanel.astro";
import LoggerPlacementDemo from "@components/demos/LoggerPlacementDemo.astro";
import HydrantTestPlanDemo from "@components/demos/HydrantTestPlanDemo.astro";
import FieldDataImportDemo from "@components/demos/FieldDataImportDemo.astro";
import BenefitGrid from "@components/marketing/BenefitGrid.astro";
import CardGrid from "@components/marketing/CardGrid.astro";
import FaqList from "@components/marketing/FaqList.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import { solutions } from "@config/navigation";
import { Crosshair, MapPin, ClipboardList, Workflow } from "lucide-react";

export const prerender = true;
const lang = "en";

const benefits = [
  {
    icon: Crosshair,
    title: "Measure the right things",
    description:
      "Plan where to record pressures and flows so the data you collect actually constrains the model.",
  },
  {
    icon: MapPin,
    title: "Optimized placement",
    description:
      "Let a search find the monitoring locations that tell you the most about how your network behaves.",
  },
  {
    icon: ClipboardList,
    title: "A clear field plan",
    description:
      "Turn the analysis into a practical, shareable plan your field crews can follow on the ground.",
  },
  {
    icon: Workflow,
    title: "Feeds straight into calibration",
    description:
      "Collect the measurements that make calibration faster and the resulting model more trustworthy.",
  },
];

const related = solutions.columns
  .flatMap((c) => c.items)
  .filter((i) => i.href !== "/solutions/field-planning")
  .slice(0, 3);

const faqs = [
  {
    question: "How do I plan logger placement?",
    answer:
      "The logger optimization tool lets you drop loggers on the map and see their listening range instantly, or run an automatic search that finds the layout giving the best coverage for the least cost. It runs on our <a href=\"https://utils.epanetjs.com/\" target=\"_blank\" rel=\"noopener noreferrer\">utilities site</a>.",
  },
  {
    question: "How does the automatic optimization work?",
    answer:
      "A genetic algorithm searches thousands of placement combinations and converges on layouts that maximize coverage while minimizing the number of loggers, so you get strong coverage without over-deploying.",
  },
  {
    question: "Does it cover pressure and flow loggers too?",
    answer:
      "The same placement thinking extends to pressure and flow monitoring: choosing the locations whose measurements most reduce uncertainty in the model, so a calibration campaign is designed rather than guessed.",
  },
  {
    question: "How does this connect to calibration?",
    answer:
      "Directly. A field plan defines what to measure and where; the data you bring back is exactly what <a href=\"/solutions/calibration\">calibration</a> uses to tune the model. Planning the campaign well is what makes the calibration that follows fast and trustworthy.",
  },
];
---

<Layout
  title="Field planning"
  description="Design the field data campaign that makes your model trustworthy. Plan logger coverage, optimize monitoring placement, and collect the measurements that feed calibration."
  lang={lang}>
  <PageHero
    title="Design the field campaign that makes your model trustworthy"
    subtitle="Plan where to place loggers and what to measure so you constrain the model with the right data, in the right places, the first time. The campaign that makes the calibration that follows fast and defensible.">
    <div slot="media">
      <div
        class="relative mx-auto aspect-[3/2] w-full max-w-[480px] overflow-hidden rounded-xl border border-gray-200 shadow-lg bg-white select-none"
        role="img"
        aria-label="Diagram: a water network map with a proposed monitoring point placed on it for a field campaign.">
        <svg
          viewBox="0 0 480 320"
          preserveAspectRatio="xMidYMid meet"
          class="absolute inset-0 h-full w-full"
          aria-hidden="true">
          <foreignObject x="0" y="0" width="480" height="320">
            <div {...{ xmlns: "http://www.w3.org/1999/xhtml" }} class="relative h-full w-full">
              <NetworkMap markers class="absolute inset-0" />
              <LegendPanel
                title="Field campaign"
                entries={[{ color: "#8b5cf6", label: "Proposed monitoring point" }]}
                class="absolute bottom-4 left-4"
              />
            </div>
          </foreignObject>
        </svg>
      </div>
    </div>
  </PageHero>

  <ProseSection
    title="Good models start with good field data">
    <p>
      A calibration is only as strong as the measurements behind it. Where you
      put loggers, what you measure, and when, decides whether a campaign
      constrains your model or wastes a week of crew time on data that tells you
      nothing new.
    </p>
    <p>
      Field planning is about making those choices deliberately, before anyone
      goes out. Plan the campaign well and the calibration that follows is
      faster, cheaper, and far more trustworthy.
    </p>
  </ProseSection>

  <ContentMediaRow
    title="Plan logger coverage on the map">
    <p>
      Field planning starts on the map. Drop acoustic
      loggers onto the network and see each one's listening range immediately, so
      coverage is something you can see and shape rather than estimate. Test
      deployment ideas on the fly, moving loggers until the gaps close.
    </p>
    <p>
      It turns logger planning from a spreadsheet exercise into a visual one,
      where the coverage you're buying is right there on the map.
    </p>
    <Media
      slot="media"
      src="/assets/blog/progress-report/2025-11/acoustic-logger.mp4"
    />
  </ContentMediaRow>

  <ContentMediaRow
    title="Optimize placement automatically"
    reverse>
    <p>
      Placing loggers by hand is fine for a few. For a real network, the number
      of possible layouts is enormous. An automatic search — a genetic algorithm
      — works through thousands of combinations and finds the layouts that
      maximize coverage while keeping the number of loggers down.
    </p>
    <p>
      You get strong, defensible coverage without over-deploying, and a starting
      point you can adjust with local knowledge. The logger optimization tool is
      live on our utilities site today.
    </p>
    <LoggerPlacementDemo slot="media" />
  </ContentMediaRow>

  <ContentMediaRow
    title="Measure what the model is least sure about">
    <p>
      The same placement thinking extends beyond acoustic loggers to pressure and
      flow monitoring for calibration. Rather than spreading sensors evenly,
      field planning chooses the locations whose measurements most reduce
      uncertainty in the model, the points where new data changes what you know.
    </p>
    <p>
      Planned hydrant tests follow the same logic, putting a controlled,
      high-flow stress on the parts of the network the model is least sure
      about.
    </p>
    <p>
      That turns a calibration campaign into something designed against the
      model, not assembled from habit and hydrant access.
    </p>
    <HydrantTestPlanDemo slot="media" />
  </ContentMediaRow>

  <ContentMediaRow
    title="From plan to data to a calibrated model"
    reverse>
    <p>
      Field planning is the first step in a loop that runs through the whole tool:
      plan the campaign, send crews to the chosen locations, bring the
      measurements back in, and calibrate against them. Because it all lives in
      one place, the plan you make here lines up exactly with the data
      calibration expects.
    </p>
    <p>
      No exporting coordinates to one tool, results to another, and reconciling
      them by hand. The campaign and the model are part of the same workflow.
    </p>
    <FieldDataImportDemo slot="media" />
  </ContentMediaRow>

  <BenefitGrid
    heading="Field planning, the epanet-js way"
    items={benefits}
    columns={4}
  />

  <CtaSection
    heading="Plan your next field campaign"
    subheading="See logger coverage on the map and design the campaign before a crew rolls."
    dark={false}
  />

  <ProseSection
    title="The campaign and the model, in one place">
    <p>
      Field planning exists to serve
      <a href="/solutions/calibration" class="font-medium text-indigo-600 hover:text-indigo-800 transition-colors">calibration</a>:
      the measurements you plan here are the observed pressures and flows it tunes
      against. Plan the campaign on the same network you'll calibrate, and the
      data comes back ready to use. Logger optimization runs on the
      <a href="https://utils.epanetjs.com/" target="_blank" rel="noopener noreferrer" class="font-medium text-indigo-600 hover:text-indigo-800 transition-colors">utilities site</a>.
    </p>
  </ProseSection>

  <CardGrid
    heading="Where to next"
    subheading="Field data feeds the rest of the modeling workflow."
    items={related}
    columns={3}
  />

  <FaqList
    subheading="How planning a field campaign works with epanet-js."
    items={faqs}
  />

  <CtaSection
    heading="Make every measurement count"
    subheading="Plan coverage, optimize placement, and collect the data calibration needs. Launch epanet-js or book a demo."
  />
</Layout>
