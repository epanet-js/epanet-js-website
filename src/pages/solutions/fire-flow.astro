---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/marketing/PageHero.astro";
import ProseSection from "@components/marketing/ProseSection.astro";
import ContentMediaRow from "@components/marketing/ContentMediaRow.astro";
import MediaPlaceholder from "@components/marketing/MediaPlaceholder.astro";
import PullQuote from "@components/marketing/PullQuote.astro";
import BenefitGrid from "@components/marketing/BenefitGrid.astro";
import CardGrid from "@components/marketing/CardGrid.astro";
import FaqList from "@components/marketing/FaqList.astro";
import CtaSection from "@components/marketing/CtaSection.astro";
import { solutions } from "@config/navigation";
import { CheckCircle2, Network, AlertTriangle, ClipboardCheck } from "lucide-react";

export const prerender = true;
const lang = "en";

const benefits = [
  {
    icon: CheckCircle2,
    title: "Defensible capacity answers",
    description:
      "Know the available fire flow at any hydrant or node, at the residual pressure you need to hold.",
  },
  {
    icon: Network,
    title: "The whole network, one run",
    description:
      "Test every hydrant and junction together instead of editing demands one location at a time.",
  },
  {
    icon: AlertTriangle,
    title: "Catch hidden constraints",
    description:
      "Design checks flag low pressures and high velocities elsewhere, so a pass at the hydrant is a real pass.",
  },
  {
    icon: ClipboardCheck,
    title: "Built for planning enquiries",
    description:
      "Right-click any point for an instant capacity curve, then export straight to GIS or CSV.",
  },
];

const related = solutions.columns
  .flatMap((c) => c.items)
  .filter((i) => i.href !== "/solutions/fire-flow")
  .slice(0, 3);

const faqs = [
  {
    question: "What's the difference between the two tools?",
    answer:
      "The <strong>fire flow analysis</strong> tests many locations across the network at once and reports available or design fire flow for each. The <strong>pressure and flow analysis</strong> focuses on a single point and gives a full pressure-versus-flow curve. Use the first to find weak spots system-wide, and the second to understand one location in depth.",
  },
  {
    question: "What does \"available fire flow\" mean?",
    answer:
      "It's the maximum flow a location can deliver while still holding a minimum residual pressure that you set. It answers how much capacity a hydrant or node actually has.",
  },
  {
    question: "Can I test against a required flow rate?",
    answer:
      "Yes. Set a design flow, such as 500 gpm, and the analysis reports the residual pressure the network holds while delivering it, so you can check it against your requirement.",
  },
  {
    question: "Does it check the rest of the network, not just the test point?",
    answer:
      "Yes. The design fire flow check looks at minimum pressures and maximum velocities across the network, so a result that passes at the hydrant doesn't hide a problem upstream.",
  },
  {
    question: "Can I run it across every hydrant?",
    answer:
      "Yes. The fire flow analysis works through every hydrant or junction you have represented and reports a result for each, mapped across the network.",
  },
  {
    question: "Can I export the results?",
    answer:
      "Yes. Results export to GIS or CSV, ready for reports, capacity registers, or further analysis in your own tools.",
  },
  {
    question: "Do I have to change demands to run a fire flow test?",
    answer:
      "No. Both tools handle the test setup for you, so there are no manual demand edits or workarounds to manage.",
  },
];
---

<Layout
  title="Fire flow"
  description="Test the fire flow capacity of every hydrant in your network, check available flow against your residual pressure target, and read a full pressure and flow curve for any point."
  lang={lang}>
  <PageHero
    eyebrow="Fire flow"
    title="Test the capacity of your network, hydrant by hydrant"
    subtitle="Run fire flow across every hydrant and junction, check available flow against your residual pressure target, and map where capacity runs short. Then dig into any single point with a full pressure and flow curve.">
    <MediaPlaceholder
      slot="media"
      label="Screen capture: a fire flow analysis sweeping the network, with each hydrant colored by available flow at the target residual pressure."
    />
  </PageHero>

  <ProseSection
    eyebrow="Why it matters"
    title="Capacity questions arrive constantly, and they're hard to answer by hand">
    <p>
      Can the network support a new development? Will this hydrant deliver the
      required fire flow at an acceptable residual pressure? Where does the
      system run short, and what would it take to fix it? Questions like these
      come in from planners, fire departments, and developers all the time, and
      answering them by editing EPANET demands one location at a time is slow and
      easy to get wrong.
    </p>
    <p>
      epanet-js gives you two purpose-built tools for this. A <strong>fire flow
      analysis</strong> tests the whole network at once, and a <strong>pressure
      and flow analysis</strong> lets you dig into any single point. Together
      they answer almost every capacity question you'll be asked.
    </p>
  </ProseSection>

  <ContentMediaRow
    eyebrow="Fire flow analysis"
    title="Test every hydrant and junction in one run">
    <p>
      Point the fire flow analysis at your hydrants, junctions, or whatever you
      use to represent demand points, and it works through them one by one. For
      each location it can answer three different questions:
    </p>
    <ul class="list-disc space-y-3 pl-5 marker:text-purple-400">
      <li>
        <strong>Available fire flow</strong> — the default. The maximum flow the
        location can deliver while holding a minimum residual pressure you set.
        This is the “how much have I got?” answer.
      </li>
      <li>
        <strong>Design fire flow</strong> — set a target flow rate, say 500 gpm,
        and the analysis reports the residual pressure the network can hold while
        delivering it. This is the “does it meet the requirement?” answer.
      </li>
      <li>
        <strong>Design fire flow with system limits</strong> — the same
        target-flow test, checked against wider constraints across the network,
        including minimum pressures and maximum velocities, so a pass at the
        hydrant doesn't hide a problem somewhere else.
      </li>
    </ul>
    <MediaPlaceholder
      slot="media"
      kind="image"
      label="Screenshot: the fire flow setup with a residual pressure target and a choice of available, design, or design-with-limits mode."
    />
  </ContentMediaRow>

  <PullQuote>
    Instead of editing demands by hand for one hydrant at a time, you test the
    whole network in a single run.
  </PullQuote>

  <ContentMediaRow
    eyebrow="Pressure and flow analysis"
    title="Right-click any point for a full capacity curve"
    reverse>
    <p>
      Sometimes you don't need the whole network. You need to understand one
      location in depth. Right-click a point and the pressure and flow analysis
      builds a hydraulic curve for it: across a range of flows, 0, 5, 10, 15, 20
      L/s and up, it shows how far the pressure drops. In a few seconds you can
      read exactly how much capacity is there and where it gives out.
    </p>
    <p>
      It's the quickest way to answer a development enquiry. Because the impact
      shows up visually, you can see how velocity and flow change through the
      system and pick out the critical assets that constrain it.
    </p>
    <MediaPlaceholder
      slot="media"
      label="Screen capture: right-clicking a node to produce a pressure-versus-flow curve, with the affected pipes highlighted on the map."
    />
  </ContentMediaRow>

  <PullQuote>
    For a planning department, it turns a week-long capacity enquiry into a
    right-click.
  </PullQuote>

  <ContentMediaRow
    eyebrow="See it and share it"
    title="Map capacity at a glance, then take it anywhere">
    <p>
      Both tools produce a visualization across the network, so the places with
      spare capacity and the places running short stand out immediately on the
      map. Color-coded results turn a table of numbers into a picture an engineer
      or a planner can read in seconds.
    </p>
    <p>
      When you need to take it further, export the results to GIS or CSV and use
      them wherever your work lives: a report, a GIS layer, a capacity register,
      or a response to a developer.
    </p>
    <MediaPlaceholder
      slot="media"
      kind="image"
      label="Screenshot: the network color-coded by available capacity, with an export menu for GIS and CSV."
    />
  </ContentMediaRow>

  <BenefitGrid
    eyebrow="Outcomes"
    heading="What fire flow analysis gives you"
    items={benefits}
    columns={4}
  />

  <CtaSection
    heading="Check your network's capacity"
    subheading="Run a fire flow analysis on your own model. Launch epanet-js, or book a demo to see it on your network."
    dark={false}
  />

  <ProseSection
    eyebrow="Who it's for"
    title="From fire flow compliance to development reviews">
    <p>
      Utilities use fire flow analysis to keep a live picture of capacity and to
      prioritize reinforcement where the network falls short. Consultants use it
      for capacity studies and to answer development enquiries with evidence
      rather than estimates. Planning departments lean on the pressure and flow
      analysis to understand, quickly and visually, whether the network can
      support what's being proposed.
    </p>
    <p>
      One tool, working on the same model, answers for all of them. There are no
      separate spreadsheets and no one-off demand hacks to keep track of.
    </p>
  </ProseSection>

  <CardGrid
    heading="Where to next"
    subheading="Fire flow is one part of understanding your network."
    items={related}
    columns={3}
  />

  <FaqList
    eyebrow="FAQ"
    subheading="The questions teams ask most about fire flow and capacity analysis in epanet-js."
    items={faqs}
  />

  <CtaSection
    heading="Answer your next capacity question in minutes"
    subheading="See fire flow and pressure-and-flow analysis on your own network. Launch epanet-js or book a demo."
  />
</Layout>
