export const prerender = true;
const lang = "en";

// How an entry is wrapped in its preview area. `window` and `diagram`
// components frame themselves; `panel` and `map` need a sized box.
type Frame = "window" | "diagram" | "panel" | "map";

interface DemoEntry {
  name: string;
  description: string;
  useOn: string;
  frame: Frame;
  /** Routes currently using the component. Absent or empty means new. */
  usedOn?: string[];
  /** Depicts an unshipped feature; pages must caption it as a concept. */
  concept?: boolean;
  component: any;
  props?: Record<string, unknown>;
  previewClass?: string;
}

interface DemoSection {
  id: string;
  title: string;
  entries: DemoEntry[];
}

const frameClass: Record<Frame, string> = {
  window: "w-full",
  diagram: "w-full",
  panel: "w-full max-w-[300px] mx-auto",
  map: "w-full aspect-[16/10] rounded-xl border border-gray-200 overflow-hidden bg-gray-100",
};

