const usageBadge = (entry: DemoEntry) =>
  entry.usedOn?.length
    ? `In use on ${entry.usedOn.length} page${entry.usedOn.length === 1 ? "" : "s"}`
    : "New";
---

<Layout
  title="Animation gallery"
  description="Internal reference of the animated demo components used across the site."
  lang={lang}
  noindex>
  <Container class="py-12 md:py-16">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
        Animation gallery
      </h1>
      <p class="mt-3 text-gray-600 md:text-lg">
        Every animated demo component in <code
          class="text-sm bg-gray-100 rounded px-1.5 py-0.5">
          src/components/demos/
        </code>, with a short description and where each one could be used.
        Internal reference: not linked from navigation and excluded from search
        engines.
      </p>
    </header>

    <nav class="mt-6 flex flex-wrap gap-x-4 gap-y-1 text-sm">
      {
        sections.map((section) => (
          <a
            href={`#${section.id}`}
            class="text-indigo-600 hover:text-indigo-800 underline hover:no-underline">
            {section.title}
          </a>
        ))
      }
    </nav>

    {
      sections.map((section) => (
        <section id={section.id} class="mt-14 scroll-mt-24">
          <h2 class="text-2xl font-bold tracking-tight md:text-3xl">
            {section.title}
          </h2>
          {section.entries.length === 0 ? (
            <p class="mt-4 text-sm text-gray-400">No components yet.</p>
          ) : (
            <div class="mt-6 grid gap-6 lg:grid-cols-2 items-start">
              {section.entries.map((entry) => (
                <article class="flex flex-col rounded-xl border border-gray-200 shadow-sm bg-white overflow-hidden [content-visibility:auto] [contain-intrinsic-size:auto_480px]">
                  <div class="flex items-center justify-center bg-gray-50 border-b border-gray-100 p-4 sm:p-6">
                    <div class={entry.previewClass ?? frameClass[entry.frame]}>
                      <entry.component {...(entry.props ?? {})} />
                    </div>
                  </div>
                  <div class="p-5">
                    <div class="flex items-center justify-between gap-3 flex-wrap">
                      <h3 class="font-mono text-sm font-semibold text-gray-900">
                        {entry.name}
                      </h3>
                      <div class="flex items-center gap-1.5">
                        <Badge
                          color={entry.usedOn?.length ? "DEFAULT" : "purple"}
                          class="!px-2 !py-0.5 !text-[11px] whitespace-nowrap">
                          {usageBadge(entry)}
                        </Badge>
                        {entry.concept && (
                          <Badge
                            color="orange"
                            class="!px-2 !py-0.5 !text-[11px] whitespace-nowrap">
                            Concept
                          </Badge>
                        )}
                      </div>
                    </div>
                    <p class="mt-2 text-sm text-gray-500">{entry.description}</p>
                    <p class="mt-2 text-xs text-gray-500">
                      <span class="font-medium text-gray-600">Use it on:</span>{" "}
                      {entry.useOn}
                    </p>
                    {entry.usedOn?.length && (
                      <p class="mt-1 text-xs text-gray-400">
                        {entry.usedOn.join(" · ")}
                      </p>
                    )}
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>
      ))
    }
  </Container>
</Layout>
